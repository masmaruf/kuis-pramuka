---
/**
 * SemaphoreQuiz.astro - Specialized Semaphore Flag Signal Quiz Component
 * Komponen kuis khusus untuk Sinyal Bendera Semaphore dengan visualisasi SVG
 * 
 * TypeScript enabled with strict type checking
 */

import type { QuizModule, Question, GameModeType, Badge } from '../types/quiz';

interface Props {
  quizId: string;
  level?: string;
  totalQuestions?: number;
  mode?: GameModeType;
}

const { quizId, level, totalQuestions = 10, mode = 'standard' } = Astro.props;

// Semaphore-specific types
interface SemaphoreQuizData extends QuizModule {
  semaphoreAngles: Record<string, { left: number; right: number }>;
  hasAudio: boolean;
  hasVisual: boolean;
}

interface SemaphoreQuestion extends Question {
  type: 'letter' | 'word';
  value: string;
}

// Game modes configuration
const GAME_MODES: Record<GameModeType, { xpMultiplier: number; timeLimit?: number; lives?: number }> = {
  standard: { xpMultiplier: 1.0 },
  time_attack: { xpMultiplier: 1.5, timeLimit: 300 },
  no_mistake: { xpMultiplier: 2.0, lives: 1 },
  daily: { xpMultiplier: 1.2 },
  duel: { xpMultiplier: 1.5 },
  survival: { xpMultiplier: 1.0 }
} as const;

const currentMode = GAME_MODES[mode];

// Difficulty colors and labels
const DIFFICULTY_COLORS: Record<string, string> = {
  easy: 'green',
  medium: 'red',
  hard: 'yellow',
  mix: 'purple'
} as const;

const DIFFICULTY_LABELS: Record<string, string> = {
  easy: 'Mudah',
  medium: 'Sedang',
  hard: 'Sulit',
  mix: 'Campuran'
} as const;

// Badge definitions for Semaphore module
const SEMAPHORE_BADGES: Record<string, Badge> = {
  semaphore_novice: {
    id: 'semaphore_novice',
    name: 'Isyarat Angin',
    description: 'Selesaikan 1 kuis Semaphore',
    icon: '🚩',
    category: 'Semaphore',
    rarity: 'common'
  },
  semaphore_expert: {
    id: 'semaphore_expert',
    name: 'Ahli Bendera',
    description: 'Selesaikan kuis Semaphore dengan skor 100%',
    icon: '🎌',
    category: 'Semaphore',
    rarity: 'rare'
  }
} as const;

// State for quiz data
let quizData: SemaphoreQuizData | null = null;
let questions: SemaphoreQuestion[] = [];
let quizMetadata: Partial<SemaphoreQuizData> = {};
let semaphoreAngles: Record<string, { left: number; right: number }> = {};
let helpContent: { title: string; content: string } | null = null;

// Load Semaphore quiz data
try {
  const semaphoreQuiz: SemaphoreQuizData = await import(`../data/quizzes/${quizId}.json`).then(m => m.default);
  quizData = semaphoreQuiz;
  questions = semaphoreQuiz.questions || [];
  quizMetadata = { ...quizMetadata, ...semaphoreQuiz };
  semaphoreAngles = semaphoreQuiz.semaphoreAngles || {};
  helpContent = semaphoreQuiz.helpContent || null;
} catch (e: unknown) {
  console.error('Failed to load Semaphore quiz data:', quizId, e);
  // Fallback empty data
  questions = [];
  quizMetadata = {
    id: quizId,
    title: 'Semaphore (Sinyal Bendera)',
    description: 'Latihan semaphore pramuka interaktif',
    category: 'Komunikasi & Isyarat',
    difficulty: 'medium',
    xpPerQuestion: 15,
    totalQuestions: 12,
    color: 'green',
    icon: '🚩',
    hasAudio: false,
    hasVisual: true
  };
  semaphoreAngles = {
    'A': { left: 315, right: 0 },
    'B': { left: 270, right: 0 },
    'C': { left: 225, right: 0 },
    'D': { left: 180, right: 0 },
    'E': { left: 0, right: 135 },
    'F': { left: 0, right: 90 },
    'G': { left: 0, right: 45 },
    'H': { left: 315, right: 270 },
    'I': { left: 315, right: 225 },
    'J': { left: 180, right: 90 },
    'K': { left: 315, right: 180 },
    'L': { left: 315, right: 135 },
    'M': { left: 315, right: 90 },
    'N': { left: 315, right: 45 },
    'O': { left: 270, right: 225 },
    'P': { left: 270, right: 180 },
    'Q': { left: 270, right: 135 },
    'R': { left: 270, right: 90 },
    'S': { left: 270, right: 45 },
    'T': { left: 225, right: 180 },
    'U': { left: 225, right: 135 },
    'V': { left: 180, right: 45 },
    'W': { left: 135, right: 90 },
    'X': { left: 135, right: 45 },
    'Y': { left: 225, right: 90 },
    'Z': { left: 45, right: 90 }
  };
}

// Shuffle questions and limit to totalQuestions
function getShuffledQuestions(questionsPool: SemaphoreQuestion[], count: number): SemaphoreQuestion[] {
  const shuffled = [...questionsPool].sort(() => 0.5 - Math.random());
  return shuffled.slice(0, Math.min(count, shuffled.length));
}

const selectedQuestions: SemaphoreQuestion[] = getShuffledQuestions(questions, totalQuestions);
const xpPerQuestion: number = quizMetadata.xpPerQuestion || 15;
const difficulty: string = quizMetadata.difficulty || 'medium';
const quizColor: string = quizMetadata.color || 'green';
const quizIcon: string = quizMetadata.icon || '🚩';
const quizCategory: string = quizMetadata.category || 'Komunikasi & Isyarat';
const hasAudio: boolean = quizMetadata.hasAudio || false;
const hasVisual: boolean = quizMetadata.hasVisual || true;

// Calculate XP multiplier based on mode
const xpMultiplier: number = currentMode.xpMultiplier;

// Helper function to build class names
function buildClass(baseClass: string, modifier: string): string {
  return baseClass + ' ' + modifier;
}
---

<div class="semaphore-quiz-container" data-quiz-id={quizId} data-level={level} data-mode={mode}>
  <header class="semaphore-quiz-header glass-card">
    <a href="/" class="btn-back">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="19" y1="12" x2="5" y2="12"/>
        <polyline points="12 19 5 12 12 5"/>
      </svg>
      Kembali ke Dasbor
    </a>
    <div class="semaphore-quiz-title-area">
      <h2>{quizMetadata.title || 'Kuis Semaphore'}</h2>
      <span class={buildClass('quiz-difficulty', DIFFICULTY_COLORS[difficulty] || 'medium')}>
        {DIFFICULTY_LABELS[difficulty] || 'Sedang'}
      </span>
    </div>
  </header>

  <div class="semaphore-quiz-layout" id="semaphore-quiz-layout">
    <div class="semaphore-main-card glass-card">
      <div class="progress-tracker">
        <span id="semaphore-question-number">Soal 1 dari {totalQuestions}</span>
        <div class="progress-bar-outer">
          <div id="semaphore-progress-bar" class="progress-bar-inner" style="width: 10%"></div>
        </div>
      </div>

      {mode === 'time_attack' && (
        <div class="mode-display timer-display">
          <span class="mode-icon">⏱️</span>
          <span id="semaphore-timer">{currentMode.timeLimit || 300}</span> detik
        </div>
      )}
      
      {mode === 'no_mistake' && (
        <div class="mode-display lives-display">
          <span class="mode-icon">❤️</span>
          <span id="semaphore-lives">{currentMode.lives || 1}</span>
        </div>
      )}

      <!-- Semaphore Visualizer Screen -->
      <div class="stimulus-display">
        <div class="visualizer-container">
          <svg id="semaphore-svg" viewBox="0 0 200 200" class="semaphore-svg">
            <!-- Grid / Horizon reference line -->
            <line x1="20" y1="140" x2="180" y2="140" stroke="rgba(255, 255, 255, 0.05)" stroke-width="2" />
            
            <!-- Stand/Ground -->
            <line x1="100" y1="140" x2="100" y2="180" stroke="var(--color-primary-dark)" stroke-width="6" />
            
            <!-- Human Body Torso & Head -->
            <circle cx="100" cy="75" r="14" stroke="var(--color-text)" stroke-width="3" fill="var(--color-bg)" />
            <line x1="100" y1="89" x2="100" y2="140" stroke="var(--color-text)" stroke-width="4" />
            
            <!-- Legs -->
            <line x1="100" y1="140" x2="85" y2="180" stroke="var(--color-text)" stroke-width="3.5" />
            <line x1="100" y1="140" x2="115" y2="180" stroke="var(--color-text)" stroke-width="3.5" />

            <!-- Left Arm & Flag (Rendered dynamically) -->
            <g id="left-arm-group">
              <line id="left-arm" x1="100" y1="95" x2="70" y2="125" stroke="var(--color-text)" stroke-width="3.5" stroke-linecap="round" />
              <polygon id="left-flag" points="70,125 50,145 70,165" fill="var(--color-gold)" stroke="#b93b22" stroke-width="1.5" />
            </g>
            
            <!-- Right Arm & Flag (Rendered dynamically) -->
            <g id="right-arm-group">
              <line id="right-arm" x1="100" y1="95" x2="130" y2="125" stroke="var(--color-text)" stroke-width="3.5" stroke-linecap="round" />
              <polygon id="right-flag" points="130,125 150,145 130,165" fill="var(--color-gold)" stroke="#b93b22" stroke-width="1.5" />
            </g>

            <!-- Shoulder anchor decoration -->
            <circle cx="100" cy="95" r="4" fill="var(--color-gold)" />
          </svg>
        </div>
        <div id="semaphore-word-reveal" class="word-reveal" style="display: none;">
          <div class="reveal-letters" id="semaphore-reveal-letters-container"></div>
          <div class="word-controls">
            <button id="btn-semaphore-replay-word" class="btn btn-secondary btn-sm">Putar Ulang Kata 🔁</button>
          </div>
        </div>
      </div>

      <!-- Question Prompt -->
      <div class="question-text-area">
        <h3 id="semaphore-question-prompt">{selectedQuestions[0]?.question || 'Memuat soal...'}</h3>
      </div>

      <!-- Options Grid -->
      <div class="flex flex-col gap-2" id="semaphore-options-container"></div>

      <!-- Education Card -->
      <div class="education-card" id="semaphore-education-card" style="display: none;">
        <div class="edu-header">
          <span class="edu-icon">🚩</span>
          <span class="edu-label">Posisi Bendera Semaphore</span>
        </div>
        <p id="semaphore-education-text"></p>
      </div>

      <!-- Actions -->
      <div class="action-footer">
        <button id="btn-semaphore-submit-answer" class="btn btn-gold" disabled>Konfirmasi Jawaban</button>
      </div>
    </div>

    <!-- Semaphore Learning Reference -->
    {helpContent && (
      <div class="semaphore-help-card glass-card" id="semaphore-help-sidebar">
        <h3 id="semaphore-help-sidebar-title">{helpContent.title}</h3>
        <div class="help-content-area" id="semaphore-help-sidebar-content" set:html={helpContent.content}></div>
        
        <div class="semaphore-guide-visual">
          <div class="guide-circle">
            <span class="g-dir dir-0" title="Utara (U / Up)">U</span>
            <span class="g-dir dir-45">NE</span>
            <span class="g-dir dir-90">E</span>
            <span class="g-dir dir-135">SE</span>
            <span class="g-dir dir-180" title="Selatan (S / Down)">S</span>
            <span class="g-dir dir-225">SW</span>
            <span class="g-dir dir-270">W</span>
            <span class="g-dir dir-315">NW</span>
            <div class="guide-center">⚜️</div>
          </div>
        </div>
        <p class="help-tip">Tips: Arah <strong>Selatan (S)</strong> adalah posisi tangan tegak lurus ke bawah. Arah <strong>Utara (U)</strong> adalah tegak lurus ke atas.</p>
      </div>
    )}
  </div>

  <!-- Result Overlay -->
  <div class="result-overlay" id="semaphore-result-overlay" style="display: none;">
    <div class="result-card glass-card">
      <div class="result-emoji" id="semaphore-result-emoji">🏆</div>
      <h2>Kuis Selesai!</h2>
      <p class="result-summary" id="semaphore-result-text"></p>
      
      <div class="result-stats-details">
        <div class="detail-item">
          <span class="label">XP Diperoleh</span>
          <span class="value score-xp" id="semaphore-result-xp">+0 XP</span>
        </div>
        <div class="detail-item">
          <span class="label">Skor Akhir</span>
          <span class="value" id="semaphore-result-score">0/100</span>
        </div>
        {mode === 'time_attack' && (
          <div class="detail-item">
            <span class="label">Waktu</span>
            <span class="value" id="semaphore-result-time">0 detik</span>
          </div>
        )}
      </div>

      <div class="unlocked-badges-container" id="semaphore-unlocked-badges" style="display: none;">
        <h3>🎖️ Lencana Baru Terbuka!</h3>
        <div class="unlocked-badges-list" id="semaphore-badges-list-el"></div>
      </div>

      <div class="result-actions">
        <button id="btn-semaphore-restart" class="btn btn-primary">Ulangi Kuis</button>
        <a href="/" class="btn btn-gold">Kembali ke Dasbor</a>
      </div>
    </div>
  </div>
</div>

<style>
  .semaphore-quiz-container { max-width: 1000px; margin: 0 auto; padding: 2rem 1.5rem; display: flex; flex-direction: column; gap: 2rem; }
  .semaphore-quiz-header { padding: 1.5rem 2rem; display: flex; flex-direction: column; gap: 0.75rem; }
  .btn-back { display: inline-flex; align-items: center; gap: 0.5rem; color: var(--color-text-muted); text-decoration: none; font-size: 0.9rem; font-weight: 500; width: max-content; transition: color var(--transition-fast); }
  .btn-back:hover { color: var(--color-gold); }
  .btn-back svg { width: 16px; height: 16px; }
  .semaphore-quiz-title-area { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; }
  .semaphore-quiz-title-area h2 { font-size: 1.5rem; font-weight: 800; color: var(--color-text); margin: 0; }
  .quiz-difficulty { font-size: 0.75rem; font-weight: 700; padding: 0.3rem 0.75rem; border-radius: 4px; text-transform: uppercase; }
  .quiz-difficulty.green { background: rgba(43, 112, 76, 0.12); color: #62c370; border: 1px solid rgba(43, 112, 76, 0.25); }
  .quiz-difficulty.medium { background: rgba(212, 163, 43, 0.1); color: var(--color-gold); border: 1px solid rgba(212, 163, 43, 0.25); }
  .quiz-difficulty.hard { background: rgba(185, 59, 34, 0.1); color: #e56b55; border: 1px solid rgba(185, 59, 34, 0.25); }
  
  .semaphore-quiz-layout { display: grid; grid-template-columns: 2.2fr 1fr; gap: 2rem; align-items: start; }
  @media (max-width: 900px) { .semaphore-quiz-layout { grid-template-columns: 1fr; } }
  
  .semaphore-main-card { padding: 2.5rem; display: flex; flex-direction: column; gap: 2rem; }
  .progress-tracker { display: flex; flex-direction: column; gap: 0.5rem; }
  .progress-tracker span { font-size: 0.85rem; color: var(--color-text-muted); font-weight: 600; }
  .progress-bar-outer { height: 6px; background: rgba(27, 77, 50, 0.1); border-radius: 50px; overflow: hidden; }
  .progress-bar-inner { height: 100%; background: linear-gradient(90deg, var(--color-primary), var(--color-gold)); border-radius: 50px; transition: width var(--transition-normal); }
  
  .mode-display { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.5rem 1rem; background: var(--color-bg); border-radius: 8px; font-size: 0.9rem; font-weight: 600; width: max-content; }
  
  /* Visualizer panel */
  .stimulus-display { background: rgba(27, 77, 50, 0.04); border: 1px solid var(--color-border); border-radius: 12px; padding: 1.5rem; display: flex; flex-direction: column; align-items: center; gap: 1rem; min-height: 250px; justify-content: center; }
  .visualizer-container { width: 200px; height: 200px; position: relative; }
  .semaphore-svg { width: 100%; height: 100%; }
  
  /* Animasi lengan agar perpindahan posisi bendera terasa smooth */
  #left-arm, #right-arm, #left-flag, #right-flag { transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1); transform-origin: 100px 95px; }
  #left-flag { fill: #d4a32b; }
  #right-flag { fill: #d4a32b; }
  
  /* Word Reveal Panel */
  .word-reveal { display: flex; flex-direction: column; align-items: center; gap: 0.75rem; width: 100%; }
  .reveal-letters-container { display: flex; gap: 0.5rem; justify-content: center; flex-wrap: wrap; }
  .reveal-letter-box { width: 32px; height: 32px; border-radius: 6px; background: var(--color-bg); border: 1px solid var(--color-border); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.9rem; color: var(--color-text-muted); }
  .reveal-letter-box.active { border-color: var(--color-gold); color: var(--color-gold); box-shadow: 0 0 8px rgba(212, 163, 43, 0.2); }
  .reveal-letter-box.revealed { background: rgba(43, 112, 76, 0.1); border-color: var(--color-success); color: var(--color-success); }
  .word-controls { margin-top: 0.25rem; }
  .btn-sm { padding: 0.4rem 0.9rem; font-size: 0.8rem; border-radius: 6px; }
  
  .question-text-area h3 { font-size: 1.15rem; font-weight: 600; color: var(--color-text); line-height: 1.4; }

  /* Options */
  .opt-btn { display: flex; align-items: center; gap: 1rem; padding: 1rem 1.25rem; border: 2px solid var(--color-border); border-radius: 10px; background: var(--color-bg); cursor: pointer; transition: all var(--transition-normal); text-align: left; position: relative; overflow: hidden; }
  .opt-btn:hover:not(.is-answered) { border-color: var(--color-gold); box-shadow: 0 4px 12px rgba(178, 131, 27, 0.2); }
  .opt-btn.is-selected { border-color: var(--color-gold); background: rgba(178, 131, 27, 0.08); }
  .opt-btn.is-correct { border-color: var(--color-success); background: rgba(43, 112, 76, 0.1); }
  .opt-btn.is-incorrect { border-color: var(--color-danger); background: rgba(185, 59, 34, 0.1); }
  .opt-btn.is-dimmed { opacity: 0.5; }
  .opt-btn.is-answered { cursor: not-allowed; }
  .opt-letter { font-size: 1.1rem; font-weight: 700; color: var(--color-text-muted); width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; border-radius: 50%; background: var(--color-border); flex-shrink: 0; }
  .opt-btn.is-selected .opt-letter, .opt-btn.is-correct .opt-letter, .opt-btn.is-incorrect .opt-letter { color: white; }
  .opt-btn.is-selected .opt-letter { background: var(--color-gold); }
  .opt-btn.is-correct .opt-letter { background: var(--color-success); }
  .opt-btn.is-incorrect .opt-letter { background: var(--color-danger); }
  .opt-text { flex: 1; font-size: 0.95rem; color: var(--color-text); line-height: 1.4; }
  .opt-indicator { display: flex; align-items: center; justify-content: center; width: 24px; height: 24px; border-radius: 50%; background: var(--color-bg); position: relative; }
  .opt-radio { width: 12px; height: 12px; border-radius: 50%; border: 2px solid var(--color-border); }
  .opt-btn.is-selected .opt-radio { border-color: var(--color-gold); background: var(--color-gold); }
  .opt-icon { width: 16px; height: 16px; position: absolute; display: none; }
  .opt-btn.is-correct .icon-check { display: block; }
  .opt-btn.is-incorrect .icon-cross { display: block; }

  /* Education Card */
  .education-card { border-radius: var(--radius-md); padding: 1rem 1.1rem; display: flex; flex-direction: column; gap: 0.5rem; animation: slide-in 0.2s ease; }
  .education-card.correct { background: rgba(35, 108, 50, 0.07); border: 1px solid rgba(35, 108, 50, 0.2); }
  .education-card.incorrect { background: rgba(165, 48, 26, 0.06); border: 1px solid rgba(165, 48, 26, 0.18); }
  @keyframes slide-in { from { opacity: 0; transform: translateY(-6px); } to { opacity: 1; transform: translateY(0); } }
  .edu-header { display: flex; align-items: center; gap: 0.45rem; }
  .edu-icon { font-size: 1rem; }
  .edu-label { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.8px; color: var(--color-primary-light); }
  .education-card.incorrect .edu-label { color: var(--color-danger); }
  #semaphore-education-text { font-size: 0.85rem; color: var(--color-text); line-height: 1.55; }
  
  .action-footer { display: flex; justify-content: flex-end; margin-top: 1rem; }
  #btn-semaphore-submit-answer { padding: 0.9rem 2rem; border-radius: 8px; }

  /* Help Card Sidebar */
  .semaphore-help-card { padding: 1.75rem; display: flex; flex-direction: column; gap: 1.25rem; }
  .semaphore-help-card h3 { font-size: 1.15rem; font-weight: 700; color: var(--color-text); }
  .help-content-area { font-size: 0.85rem; color: var(--color-text-muted); line-height: 1.5; }
  .help-content-area h4 { color: var(--color-text); margin: 0 0 0.5rem 0; }
  .help-content-area p { margin: 0 0 0.75rem 0; }
  .help-content-area strong { color: var(--color-text); }
  .help-content-area ul { margin: 0 0 0.75rem 0; padding-left: 1rem; }
  .help-content-area li { margin: 0.25rem 0; }
  
  .semaphore-guide-visual { display: flex; justify-content: center; padding: 1rem 0; }
  .guide-circle { width: 140px; height: 140px; border-radius: 50%; border: 2px dashed rgba(212, 163, 43, 0.25); position: relative; display: flex; align-items: center; justify-content: center; }
  .guide-center { font-size: 1.25rem; color: var(--color-gold); filter: drop-shadow(0 0 4px rgba(212, 163, 43, 0.2)); }
  .g-dir { position: absolute; font-size: 0.65rem; font-weight: 700; color: var(--color-text-muted); }
  .dir-0 { top: 6px; }
  .dir-45 { top: 22px; right: 22px; }
  .dir-90 { right: 8px; }
  .dir-135 { bottom: 22px; right: 22px; }
  .dir-180 { bottom: 6px; }
  .dir-225 { bottom: 22px; left: 22px; }
  .dir-270 { left: 8px; }
  .dir-315 { top: 22px; left: 22px; }
  .help-tip { font-size: 0.8rem; color: var(--color-text-muted); line-height: 1.35; border-left: 2px solid var(--color-gold); padding-left: 0.5rem; }
  .help-tip strong { color: var(--color-text); }

  /* Result Overlay */
  .result-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(7, 12, 9, 0.85); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); display: flex; align-items: center; justify-content: center; z-index: 1000; padding: 1.5rem; }
  .result-card { width: 100%; max-width: 550px; padding: 3rem 2.5rem; text-align: center; display: flex; flex-direction: column; align-items: center; gap: 1.5rem; animation: scale-up 0.3s cubic-bezier(0.34, 1.56, 0.64, 1); }
  .result-emoji { font-size: 4rem; }
  .result-card h2 { font-size: 2rem; font-weight: 800; color: #ffffff; }
  .result-summary { font-size: 1.05rem; color: var(--color-text-muted); line-height: 1.5; }
  .result-stats-details { display: flex; width: 100%; gap: 1.5rem; margin: 0.5rem 0; }
  .detail-item { flex: 1; background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.1); padding: 1.25rem; border-radius: 12px; display: flex; flex-direction: column; gap: 0.25rem; }
  .detail-item .label { font-size: 0.8rem; color: var(--color-text-muted); text-transform: uppercase; font-weight: 600; letter-spacing: 0.5px; }
  .detail-item .value { font-size: 1.6rem; font-weight: 800; color: white; }
  .detail-item .value.score-xp { color: var(--color-gold); }
  .unlocked-badges-container { width: 100%; background: rgba(212, 163, 43, 0.05); border: 1px solid rgba(212, 163, 43, 0.2); border-radius: 12px; padding: 1.25rem; text-align: left; }
  .unlocked-badges-container h3 { font-size: 1rem; font-weight: 700; color: var(--color-gold-light); margin-bottom: 0.75rem; text-align: center; }
  .unlocked-badges-list { display: flex; flex-direction: column; gap: 0.5rem; }
  .unlocked-badge-item { font-size: 0.9rem; color: var(--color-text); display: flex; align-items: center; gap: 0.5rem; }
  .unlocked-badge-item .u-icon { font-size: 1.25rem; }
  .result-actions { display: flex; gap: 1rem; width: 100%; margin-top: 1rem; }
  .result-actions button, .result-actions a { flex: 1; }
  
  @media (max-width: 768px) {
    .semaphore-quiz-layout { grid-template-columns: 1fr; }
    .options-grid { grid-template-columns: 1fr; }
    .semaphore-main-card { padding: 1.5rem; }
  }
  
  @keyframes scale-up { from { opacity: 0; transform: scale(0.9); } to { opacity: 1; transform: scale(1); } }
  
  .glass-card { background: var(--color-glass); backdrop-filter: blur(10px); border: 1px solid var(--color-border); border-radius: 16px; }
</style>

<script>
  // Type annotations for state
  let currentQuestions: SemaphoreQuestion[] = selectedQuestions;
  let currentQuestionIndex: number = 0;
  let selectedOptionIndex: number | null = null;
  let correctAnswersCount: number = 0;
  let timeLeft: number = currentMode.timeLimit || 0;
  let lives: number = currentMode.lives || Infinity;
  let startTime: number = 0;
  let timer: ReturnType<typeof setInterval> | null = null;
  let wordIntervalId: ReturnType<typeof setInterval> | null = null;
  let currentWordLetterIdx: number = 0;

  // DOM Elements with type annotations
  const semaphoreQuizLayout: HTMLElement | null = document.getElementById('semaphore-quiz-layout');
  const semaphoreQuestionPrompt: HTMLElement | null = document.getElementById('semaphore-question-prompt');
  const semaphoreWordReveal: HTMLElement | null = document.getElementById('semaphore-word-reveal');
  const semaphoreRevealLettersContainer: HTMLElement | null = document.getElementById('semaphore-reveal-letters-container');
  const semaphoreOptionsContainer: HTMLElement | null = document.getElementById('semaphore-options-container');
  const semaphoreQuestionNumber: HTMLElement | null = document.getElementById('semaphore-question-number');
  const semaphoreProgressBar: HTMLElement | null = document.getElementById('semaphore-progress-bar');
  const semaphoreSubmitBtn: HTMLButtonElement | null = document.getElementById('btn-semaphore-submit-answer') as HTMLButtonElement | null;
  const semaphoreEduCard: HTMLElement | null = document.getElementById('semaphore-education-card');
  const semaphoreEduText: HTMLElement | null = document.getElementById('semaphore-education-text');
  const semaphoreResultOverlay: HTMLElement | null = document.getElementById('semaphore-result-overlay');
  const semaphoreResultText: HTMLElement | null = document.getElementById('semaphore-result-text');
  const semaphoreResultXp: HTMLElement | null = document.getElementById('semaphore-result-xp');
  const semaphoreResultScore: HTMLElement | null = document.getElementById('semaphore-result-score');
  const semaphoreResultEmoji: HTMLElement | null = document.getElementById('semaphore-result-emoji');
  const semaphoreResultTimer: HTMLElement | null = document.getElementById('semaphore-timer');
  const semaphoreResultLives: HTMLElement | null = document.getElementById('semaphore-lives');
  const semaphoreResultTime: HTMLElement | null = document.getElementById('semaphore-result-time');
  const semaphoreUnlockedBadges: HTMLElement | null = document.getElementById('semaphore-unlocked-badges');
  const semaphoreBadgesListEl: HTMLElement | null = document.getElementById('semaphore-badges-list-el');
  const semaphoreRestartBtn: HTMLButtonElement | null = document.getElementById('btn-semaphore-restart') as HTMLButtonElement | null;
  const btnSemaphoreReplayWord: HTMLButtonElement | null = document.getElementById('btn-semaphore-replay-word') as HTMLButtonElement | null;

  // Semaphore visualization elements
  const leftArmEl: SVGGElement | null = document.getElementById('left-arm-group') as SVGGElement | null;
  const rightArmEl: SVGGElement | null = document.getElementById('right-arm-group') as SVGGElement | null;

  // Animation configuration
  const WORD_ANIMATION_SPEED: number = 1200; // ms per letter

  // Render SVG Semaphore
  function drawSemaphore(char: string): void {
    const upperChar: string = char.toUpperCase();
    const positions: { left: number; right: number } = semaphoreAngles[upperChar] || { left: 0, right: 0 };
    
    const shoulderX: number = 100;
    const shoulderY: number = 95;
    const armLength: number = 35;
    const flagLength: number = 22;

    // Convert degrees to radians (0 = Bawah, 90 = Kanan, 180 = Atas, 270 = Kiri)
    // Formula: Radian = (Sudut + 90) * PI / 180
    const radLeft: number = (positions.left + 90) * Math.PI / 180;
    const radRight: number = (positions.right + 90) * Math.PI / 180;

    const leftHandX: number = shoulderX + armLength * Math.cos(radLeft);
    const leftHandY: number = shoulderY + armLength * Math.sin(radLeft);
    
    const rightHandX: number = shoulderX + armLength * Math.cos(radRight);
    const rightHandY: number = shoulderY + armLength * Math.sin(radRight);

    // Update Left Arm
    const leftArmLine: SVGLineElement | null = document.getElementById('left-arm') as SVGLineElement | null;
    if (leftArmLine) {
      leftArmLine.setAttribute('x2', leftHandX.toString());
      leftArmLine.setAttribute('y2', leftHandY.toString());
    }

    // Update Left Flag
    const flagEndX: number = leftHandX + flagLength * Math.cos(radLeft);
    const flagEndY: number = leftHandY + flagLength * Math.sin(radLeft);
    const flagLeftX: number = leftHandX + flagLength * Math.cos(radLeft - 0.7);
    const flagLeftY: number = leftHandY + flagLength * Math.sin(radLeft - 0.7);

    const leftFlagEl: SVGPolygonElement | null = document.getElementById('left-flag') as SVGPolygonElement | null;
    if (leftFlagEl) {
      leftFlagEl.setAttribute('points', `${leftHandX},${leftHandY} ${flagEndX},${flagEndY} ${flagLeftX},${flagLeftY}`);
    }

    // Update Right Arm
    const rightArmLine: SVGLineElement | null = document.getElementById('right-arm') as SVGLineElement | null;
    if (rightArmLine) {
      rightArmLine.setAttribute('x2', rightHandX.toString());
      rightArmLine.setAttribute('y2', rightHandY.toString());
    }

    // Update Right Flag
    const flagEndXRight: number = rightHandX + flagLength * Math.cos(radRight);
    const flagEndYRight: number = rightHandY + flagLength * Math.sin(radRight);
    const flagLeftXRight: number = rightHandX + flagLength * Math.cos(radRight + 0.7);
    const flagLeftYRight: number = rightHandY + flagLength * Math.sin(radRight + 0.7);

    const rightFlagEl: SVGPolygonElement | null = document.getElementById('right-flag') as SVGPolygonElement | null;
    if (rightFlagEl) {
      rightFlagEl.setAttribute('points', `${rightHandX},${rightHandY} ${flagEndXRight},${flagEndYRight} ${flagLeftXRight},${flagLeftYRight}`);
    }
  }

  // Animasi mengeja kata
  function playWordSemaphore(word: string, speed: number = WORD_ANIMATION_SPEED): void {
    clearInterval(wordIntervalId);
    currentWordLetterIdx = 0;
    
    if (semaphoreRevealLettersContainer) {
      semaphoreRevealLettersContainer.innerHTML = '';
    }

    // Siapkan wadah visual ejaan huruf
    for (let i: number = 0; i < word.length; i++) {
      const box: HTMLSpanElement = document.createElement('span');
      box.className = 'reveal-letter-box';
      box.textContent = '?';
      if (semaphoreRevealLettersContainer) {
        semaphoreRevealLettersContainer.appendChild(box);
      }
    }

    function showNext(): void {
      if (currentWordLetterIdx >= word.length) {
        clearInterval(wordIntervalId);
        // Tahan di posisi netral/istirahat setelah kata selesai
        setTimeout(() => {
          drawSemaphore('A'); // Posisi default A (istirahat)
        }, 1000);
        return;
      }

      const char: string = word[currentWordLetterIdx];
      drawSemaphore(char);

      // Tandai box huruf yang sedang aktif
      const boxes: NodeListOf<HTMLElement> = document.querySelectorAll('.reveal-letter-box');
      if (boxes[currentWordLetterIdx]) {
        boxes[currentWordLetterIdx].classList.add('active');
        boxes[currentWordLetterIdx].textContent = '●';
      }

      currentWordLetterIdx++;
    }

    showNext();
    wordIntervalId = setInterval(showNext, speed) as unknown as ReturnType<typeof setInterval>;
  }

  // Render question
  function renderQuestion(): void {
    clearInterval(wordIntervalId);
    const question: SemaphoreQuestion | undefined = currentQuestions[currentQuestionIndex];
    
    if (!question) return;

    // Update header progress
    if (semaphoreQuestionNumber) {
      semaphoreQuestionNumber.textContent = `Soal ${currentQuestionIndex + 1} dari ${currentQuestions.length}`;
    }
    if (semaphoreProgressBar) {
      semaphoreProgressBar.style.width = `${((currentQuestionIndex + 1) / currentQuestions.length) * 100}%`;
    }

    if (semaphoreQuestionPrompt) {
      semaphoreQuestionPrompt.textContent = question.question;
    }

    if (semaphoreWordReveal) {
      if (question.type === 'word') {
        semaphoreWordReveal.style.display = 'flex';
        // Play word animation
        playWordSemaphore(question.value);
      } else {
        semaphoreWordReveal.style.display = 'none';
        // Draw single letter
        drawSemaphore(question.value);
      }
    }

    // Render options
    if (semaphoreOptionsContainer) {
      semaphoreOptionsContainer.innerHTML = '';
      question.options.forEach((option: string, index: number) => {
        const optionBtn: HTMLButtonElement = document.createElement('button');
        optionBtn.className = 'opt-btn';
        optionBtn.style.animationDelay = `${index * 0.06}s`;
        optionBtn.innerHTML = `
          <span class="opt-letter">${String.fromCharCode(65 + index)}</span>
          <span class="opt-text">${option}</span>
          <span class="opt-indicator">
            <span class="opt-radio"></span>
            <svg class="opt-icon icon-check" viewBox="0 0 24 24" fill="none" stroke="#236c32" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            <svg class="opt-icon icon-cross" viewBox="0 0 24 24" fill="none" stroke="#a5301a" stroke-width="2.5" stroke-linecap="round">
              <line x1="18" y1="6" x2="6" y2="18"/>
              <line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
          </span>
        `;
        optionBtn.addEventListener('click', () => selectOption(index));
        semaphoreOptionsContainer.appendChild(optionBtn);
      });
    }

    if (semaphoreEduCard) {
      semaphoreEduCard.style.display = 'none';
      if (semaphoreEduCard.classList.contains('correct')) {
        semaphoreEduCard.classList.remove('correct');
      }
      if (semaphoreEduCard.classList.contains('incorrect')) {
        semaphoreEduCard.classList.remove('incorrect');
      }
    }
    
    selectedOptionIndex = null;
    if (semaphoreSubmitBtn) {
      semaphoreSubmitBtn.disabled = true;
      semaphoreSubmitBtn.textContent = 'Konfirmasi Jawaban';
    }
  }

  // Select option
  function selectOption(index: number): void {
    if (!semaphoreSubmitBtn) return;
    if (semaphoreSubmitBtn.textContent === 'Soal Berikutnya' || semaphoreSubmitBtn.textContent === 'Lihat Hasil') return;
    selectedOptionIndex = index;
    document.querySelectorAll('.opt-btn').forEach((btn: Element, idx: number) => {
      btn.classList.toggle('is-selected', idx === index);
    });
    if (semaphoreSubmitBtn) {
      semaphoreSubmitBtn.disabled = false;
    }
  }

  // Submit answer
  function submitAnswer(): void {
    const question: SemaphoreQuestion | undefined = currentQuestions[currentQuestionIndex];
    if (!question || !semaphoreSubmitBtn) return;

    if (semaphoreSubmitBtn.textContent === 'Soal Berikutnya' || semaphoreSubmitBtn.textContent === 'Lihat Hasil') {
      nextQuestion();
      return;
    }

    const isCorrect: boolean = selectedOptionIndex !== null && question.options[selectedOptionIndex] === question.correctAnswer;

    document.querySelectorAll('.opt-btn').forEach((btn: Element, idx: number) => {
      btn.classList.add('is-answered');
      btn.classList.remove('is-selected');
      if (question.options[idx] === question.correctAnswer) {
        btn.classList.add('is-correct');
      } else if (idx === selectedOptionIndex) {
        btn.classList.add('is-incorrect');
      } else {
        btn.classList.add('is-dimmed');
      }
    });

    // Jika bertipe ejaan kata, reveal huruf sebenarnya
    if (question.type === 'word') {
      document.querySelectorAll('.reveal-letter-box').forEach((box: Element, idx: number) => {
        box.textContent = question.value[idx];
        box.classList.add('revealed');
      });
    }

    if (isCorrect) correctAnswersCount++;

    if (!isCorrect && mode === 'no_mistake') {
      lives--;
      if (semaphoreResultLives) semaphoreResultLives.textContent = lives.toString();
      if (lives <= 0) {
        endGame();
        return;
      }
    }

    if (semaphoreEduCard && semaphoreEduText && question.explanation) {
      semaphoreEduText.textContent = question.explanation;
      semaphoreEduCard.style.display = 'flex';
      semaphoreEduCard.classList.add(isCorrect ? 'correct' : 'incorrect');
    }

    if (currentQuestionIndex === currentQuestions.length - 1) {
      if (semaphoreSubmitBtn) semaphoreSubmitBtn.textContent = 'Lihat Hasil';
    } else {
      if (semaphoreSubmitBtn) semaphoreSubmitBtn.textContent = 'Soal Berikutnya';
    }
  }

  // Next question or show results
  function nextQuestion(): void {
    if (currentQuestionIndex < currentQuestions.length - 1) {
      currentQuestionIndex++;
      renderQuestion();
    } else {
      showQuizResults();
    }
  }

  // Timer functions
  function startTimer(): void {
    if (!currentMode.timeLimit || !semaphoreResultTimer) return;
    timeLeft = currentMode.timeLimit;
    startTime = Date.now();
    timer = setInterval(() => {
      timeLeft--;
      if (semaphoreResultTimer) semaphoreResultTimer.textContent = timeLeft.toString();
      if (timeLeft <= 0) endGame();
    }, 1000);
  }

  function stopTimer(): void {
    if (timer) {
      clearInterval(timer);
      timer = null;
    }
  }

  // End game
  function endGame(): void {
    stopTimer();
    showQuizResults();
  }

  // Show results
  function showQuizResults(): void {
    const score: number = correctAnswersCount;
    const total: number = currentQuestions.length;
    const xpGained: number = Math.round(score * xpPerQuestion * xpMultiplier);
    const scorePercent: number = Math.round((score / total) * 100);
    const timeTaken: number = currentMode.timeLimit ? (currentMode.timeLimit - timeLeft) : Math.floor((Date.now() - startTime) / 1000);

    if (semaphoreResultText) {
      semaphoreResultText.textContent = `Anda berhasil menjawab ${score} dari ${total} soal dengan benar.`;
    }
    if (semaphoreResultXp) semaphoreResultXp.textContent = `+${xpGained} XP`;
    if (semaphoreResultScore) semaphoreResultScore.textContent = `${scorePercent}/100`;
    if (semaphoreResultEmoji) {
      if (scorePercent === 100) semaphoreResultEmoji.textContent = '👑';
      else if (scorePercent >= 70) semaphoreResultEmoji.textContent = '🏆';
      else semaphoreResultEmoji.textContent = '🧭';
    }
    if (semaphoreResultTime && mode === 'time_attack') semaphoreResultTime.textContent = `${timeTaken} detik`;

    // Check for badges
    let newlyUnlocked: Badge[] = [];
    if (scorePercent >= 70) {
      const badge: Badge | undefined = SEMAPHORE_BADGES.semaphore_novice;
      if (badge) {
        const userBadges: string[] = JSON.parse(localStorage.getItem('scout_badges') || '[]');
        if (!userBadges.includes(badge.id)) newlyUnlocked.push(badge);
      }
    }
    if (scorePercent === 100) {
      const badge: Badge | undefined = SEMAPHORE_BADGES.semaphore_expert;
      if (badge) {
        const userBadges: string[] = JSON.parse(localStorage.getItem('scout_badges') || '[]');
        if (!userBadges.includes(badge.id)) newlyUnlocked.push(badge);
      }
    }

    // Display badges
    if (semaphoreBadgesListEl && semaphoreUnlockedBadges) {
      if (newlyUnlocked.length > 0) {
        semaphoreBadgesListEl.innerHTML = '';
        newlyUnlocked.forEach((b: Badge) => {
          const item: HTMLDivElement = document.createElement('div');
          item.className = 'unlocked-badge-item';
          item.innerHTML = `<span class="u-icon">${b.icon}</span> <strong>${b.name}</strong> - ${b.description}`;
          semaphoreBadgesListEl.appendChild(item);
        });
        semaphoreUnlockedBadges.style.display = 'block';
      } else {
        semaphoreUnlockedBadges.style.display = 'none';
      }
    }

    updateUserStats(score, xpGained, newlyUnlocked, level);
    if (semaphoreResultOverlay) semaphoreResultOverlay.style.display = 'flex';
  }

  // Update user stats
  function updateUserStats(score: number, xpGained: number, badges: Badge[], level?: string): void {
    const total: number = currentQuestions.length;
    const scorePercent: number = Math.round((score / total) * 100);
    let oldXp: number = parseInt(localStorage.getItem('scout_xp') || '0');
    let newXp: number = oldXp + xpGained;
    localStorage.setItem('scout_xp', newXp.toString());
    let userBadges: string[] = JSON.parse(localStorage.getItem('scout_badges') || '[]');
    badges.forEach((b: Badge) => {
      if (!userBadges.includes(b.id)) userBadges.push(b.id);
    });
    localStorage.setItem('scout_badges', JSON.stringify(userBadges));
    let streak: number = parseInt(localStorage.getItem('scout_streak') || '0');
    if (scorePercent >= 70) streak++;
    else streak = 0;
    localStorage.setItem('scout_streak', streak.toString());
    localStorage.setItem('scout_last_visit', new Date().toISOString());
    window.dispatchEvent(new Event('statsUpdated'));
  }

  // Initialize quiz
  function initQuiz(): void {
    currentQuestions = getShuffledQuestions(questions as SemaphoreQuestion[], totalQuestions);
    
    if (mode === 'time_attack') {
      startTimer();
    }
    renderQuestion();

    // Initialize replay button
    if (btnSemaphoreReplayWord) {
      btnSemaphoreReplayWord.addEventListener('click', () => {
        const question: SemaphoreQuestion | undefined = currentQuestions[currentQuestionIndex];
        if (question?.type === 'word') {
          playWordSemaphore(question.value);
        }
      });
    }
  }

  // Event listeners
  if (semaphoreSubmitBtn) {
    semaphoreSubmitBtn.addEventListener('click', submitAnswer);
  }
  
  if (semaphoreRestartBtn) {
    semaphoreRestartBtn.addEventListener('click', () => {
      currentQuestionIndex = 0;
      correctAnswersCount = 0;
      selectedOptionIndex = null;
      if (mode === 'time_attack') {
        timeLeft = currentMode.timeLimit || 0;
        if (semaphoreResultTimer) semaphoreResultTimer.textContent = timeLeft.toString();
        startTimer();
      }
      if (mode === 'no_mistake') {
        lives = currentMode.lives || Infinity;
        if (semaphoreResultLives) semaphoreResultLives.textContent = lives.toString();
      }
      if (semaphoreResultOverlay) semaphoreResultOverlay.style.display = 'none';
      currentQuestions = getShuffledQuestions(questions as SemaphoreQuestion[], totalQuestions);
      renderQuestion();
    });
  }

  document.addEventListener('DOMContentLoaded', initQuiz);
  window.addEventListener('beforeunload', () => {
    stopTimer();
    clearInterval(wordIntervalId);
  });
</script>
