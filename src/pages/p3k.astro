		{
			kategori: "Tersedak & Pernapasan",
			q: "Rasio kompresi dada berbanding napas buatan dalam RJP (Resusitasi Jantung Paru / CPR) untuk orang dewasa adalah...",
			options: ["15 : 1", "30 : 2", "5 : 1", "10 : 2"],
			correct: "30 : 2",
			edu: "Standar RJP (CPR) dewasa terkini: 30 kompresi dada diikuti 2 napas buatan, dengan kedalaman kompresi 5–6 cm, kecepatan 100–120 kompresi per menit. Posisi tangan: tumit telapak tangan di tengah dada (sternum bawah). Jika tidak terlatih memberikan napas buatan, kompresi saja (hands-only CPR) juga efektif. RJP dilanjutkan hingga korban sadar, penolong kelelahan, atau bantuan medis datang."
		},
		{
			kategori: "Tersedak & Pernapasan",
			q: "Cara memeriksa apakah korban masih bernapas adalah...",
			options: [
				"Pegang pergelangan tangan dan rasakan denyut nadi selama 10 detik",
				"Lihat gerakan dada, dengar suara napas, rasakan hembusan napas di pipi selama 10 detik (Look-Listen-Feel)",
				"Letakkan cermin di depan mulut dan lihat apakah ada embun",
				"Tepuk punggung korban tiga kali dan perhatikan reaksinya"
			],
			correct: "Lihat gerakan dada, dengar suara napas, rasakan hembusan napas di pipi selama 10 detik (Look-Listen-Feel)",
			edu: "Teknik memeriksa pernapasan: Look (lihat gerakan naik-turun dada), Listen (dengar suara napas), Feel (rasakan aliran udara napas di pipi penolong) — selama tidak lebih dari 10 detik. Jika korban tidak bernapas normal (atau hanya megap-megap/gasping), segera mulai RJP. Memeriksa denyut nadi sering tidak akurat untuk orang awam dan memakan waktu, sehingga kini fokus pada pemeriksaan napas."
		},
		// ── Gigitan & Sengatan ───────────────────────────────────────────────────
		{
			kategori: "Gigitan & Sengatan",
			q: "Tindakan pertama yang benar untuk menangani gigitan ular berbisa adalah...",
			options: [
				"Isap racun dari luka menggunakan mulut atau alat penghisap",
				"Ikat erat bagian atas luka dengan tali untuk menghentikan racun menyebar",
				"Buat sayatan silang di luka dan biarkan darah mengalir bersama racun",
				"Imobilisasi anggota tubuh yang digigit, tenangkan korban, dan segera bawa ke RS"
			],
			correct: "Imobilisasi anggota tubuh yang digigit, tenangkan korban, dan segera bawa ke RS",
			edu: "Penanganan gigitan ular: (1) Jangan panik dan tenangkan korban — gerakan dan panik mempercepat penyebaran bisa. (2) Imobilisasi anggota tubuh yang digigit, pertahankan posisi di bawah level jantung. (3) Lepas perhiasan/jam tangan di sekitar gigitan. (4) JANGAN isap, iris, bakar, atau ikat terlalu kencang. (5) Segera bawa ke RS yang memiliki antivenom (serum anti bisa ular). Catat ciri ular jika memungkinkan."
		},
		{
			kategori: "Gigitan & Sengatan",
			q: "Jika tersengat lebah, tindakan pertama yang paling tepat adalah...",
			options: [
				"Tekan dan peras area sengatan untuk mengeluarkan racun",
				"Gesek sengat keluar menggunakan kartu atau kuku (bukan dicabut), lalu dinginkan area tersebut",
				"Oleskan pasta gigi atau lumpur pada area sengatan",
				"Biarkan saja karena racun lebah akan hilang sendiri dalam beberapa menit"
			],
			correct: "Gesek sengat keluar menggunakan kartu atau kuku (bukan dicabut), lalu dinginkan area tersebut",
			edu: "Cara menangani sengatan lebah: (1) Gesek (jangan dicabut dengan pinset) sengat menggunakan tepi kartu kredit, kuku, atau benda datar untuk mendorong sengat keluar tanpa memeras kantung racun. (2) Cuci area sengatan dengan sabun dan air. (3) Kompres dingin untuk mengurangi bengkak dan nyeri. (4) Perhatikan tanda alergi berat (anafilaksis): sesak napas, bengkak di wajah/tenggorokan, pusing — segera ke RS jika muncul."
		},
		// ── Keseleo & RICE ───────────────────────────────────────────────────────
		{
			kategori: "Keseleo & RICE",
			q: "Metode RICE yang digunakan untuk menangani keseleo (terkilir) kepanjangan dari...",
			options: [
				"Relax, Ice, Cool, Elevate",
				"Rest, Ice, Compression, Elevation",
				"Reduce, Immobilize, Compress, Examine",
				"Rest, Immobilize, Cool, Elevate"
			],
			correct: "Rest, Ice, Compression, Elevation",
			edu: "RICE adalah metode standar penanganan cedera otot dan sendi ringan-sedang seperti keseleo: R = Rest (istirahatkan anggota tubuh yang cedera), I = Ice (kompres es selama 15-20 menit, dilapisi kain, ulangi setiap 2 jam), C = Compression (balut dengan perban elastis untuk mengurangi bengkak), E = Elevation (angkat anggota tubuh di atas level jantung untuk mengurangi bengkak). Terapkan dalam 24-48 jam pertama."
		},
		{
			kategori: "Keseleo & RICE",
			q: "Perbedaan keseleo (sprain) dan terkilir (strain) adalah...",
			options: [
				"Keseleo dan terkilir adalah istilah yang sama persis",
				"Keseleo adalah cedera ligamen (penghubung tulang), terkilir adalah cedera otot/tendon",
				"Keseleo lebih berat dari terkilir dan selalu membutuhkan operasi",
				"Terkilir hanya terjadi pada pergelangan kaki, keseleo di tempat lain"
			],
			correct: "Keseleo adalah cedera ligamen (penghubung tulang), terkilir adalah cedera otot/tendon",
			edu: "Sprain (keseleo/salah urat) adalah regangan atau robekan ligamen — jaringan yang menghubungkan tulang satu sama lain di sendi. Strain (terkilir/kram otot) adalah regangan atau robekan otot atau tendon — jaringan yang menghubungkan otot ke tulang. Keduanya ditangani dengan metode RICE, namun sprain berat dan strain berat tetap perlu dievaluasi dokter untuk memastikan tidak ada robekan total."
		},
		// ── Pembalutan & Peralatan ───────────────────────────────────────────────
		{
			kategori: "Pembalutan",
			q: "Cara membalut luka yang benar menggunakan perban gulung adalah...",
			options: [
				"Mulai dari bagian teratas luka, balut ke bawah dengan tekanan maksimal",
				"Mulai dari bawah luka ke atas, sedikit tumpang tindih tiap putaran, dan kunci dengan plester atau peniti",
				"Balut hanya satu lapis tipis agar tidak mengurangi sirkulasi darah",
				"Ikat perban sekencang mungkin agar tidak bergeser"
			],
			correct: "Mulai dari bawah luka ke atas, sedikit tumpang tindih tiap putaran, dan kunci dengan plester atau peniti",
			edu: "Teknik membalut dengan perban gulung: (1) Mulai melingkar 2 kali di bagian bawah sebagai jangkar. (2) Gulung ke atas dengan arah spiral, tumpang-tindih ⅓–½ lebar perban setiap putaran untuk menutup luka merata. (3) Kencangkan cukup untuk menahan, tidak memotong sirkulasi (periksa: ujung jari masih hangat dan berwarna normal). (4) Kunci ujung perban dengan plester, peniti, atau simpul. Pembalutan terlalu ketat bisa menyebabkan sindrom kompartemen."
		},
		{
			kategori: "Pembalutan",
			q: "Pembalutan segitiga (mitella) sering digunakan untuk...",
			options: [
				"Membalut luka sayat yang panjang",
				"Membuat gendongan lengan (sling) pada cedera bahu atau lengan",
				"Membalut luka bakar seluruh tubuh",
				"Menghentikan perdarahan kepala yang berat"
			],
			correct: "Membuat gendongan lengan (sling) pada cedera bahu atau lengan",
			edu: "Pembalut segitiga (mitella/triangular bandage) sangat serbaguna. Fungsi utama dalam P3K Pramuka: (1) Gendongan lengan (arm sling) untuk cedera bahu, lengan atas, atau setelah memasang bidai pada lengan. (2) Membalut kepala, tangan, atau kaki. (3) Sebagai bidai improvasi. (4) Membuat tourniquet darurat. Dalam kotak P3K pramuka, mitella adalah perlengkapan wajib."
		},
		// ── Kondisi Khusus ───────────────────────────────────────────────────────
		{
			kategori: "Kondisi Khusus",
			q: "Penanganan pertama pada korban yang mengalami sengatan panas (heat stroke) saat kegiatan pramuka di lapangan adalah...",
			options: [
				"Berikan minuman beralkohol untuk menghangatkan tubuh dari dalam",
				"Biarkan korban berjemur matahari agar suhu tubuh stabil kembali",
				"Pindahkan ke tempat teduh, lepaskan pakaian berlebih, kompres dingin di leher/ketiak/selangkangan, dan beri minum jika sadar",
				"Berikan obat penurun panas oral dan pantau selama 30 menit"
			],
			correct: "Pindahkan ke tempat teduh, lepaskan pakaian berlebih, kompres dingin di leher/ketiak/selangkangan, dan beri minum jika sadar",
			edu: "Heat stroke adalah kedaruratan medis akibat suhu tubuh di atas 40°C. Penanganan: (1) Segera pindahkan ke tempat teduh dan sejuk. (2) Lepaskan pakaian berlebih. (3) Kompres dingin (bukan es) di area dengan pembuluh darah besar: leher, ketiak, selangkangan, dan pergelangan tangan. (4) Kipasi korban. (5) Beri minum air putih sedikit-sedikit JIKA korban sadar dan bisa menelan. (6) Segera hubungi bantuan medis — heat stroke bisa fatal."
		},
		{
			kategori: "Kondisi Khusus",
			q: "Tanda hipotermia (suhu tubuh terlalu rendah) yang perlu diwaspadai adalah...",
			options: [
				"Berkeringat banyak, wajah memerah, dan denyut nadi cepat",
				"Menggigil hebat, kulit pucat kebiruan, bicara cadel, bingung, dan kantuk ekstrem",
				"Suhu badan sangat tinggi dan kejang-kejang",
				"Kulit terasa panas dan kering, serta tidak berkeringat"
			],
			correct: "Menggigil hebat, kulit pucat kebiruan, bicara cadel, bingung, dan kantuk ekstrem",
			edu: "Hipotermia adalah kondisi suhu tubuh inti di bawah 35°C. Tanda progresif: menggigil (tubuh mencoba menghasilkan panas), kulit pucat/kebiruan, otot kaku, bicara cadel, koordinasi buruk, bingung, dan akhirnya kehilangan kesadaran. Penanganan: (1) Pindahkan ke tempat hangat dan terlindung angin. (2) Ganti pakaian basah dengan yang kering. (3) Selimuti, termasuk kepala. (4) Jika sadar, beri minuman hangat (bukan alkohol). (5) Jangan gosok kulit kuat-kuat."
		},
		{
			kategori: "Kondisi Khusus",
			q: "Ketika menolong korban yang diduga mengalami cedera tulang belakang, hal yang paling penting untuk TIDAK dilakukan adalah...",
			options: [
				"Memanggi bantuan medis segera",
				"Memindahkan atau menggerakkan korban secara sembarangan tanpa stabilisasi",
				"Menjaga kepala dan leher korban agar tidak bergerak",
				"Memastikan jalan napas korban terbuka"
			],
			correct: "Memindahkan atau menggerakkan korban secara sembarangan tanpa stabilisasi",
			edu: "Pada dugaan cedera tulang belakang, pergerakan sembarangan dapat memperparah cedera sumsum tulang belakang yang bisa menyebabkan kelumpuhan permanen. Prinsip: (1) Jangan gerakkan korban kecuali dalam bahaya langsung (kebakaran, tenggelam). (2) Stabilkan kepala dan leher dalam posisi netral. (3) Jika harus memindahkan, gunakan teknik log roll dengan minimal 3 orang. (4) Gunakan papan tulang belakang dan collar cervical jika tersedia."
		},
		{
			kategori: "Kondisi Khusus",
			q: "Cara membuka jalan napas (airway) pada korban tidak sadar yang tidak dicurigai cedera tulang belakang adalah...",
			options: [
				"Miringkan kepala ke samping kiri",
				"Head-tilt chin-lift: tengadahkan kepala dan angkat dagu ke atas",
				"Tekan dada korban untuk mendorong sumbatan keluar",
				"Masukkan jari ke mulut dan bersihkan apapun yang ada di dalamnya"
			],
			correct: "Head-tilt chin-lift: tengadahkan kepala dan angkat dagu ke atas",
			edu: "Teknik head-tilt chin-lift: (1) Letakkan satu tangan di dahi korban dan dorong kepala ke belakang (head-tilt). (2) Jari tangan lain di bawah dagu, angkat dagu ke atas (chin-lift). Manuver ini menarik lidah ke depan dan membuka jalan napas. Jika dicurigai ada cedera tulang belakang, gunakan jaw-thrust maneuver sebagai gantinya — mendorong rahang bawah ke depan tanpa menggerakkan leher."
		},
	];

	const XP_PER_CORRECT = 12;
	const QUESTIONS_PER_SESSION = 10;

	const BADGES_FOR_THIS_QUIZ = [
		{ id: 'p3k_novice', name: 'Penolong Pertama', icon: '🩺' },
		{ id: 'p3k_master', name: 'Ahli P3K',         icon: '❤️‍🩹' },
	];

	let questions: Question[] = [];
	let currentIndex = 0;
	let selectedAnswer = '';
	let score = 0;
	let totalXpEarned = 0;

	function shuffle<T>(arr: T[]): T[] { return [...arr].sort(() => Math.random() - 0.5); }
	function getEl<T extends HTMLElement>(id: string) { return document.getElementById(id) as T | null; }

	function startQuiz() {
		questions = shuffle(QUESTIONS_POOL).slice(0, QUESTIONS_PER_SESSION);
		currentIndex = 0; score = 0; totalXpEarned = 0; selectedAnswer = '';
		renderQuestion();
	}

	function renderQuestion() {
		const q = questions[currentIndex];
		const num = currentIndex + 1;
		const pct = (num / QUESTIONS_PER_SESSION) * 100;

		getEl('question-number')!.textContent = `Soal ${num} dari ${QUESTIONS_PER_SESSION}`;
		(getEl('progress-pct') as HTMLElement).textContent = `${Math.round(pct)}%`;
		getEl<HTMLDivElement>('quiz-progress-bar')!.style.width = `${pct}%`;

		const catEl = getEl('question-category');
		if (catEl) catEl.innerHTML = `<span class="cat-pill">🩺 ${q.kategori}</span>`;

		getEl('question-prompt')!.textContent = q.q;
		const eduCard = getEl<HTMLDivElement>('education-card');
		if (eduCard) eduCard.style.display = 'none';

		const submitBtn = getEl<HTMLButtonElement>('btn-submit-answer');
		if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Konfirmasi Jawaban'; submitBtn.onclick = submitAnswer; }

		const hint = getEl('answer-hint');
		if (hint) { hint.textContent = 'Pilih salah satu jawaban di atas'; hint.className = 'answer-hint'; }

		selectedAnswer = '';
		renderOptions(q);
	}

	function renderOptions(q: Question) {
		const container = getEl<HTMLDivElement>('options-container');
		if (!container) return;

		container.innerHTML = shuffle(q.options).map((opt, i) => {
			const letter = String.fromCharCode(65 + i);
			return `
			<button class="opt-btn" data-answer="${opt.replace(/"/g, '&quot;')}" style="animation-delay:${i * 0.07}s">
				<span class="opt-letter">${letter}</span>
				<span class="opt-text">${opt}</span>
				<span class="opt-indicator">
					<span class="opt-radio"></span>
					<svg class="opt-icon icon-check" viewBox="0 0 24 24" fill="none" stroke="#236c32" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
					<svg class="opt-icon icon-cross" viewBox="0 0 24 24" fill="none" stroke="#a5301a" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
				</span>
			</button>`;
		}).join('');

		container.querySelectorAll('.opt-btn').forEach((btn, i) => {
			btn.addEventListener('click', () => {
				container.querySelectorAll('.opt-btn').forEach(b => b.classList.remove('is-selected'));
				btn.classList.add('is-selected');
				selectedAnswer = (btn as HTMLElement).dataset.answer || '';
				const submitBtn = getEl<HTMLButtonElement>('btn-submit-answer');
				if (submitBtn) submitBtn.disabled = false;
				const hint = getEl('answer-hint');
				if (hint) { hint.textContent = `Jawaban ${String.fromCharCode(65 + i)} dipilih — klik Konfirmasi untuk lanjut`; hint.className = 'answer-hint chosen'; }
			});
		});
	}

	function submitAnswer() {
		const q = questions[currentIndex];
		const isCorrect = selectedAnswer === q.correct;
		if (isCorrect) { score++; totalXpEarned += XP_PER_CORRECT; }

		const container = getEl<HTMLDivElement>('options-container');
		container?.querySelectorAll('.opt-btn').forEach(btn => {
			const el = btn as HTMLElement;
			const ans = el.dataset.answer || '';
			el.classList.add('is-answered'); el.classList.remove('is-selected');
			if (ans === q.correct) el.classList.add('is-correct');
			else if (ans === selectedAnswer && !isCorrect) el.classList.add('is-incorrect');
			else el.classList.add('is-dimmed');
		});

		const eduCard = getEl<HTMLDivElement>('education-card');
		const eduText = getEl('education-text');
		if (eduCard && eduText) {
			eduText.textContent = q.edu;
			eduCard.style.display = 'flex';
			eduCard.className = `education-card ${isCorrect ? 'correct' : 'incorrect'}`;
		}

		const hint = getEl('answer-hint');
		if (hint) { hint.textContent = isCorrect ? '✓ Jawaban benar!' : '✗ Jawaban salah — lihat penjelasan di bawah.'; hint.className = `answer-hint ${isCorrect ? 'correct-hint' : 'wrong-hint'}`; }

		const submitBtn = getEl<HTMLButtonElement>('btn-submit-answer');
		if (submitBtn) { submitBtn.textContent = currentIndex < QUESTIONS_PER_SESSION - 1 ? 'Soal Berikutnya →' : 'Lihat Hasil'; submitBtn.disabled = false; submitBtn.onclick = nextQuestion; }
	}

	function nextQuestion() {
		currentIndex++;
		if (currentIndex < QUESTIONS_PER_SESSION) {
			renderQuestion();
			const s = getEl<HTMLButtonElement>('btn-submit-answer');
			if (s) s.onclick = submitAnswer;
		} else showResult();
	}

	function showResult() {
		const pct = Math.round((score / QUESTIONS_PER_SESSION) * 100);
		const currentXp = parseInt(localStorage.getItem('scout_xp') || '0');
		localStorage.setItem('scout_xp', (currentXp + totalXpEarned).toString());

		const earnedBadges: string[] = JSON.parse(localStorage.getItem('scout_badges') || '[]');
		const newlyUnlocked: typeof BADGES_FOR_THIS_QUIZ = [];

		if (!earnedBadges.includes('p3k_novice')) { earnedBadges.push('p3k_novice'); newlyUnlocked.push(BADGES_FOR_THIS_QUIZ[0]); }
		if (pct === 100 && !earnedBadges.includes('p3k_master')) { earnedBadges.push('p3k_master'); newlyUnlocked.push(BADGES_FOR_THIS_QUIZ[1]); }
		const totalXpNow = parseInt(localStorage.getItem('scout_xp') || '0');
		if (totalXpNow >= 500 && !earnedBadges.includes('scout_master')) earnedBadges.push('scout_master');
		localStorage.setItem('scout_badges', JSON.stringify(earnedBadges));

		const emoji = pct === 100 ? '🏆' : pct >= 80 ? '⭐' : pct >= 60 ? '👍' : '📚';
		getEl('result-emoji')!.textContent = emoji;
		const titleEl = getEl('result-title');
		if (titleEl) titleEl.textContent = pct === 100 ? 'Sempurna! Ahli P3K!' : pct >= 80 ? 'Bagus Sekali!' : pct >= 60 ? 'Cukup Baik!' : 'Terus Belajar!';
		getEl('result-text')!.textContent = `Kamu menjawab ${score} dari ${QUESTIONS_PER_SESSION} soal dengan benar (${pct}%). ${pct >= 80 ? 'Kamu siap memberikan pertolongan pertama di lapangan!' : 'Pelajari kembali prosedur P3K agar siap saat dibutuhkan.'}`;
		getEl('result-xp')!.textContent = `+${totalXpEarned} XP`;
		getEl('result-score')!.textContent = `${pct}/100`;
		getEl('result-correct')!.textContent = `${score}/${QUESTIONS_PER_SESSION}`;

		if (newlyUnlocked.length > 0) {
			const bc = getEl<HTMLDivElement>('unlocked-badges');
			const bl = getEl('badges-list-el');
			if (bc && bl) {
				bl.innerHTML = newlyUnlocked.map(b => `<div class="new-badge-item"><span class="new-badge-icon">${b.icon}</span><span class="new-badge-name">${b.name}</span></div>`).join('');
				bc.style.display = 'block';
			}
		}
		const overlay = getEl<HTMLDivElement>('result-overlay');
		if (overlay) overlay.style.display = 'flex';
		window.dispatchEvent(new Event('statsUpdated'));
	}

	getEl<HTMLButtonElement>('btn-submit-answer')?.addEventListener('click', submitAnswer);
	getEl<HTMLButtonElement>('btn-restart')?.addEventListener('click', () => {
		const overlay = getEl<HTMLDivElement>('result-overlay');
		if (overlay) overlay.style.display = 'none';
		startQuiz();
	});
	startQuiz();
