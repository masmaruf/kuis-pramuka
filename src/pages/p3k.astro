---
import Layout from '../layouts/Layout.astro';
import P3KQuiz from '../components/P3KQuiz.astro';
---

<Layout title="Kuis P3K Pramuka" description="Latihan pertolongan pertama (P3K) pramuka: penanganan perdarahan, luka bakar, patah tulang, syok, RJP, tersedak, gigitan ular, dan hipotermia.">
	<P3KQuiz quizId="p3k" totalQuestions={10} />
		<header class="quiz-header glass-card">
			<a href="/" class="btn-back">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<line x1="19" y1="12" x2="5" y2="12"/>
					<polyline points="12 19 5 12 12 5"/>
				</svg>
				Kembali ke Dasbor
			</a>
			<div class="quiz-title-area">
				<h2>Kuis P3K</h2>
				<span class="quiz-difficulty hard">Pertolongan Pertama</span>
			</div>
		</header>

		<div class="quiz-layout">
			<!-- Main Quiz Card -->
			<div class="quiz-main-card glass-card">
				<div class="progress-tracker">
					<div class="progress-label">
						<span id="question-number">Soal 1 dari 10</span>
						<span id="progress-pct" class="pct-label">10%</span>
					</div>
					<div class="progress-bar-outer">
						<div id="quiz-progress-bar" class="progress-bar-inner" style="width: 10%"></div>
					</div>
				</div>

				<div class="question-category" id="question-category">
					<span class="cat-pill">🩺 P3K Pramuka</span>
				</div>

				<div class="question-text-area">
					<h3 id="question-prompt">Soal akan dimuat...</h3>
				</div>

				<div class="flex flex-col gap-2.5" id="options-container"></div>

				<div class="education-card" id="education-card" style="display: none;">
					<div class="edu-header">
						<span class="edu-icon">🩺</span>
						<span class="edu-label">Penjelasan Medis</span>
					</div>
					<p id="education-text"></p>
				</div>

				<div class="action-footer">
					<span id="answer-hint" class="answer-hint">Pilih salah satu jawaban di atas</span>
					<button id="btn-submit-answer" class="btn btn-gold" disabled>Konfirmasi Jawaban</button>
				</div>
			</div>

			<!-- Reference Sidebar -->
			<div class="quiz-help-card glass-card">
				<h3>Panduan Cepat P3K</h3>
				<p class="help-subtitle">Tindakan pertolongan pertama pada kecelakaan</p>

				<div class="p3k-steps">
					<div class="step-group">
						<div class="step-title">🔴 Langkah Pertama</div>
						<div class="step-item">Pastikan keamanan lokasi & penolong</div>
						<div class="step-item">Panggil bantuan / hubungi 119</div>
						<div class="step-item">Periksa kesadaran korban</div>
					</div>
					<div class="step-group">
						<div class="step-title">🩸 Perdarahan</div>
						<div class="step-item">Tekan langsung dengan kain bersih</div>
						<div class="step-item">Angkat bagian yang luka (elevasi)</div>
						<div class="step-item">Jangan angkat benda tertancap</div>
					</div>
					<div class="step-group">
						<div class="step-title">🔥 Luka Bakar</div>
						<div class="step-item">Siram air mengalir ≥ 10 menit</div>
						<div class="step-item">Jangan gunakan pasta gigi / es</div>
						<div class="step-item">Tutup dengan kain bersih lembap</div>
					</div>
					<div class="step-group">
						<div class="step-title">🦴 Patah Tulang</div>
						<div class="step-item">Jangan digerakkan</div>
						<div class="step-item">Pasang bidai di kedua sisi tulang</div>
						<div class="step-item">Ikat bidai di atas & bawah patah</div>
					</div>
					<div class="step-group">
						<div class="step-title">😵 Pingsan / Syok</div>
						<div class="step-item">Baringkan, angkat kaki 30 cm</div>
						<div class="step-item">Longgarkan pakaian ketat</div>
						<div class="step-item">Jangan beri minum saat tidak sadar</div>
					</div>
				</div>

				<div class="p3k-fact-box">
					<div class="fact-row">
						<span class="fact-key">Ambulans / darurat</span>
						<span class="fact-val emergency">119</span>
					</div>
					<div class="fact-row">
						<span class="fact-key">Pemadam kebakaran</span>
						<span class="fact-val emergency">113</span>
					</div>
					<div class="fact-row">
						<span class="fact-key">Polisi</span>
						<span class="fact-val emergency">110</span>
					</div>
					<div class="fact-row">
						<span class="fact-key">Nomor darurat universal</span>
						<span class="fact-val emergency">112</span>
					</div>
					<div class="fact-row">
						<span class="fact-key">RJP (CPR) tekanan</span>
						<span class="fact-val">30 : 2</span>
					</div>
					<div class="fact-row">
						<span class="fact-key">RICE</span>
						<span class="fact-val">Rest · Ice · Comp. · Elev.</span>
					</div>
				</div>
			</div>
		</div>

		<!-- Result Overlay -->
		<div class="result-overlay" id="result-overlay" style="display: none;">
			<div class="result-card glass-card">
				<div class="result-emoji" id="result-emoji">🏆</div>
				<h2 id="result-title">Kuis Selesai!</h2>
				<p class="result-summary" id="result-text"></p>
				<div class="result-stats-details">
					<div class="detail-item">
						<span class="label">XP Diperoleh</span>
						<span class="value score-xp" id="result-xp">+100 XP</span>
					</div>
					<div class="detail-item">
						<span class="label">Skor Akhir</span>
						<span class="value" id="result-score">100/100</span>
					</div>
					<div class="detail-item">
						<span class="label">Jawaban Benar</span>
						<span class="value" id="result-correct">10/10</span>
					</div>
				</div>
				<div class="unlocked-badges-container" id="unlocked-badges" style="display: none;">
					<h3>🎖️ Lencana Baru Terbuka!</h3>
					<div class="unlocked-badges-list" id="badges-list-el"></div>
				</div>
				<div class="result-actions">
					<button id="btn-restart" class="btn btn-primary">Ulangi Kuis</button>
					<a href="/" class="btn btn-gold">Kembali ke Dasbor</a>
				</div>
			</div>
		</div>
	</div>
</Layout>

<script>
	interface Question {
		kategori: string;
		q: string;
		options: string[];
		correct: string;
		edu: string;
	}

	const QUESTIONS_POOL: Question[] = [
		// ── Prinsip Dasar P3K ────────────────────────────────────────────────────
		{
			kategori: "Prinsip Dasar",
			q: "Langkah pertama yang harus dilakukan sebelum memberikan pertolongan pada korban kecelakaan adalah...",
			options: [
				"Segera angkat korban ke tempat yang lebih nyaman",
				"Pastikan keamanan lokasi dan keselamatan penolong terlebih dahulu",
				"Langsung berikan napas buatan tanpa memeriksa dahulu",
				"Hubungi keluarga korban sebelum melakukan tindakan apapun"
			],
			correct: "Pastikan keamanan lokasi dan keselamatan penolong terlebih dahulu",
			edu: "Prinsip utama P3K: Danger — Penolong yang tidak aman tidak dapat menolong siapapun. Sebelum mendekati korban, penolong harus memastikan lokasi aman dari bahaya (api, arus listrik, lalu lintas, runtuhan bangunan). Ini adalah langkah D dalam protokol DR-ABC: Danger, Response, Airway, Breathing, Circulation."
		},
		{
			kategori: "Prinsip Dasar",
			q: "Singkatan DR-ABC dalam protokol pertolongan pertama mengandung urutan...",
			options: [
				"Danger, Response, Airway, Breathing, Circulation",
				"Diagnose, Rescue, Ambulance, Bandage, Compress",
				"Direct, Relax, Assess, Balance, Care",
				"Detect, Report, Assist, Bind, Compress"
			],
			correct: "Danger, Response, Airway, Breathing, Circulation",
			edu: "DR-ABC adalah protokol dasar pertolongan pertama: D = Danger (pastikan keamanan), R = Response (periksa respons korban dengan memanggil atau menepuk bahu), A = Airway (buka jalan napas), B = Breathing (periksa pernapasan), C = Circulation (periksa sirkulasi/denyut nadi dan kendalikan perdarahan). Urutan ini harus diikuti secara sistematis."
		},
		{
			kategori: "Prinsip Dasar",
			q: "Nomor telepon darurat untuk memanggil ambulans dan layanan kesehatan darurat di Indonesia adalah...",
			options: ["110", "112", "113", "119"],
			correct: "119",
			edu: "Nomor darurat kesehatan di Indonesia adalah 119 (Pusat Krisis Kesehatan Kemenkes / PSC 119). Nomor lain: 110 (Polisi), 113 (Pemadam Kebakaran), 112 (Nomor darurat universal yang akan diteruskan ke layanan terkait). Dalam kondisi darurat medis, segera hubungi 119 untuk mendapatkan panduan dan ambulans."
		},
		{
			kategori: "Prinsip Dasar",
			q: "P3K singkatan dari...",
			options: [
				"Pedoman Pertolongan Pertama pada Kecelakaan",
				"Pertolongan Pertama pada Kecelakaan",
				"Paket Perlengkapan Pertolongan Kedaruratan",
				"Prosedur Pertama Penanganan Korban"
			],
			correct: "Pertolongan Pertama pada Kecelakaan",
			edu: "P3K adalah singkatan dari Pertolongan Pertama pada Kecelakaan. Dalam kepramukaan, materi P3K merupakan salah satu syarat kecakapan umum (SKU) yang wajib dikuasai. P3K bertujuan memberikan tindakan darurat sementara sebelum korban mendapat penanganan medis profesional, bukan untuk menggantikan perawatan dokter."
		},
		// ── Perdarahan ───────────────────────────────────────────────────────────
		{
			kategori: "Perdarahan",
			q: "Cara yang paling tepat untuk menghentikan perdarahan dari luka terbuka adalah...",
			options: [
				"Ikat bagian atas luka dengan tali sekencang mungkin (tourniquet) segera",
				"Tekan langsung luka dengan kain bersih atau steril secara terus-menerus",
				"Siram luka dengan air panas untuk membunuh kuman",
				"Biarkan darah mengalir keluar sampai berhenti sendiri"
			],
			correct: "Tekan langsung luka dengan kain bersih atau steril secara terus-menerus",
			edu: "Penekanan langsung (direct pressure) adalah cara terbaik pertama untuk menghentikan perdarahan. Tekan luka dengan kain bersih/steril selama minimal 10-15 menit tanpa mengangkat kain. Tourniquet hanya digunakan sebagai pilihan terakhir pada perdarahan masif anggota tubuh yang tidak bisa dikendalikan dengan cara lain, karena dapat merusak jaringan jika dipakai terlalu lama."
		},
		{
			kategori: "Perdarahan",
			q: "Jika ada benda tajam (misalnya pecahan kaca) yang masih tertancap di dalam luka, tindakan yang benar adalah...",
			options: [
				"Segera cabut benda tersebut agar luka bisa dibersihkan",
				"Jangan cabut — stabilkan benda tersebut dan balut di sekitarnya",
				"Dorong benda lebih dalam agar tidak mengganggu pembalutan",
				"Putar benda tersebut sebelum mencabutnya untuk mengurangi rasa sakit"
			],
			correct: "Jangan cabut — stabilkan benda tersebut dan balut di sekitarnya",
			edu: "Benda tertancap TIDAK BOLEH dicabut oleh penolong pertama karena berperan sebagai sumbatan alami yang mengurangi perdarahan. Mencabut benda bisa memperparah perdarahan dan merusak jaringan lebih lanjut. Stabilkan benda dengan mengganjalnya menggunakan kain di sekitar luka agar tidak bergerak, lalu balut dengan hati-hati dan segera bawa ke fasilitas medis."
		},
		{
			kategori: "Perdarahan",
			q: "Tanda perdarahan dalam (internal bleeding) yang perlu diwaspadai antara lain...",
			options: [
				"Kulit terlihat merah dan panas di area cedera",
				"Korban mengeluh haus berlebihan dan kulit tampak basah karena keringat berlebih saja",
				"Kulit pucat, dingin, lembap; denyut nadi cepat dan lemah; perut terasa kaku atau nyeri",
				"Korban berteriak kesakitan dan suhu tubuh naik tinggi"
			],
			correct: "Kulit pucat, dingin, lembap; denyut nadi cepat dan lemah; perut terasa kaku atau nyeri",
			edu: "Perdarahan dalam (internal) tidak terlihat dari luar namun sangat berbahaya. Tandanya: kulit pucat/dingin/lembap (karena darah mengalir ke organ vital), denyut nadi lemah dan cepat, tekanan darah turun, mual/muntah, perut kaku atau nyeri tekan. Jika dicurigai ada perdarahan dalam, jangan berikan makan/minum dan segera evakuasi ke rumah sakit."
		},
		// ── Luka Bakar ──────────────────────────────────────────────────────────
		{
			kategori: "Luka Bakar",
			q: "Tindakan pertama yang benar untuk menangani luka bakar adalah...",
			options: [
				"Oleskan pasta gigi atau mentega untuk mendinginkan luka",
				"Pecahkan gelembung (lepuh) yang terbentuk agar luka cepat kering",
				"Siram dengan air mengalir bersuhu normal selama minimal 10–20 menit",
				"Tutup dengan perban kering dan segera dibawa ke dokter tanpa tindakan lain"
			],
			correct: "Siram dengan air mengalir bersuhu normal selama minimal 10–20 menit",
			edu: "Luka bakar harus segera didinginkan dengan air mengalir bersuhu normal (bukan es, bukan air es) selama minimal 10–20 menit. Air mengalir membantu menghentikan proses pembakaran jaringan yang masih berlanjut. JANGAN gunakan pasta gigi, mentega, minyak, kecap, atau bahan lainnya karena dapat memperparah luka dan menimbulkan infeksi."
		},
		{
			kategori: "Luka Bakar",
			q: "Luka bakar derajat dua (grade II) ditandai dengan...",
			options: [
				"Kulit hanya memerah tanpa rasa sakit",
				"Terbentuknya lepuhan (bula/blister) berisi cairan, kulit merah, sangat nyeri",
				"Kulit menghitam atau putih pucat, kering, tidak terasa sakit",
				"Luka mencapai otot dan tulang"
			],
			correct: "Terbentuknya lepuhan (bula/blister) berisi cairan, kulit merah, sangat nyeri",
			edu: "Tingkatan luka bakar: Derajat I — hanya lapisan kulit luar (epidermis) memerah, nyeri ringan (seperti terbakar matahari). Derajat II — mencapai lapisan dermis, terbentuk lepuhan berisi cairan, sangat nyeri. Derajat III — lapisan kulit seluruhnya rusak, kulit tampak putih/hitam/kecokelatan, tidak nyeri (saraf sudah rusak). Derajat III membutuhkan penanganan rumah sakit segera."
		},
		{
			kategori: "Luka Bakar",
			q: "Mengapa penggunaan es atau air es TIDAK dianjurkan untuk luka bakar?",
			options: [
				"Karena es bisa membuat luka menjadi lebih panas",
				"Karena es dapat menyebabkan hipotermia dan kerusakan jaringan tambahan akibat suhu ekstrem",
				"Karena es tidak tersedia di lapangan",
				"Karena es hanya boleh digunakan oleh dokter"
			],
			correct: "Karena es dapat menyebabkan hipotermia dan kerusakan jaringan tambahan akibat suhu ekstrem",
			edu: "Es atau air es TIDAK boleh digunakan pada luka bakar karena: (1) Suhu ekstrem dapat menyebabkan radang dingin (frostbite) pada jaringan yang sudah rusak. (2) Pada luka bakar luas, es bisa memicu hipotermia (suhu tubuh turun terlalu drastis). (3) Perubahan suhu terlalu cepat memperlambat proses penyembuhan. Air mengalir bersuhu ruangan adalah pilihan terbaik."
		},
		// ── Patah Tulang ────────────────────────────────────────────────────────
		{
			kategori: "Patah Tulang",
			q: "Tanda-tanda patah tulang (fraktur) yang dapat diamati oleh penolong pertama antara lain...",
			options: [
				"Kulit memerah, bengkak ringan, dan korban masih bisa berjalan normal",
				"Nyeri hebat, bengkak, deformitas (bentuk abnormal), tidak bisa digerakkan, dan kadang terdengar bunyi 'krek'",
				"Hanya rasa panas di area cedera tanpa bengkak",
				"Korban tidak merasakan sakit sama sekali karena patah tulang tidak nyeri"
			],
			correct: "Nyeri hebat, bengkak, deformitas (bentuk abnormal), tidak bisa digerakkan, dan kadang terdengar bunyi 'krek'",
			edu: "Tanda patah tulang: (1) Nyeri hebat, terutama saat ditekan atau digerakkan. (2) Bengkak dan memar. (3) Deformitas — bentuk anggota tubuh tampak tidak normal atau bengkok. (4) Tidak dapat menggerakkan bagian yang cedera. (5) Kadang terdengar bunyi 'krek' saat cedera terjadi. (6) Pada patah tulang terbuka, tulang bisa terlihat menonjol keluar dari kulit."
		},
		{
			kategori: "Patah Tulang",
			q: "Teknik memasang bidai (splint) pada patah tulang yang benar adalah...",
			options: [
				"Pasang bidai hanya di bawah tulang yang patah",
				"Pasang bidai melewati satu sendi di atas dan satu sendi di bawah lokasi patah",
				"Ikat bidai sekencang mungkin agar tulang tidak bergeser",
				"Luruskan paksa tulang yang bengkok sebelum memasang bidai"
			],
			correct: "Pasang bidai melewati satu sendi di atas dan satu sendi di bawah lokasi patah",
			edu: "Prinsip pemasangan bidai: bidai harus melewati satu sendi di atas dan satu sendi di bawah lokasi patah untuk mencegah pergerakan tulang. JANGAN mencoba meluruskan tulang yang bengkok. Ikatan bidai harus cukup kencang (tidak longgar) namun tidak terlalu ketat sampai memotong sirkulasi darah. Periksa sirkulasi (warna, hangat, denyut nadi) di ujung anggota tubuh setelah pemasangan bidai."
		},
		{
			kategori: "Patah Tulang",
			q: "Patah tulang yang paling berbahaya karena dapat mengancam jiwa jika tidak ditangani dengan benar adalah...",
			options: [
				"Patah tulang jari kaki",
				"Patah tulang tangan bagian bawah",
				"Patah tulang belakang (spinal fracture) dan patah tulang panggul",
				"Patah tulang hidung"
			],
			correct: "Patah tulang belakang (spinal fracture) dan patah tulang panggul",
			edu: "Patah tulang belakang (vertebra) sangat berbahaya karena dapat melukai sumsum tulang belakang yang berada di dalamnya, menyebabkan kelumpuhan permanen. Korban dengan dugaan cedera tulang belakang TIDAK BOLEH dipindahkan sembarangan — harus imobilisasi total dengan papan keras. Patah tulang panggul bisa menyebabkan perdarahan dalam yang masif dan mengancam jiwa."
		},
		// ── Pingsan & Syok ───────────────────────────────────────────────────────
		{
			kategori: "Pingsan & Syok",
			q: "Posisi yang benar untuk korban yang pingsan (tidak sadar) namun masih bernapas normal adalah...",
			options: [
				"Dudukkan korban bersandar di tembok agar mudah bernapas",
				"Baringkan telentang dengan kepala lebih tinggi dari kaki",
				"Posisi miring mantap (recovery position) untuk mencegah tersedak muntahan",
				"Biarkan dalam posisi apapun saat ditemukan, tidak perlu dipindah"
			],
			correct: "Posisi miring mantap (recovery position) untuk mencegah tersedak muntahan",
			edu: "Recovery position (posisi miring mantap) adalah posisi baku untuk korban tidak sadar yang masih bernapas. Posisi ini mencegah lidah jatuh ke belakang menyumbat jalan napas dan mencegah korban tersedak jika muntah. Cara: baringkan miring dengan lutut atas ditekuk ke depan sebagai penyangga, tangan bawah diluruskan, kepala dimiringkan ke bawah sedikit."
		},
		{
			kategori: "Pingsan & Syok",
			q: "Tanda-tanda syok (shock) yang harus dikenali oleh pramuka penolong meliputi...",
			options: [
				"Wajah memerah, suhu tubuh tinggi, dan denyut nadi kuat",
				"Kulit pucat/abu-abu, dingin, berkeringat dingin; denyut nadi cepat dan lemah; napas cepat dangkal",
				"Korban terlihat mengantuk namun denyut nadi normal",
				"Tekanan darah sangat tinggi dan korban tampak gelisah saja"
			],
			correct: "Kulit pucat/abu-abu, dingin, berkeringat dingin; denyut nadi cepat dan lemah; napas cepat dangkal",
			edu: "Syok medis (bukan syok emosional) adalah kondisi ketika sistem sirkulasi gagal memasok oksigen cukup ke organ vital. Tandanya: kulit pucat, dingin, lembap/berkeringat dingin; denyut nadi cepat dan lemah; napas cepat dan dangkal; korban tampak lemah, gelisah, atau bingung; bibir/kuku kebiruan (sianosis). Syok adalah keadaan darurat medis yang bisa mengancam jiwa."
		},
		{
			kategori: "Pingsan & Syok",
			q: "Penanganan pertama pada korban yang mengalami syok adalah...",
			options: [
				"Berikan minuman manis agar gula darah naik dan korban pulih",
				"Baringkan korban, angkat kaki setinggi ±30 cm (kecuali ada cedera kepala/tulang belakang), dan selimuti",
				"Dudukkan korban dan berikan banyak minum air putih",
				"Kompres kepala dengan es dan pantau tekanan darah setiap menit"
			],
			correct: "Baringkan korban, angkat kaki setinggi ±30 cm (kecuali ada cedera kepala/tulang belakang), dan selimuti",
			edu: "Penanganan syok: (1) Baringkan korban telentang di permukaan rata. (2) Angkat kaki ±30 cm agar darah mengalir ke organ vital (kecuali ada cedera kepala, tulang belakang, atau patah tulang kaki). (3) Longgarkan pakaian ketat. (4) Selimuti agar tidak kedinginan. (5) JANGAN beri makan/minum saat korban tidak sadar atau kondisi menurun. (6) Segera hubungi 119 atau evakuasi ke RS."
		},
		// ── Tersedak & Napas ────────────────────────────────────────────────────
		{
