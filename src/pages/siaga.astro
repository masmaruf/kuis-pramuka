			],
			correct: "Sukarela, mandiri, tidak membedakan suku/ras/golongan/agama, dan bukan organisasi sosial-politik",
			edu: "AD Pasal 6 menyebutkan: '(1) Gerakan Pramuka adalah organisasi pendidikan yang keanggotaannya bersifat sukarela, mandiri, tidak membedakan suku, ras, golongan, dan agama. (2) Gerakan Pramuka bukan organisasi sosial-politik, bukan bagian dari salah-satu organisasi sosial-politik dan tidak menjalankan kegiatan politik praktis. (3) Gerakan Pramuka menjamin kemerdekaan tiap-tiap anggotanya untuk memeluk agama dan kepercayaan masing-masing.' Sifat sukarela ini penting — tidak ada paksaan untuk bergabung."
		},
	];

	const XP_PER_CORRECT = 12;
	const QUESTIONS_PER_SESSION = 10;

	const BADGES_FOR_THIS_QUIZ = [
		{ id: 'siaga_novice', name: 'Pandu Siaga',    icon: '🟢' },
		{ id: 'siaga_master', name: 'Ahli Siaga',     icon: '⭐' },
	];

	let questions: Question[] = [];
	let currentIndex = 0;
	let selectedAnswer = '';
	let score = 0;
	let totalXpEarned = 0;

	function shuffle<T>(arr: T[]): T[] {
		return [...arr].sort(() => Math.random() - 0.5);
	}

	function getEl<T extends HTMLElement>(id: string) {
		return document.getElementById(id) as T | null;
	}

	function startQuiz() {
		questions = shuffle(QUESTIONS_POOL).slice(0, QUESTIONS_PER_SESSION);
		currentIndex = 0; score = 0; totalXpEarned = 0; selectedAnswer = '';
		renderQuestion();
	}

	function renderQuestion() {
		const q = questions[currentIndex];
		const num = currentIndex + 1;
		const pct = (num / QUESTIONS_PER_SESSION) * 100;
		getEl('question-number')!.textContent = `Soal ${num} dari ${QUESTIONS_PER_SESSION}`;
		(getEl('progress-pct') as HTMLElement).textContent = `${Math.round(pct)}%`;
		getEl<HTMLDivElement>('quiz-progress-bar')!.style.width = `${pct}%`;
		const catEl = getEl('question-category');
		if (catEl) catEl.innerHTML = `<span class="cat-pill">🟢 ${q.kategori}</span>`;
		getEl('question-prompt')!.textContent = q.q;
		const eduCard = getEl<HTMLDivElement>('education-card');
		if (eduCard) eduCard.style.display = 'none';
		const submitBtn = getEl<HTMLButtonElement>('btn-submit-answer');
		if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Konfirmasi Jawaban'; submitBtn.onclick = submitAnswer; }
		const hint = getEl('answer-hint');
		if (hint) { hint.textContent = 'Pilih salah satu jawaban di atas'; hint.className = 'answer-hint'; }
		selectedAnswer = '';
		renderOptions(q);
	}

	function renderOptions(q: Question) {
		const container = getEl<HTMLDivElement>('options-container');
		if (!container) return;
		const shuffledOpts = shuffle(q.options);
		container.innerHTML = shuffledOpts.map((opt, i) => {
			const letter = String.fromCharCode(65 + i);
			return `
			<button class="opt-btn" data-answer="${opt.replace(/"/g, '&quot;')}" style="animation-delay:${i * 0.07}s">
				<span class="opt-letter">${letter}</span>
				<span class="opt-text">${opt}</span>
				<span class="opt-indicator">
					<span class="opt-radio"></span>
					<svg class="opt-icon icon-check" viewBox="0 0 24 24" fill="none" stroke="#236c32" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
					<svg class="opt-icon icon-cross" viewBox="0 0 24 24" fill="none" stroke="#a5301a" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
				</span>
			</button>`;
		}).join('');
		container.querySelectorAll('.opt-btn').forEach((btn, i) => {
			btn.addEventListener('click', () => {
				container.querySelectorAll('.opt-btn').forEach(b => b.classList.remove('is-selected'));
				btn.classList.add('is-selected');
				selectedAnswer = (btn as HTMLElement).dataset.answer || '';
				const submitBtn = getEl<HTMLButtonElement>('btn-submit-answer');
				if (submitBtn) submitBtn.disabled = false;
				const hint = getEl('answer-hint');
				if (hint) { hint.textContent = `Jawaban ${String.fromCharCode(65 + i)} dipilih — klik Konfirmasi untuk lanjut`; hint.className = 'answer-hint chosen'; }
			});
		});
	}

	function submitAnswer() {
		const q = questions[currentIndex];
		const isCorrect = selectedAnswer === q.correct;
		if (isCorrect) { score++; totalXpEarned += XP_PER_CORRECT; }
		const container = getEl<HTMLDivElement>('options-container');
		container?.querySelectorAll('.opt-btn').forEach(btn => {
			const el = btn as HTMLElement; const ans = el.dataset.answer || '';
			el.classList.add('is-answered'); el.classList.remove('is-selected');
			if (ans === q.correct) el.classList.add('is-correct');
			else if (ans === selectedAnswer && !isCorrect) el.classList.add('is-incorrect');
			else el.classList.add('is-dimmed');
		});
		const eduCard = getEl<HTMLDivElement>('education-card');
		const eduText = getEl('education-text');
		if (eduCard && eduText) { eduText.textContent = q.edu; eduCard.style.display = 'flex'; eduCard.className = `education-card ${isCorrect ? 'correct' : 'incorrect'}`; }
		const hint = getEl('answer-hint');
		if (hint) { hint.textContent = isCorrect ? '✓ Jawaban benar!' : '✗ Jawaban salah — lihat penjelasan di bawah.'; hint.className = `answer-hint ${isCorrect ? 'correct-hint' : 'wrong-hint'}`; }
		const submitBtn = getEl<HTMLButtonElement>('btn-submit-answer');
		if (submitBtn) { submitBtn.textContent = currentIndex < QUESTIONS_PER_SESSION - 1 ? 'Soal Berikutnya →' : 'Lihat Hasil'; submitBtn.disabled = false; submitBtn.onclick = nextQuestion; }
	}

	function nextQuestion() {
		currentIndex++;
		if (currentIndex < QUESTIONS_PER_SESSION) { renderQuestion(); const sb = getEl<HTMLButtonElement>('btn-submit-answer'); if (sb) sb.onclick = submitAnswer; }
		else showResult();
	}

	function showResult() {
		const pct = Math.round((score / QUESTIONS_PER_SESSION) * 100);
		const currentXp = parseInt(localStorage.getItem('scout_xp') || '0');
		localStorage.setItem('scout_xp', (currentXp + totalXpEarned).toString());
		const earnedBadges: string[] = JSON.parse(localStorage.getItem('scout_badges') || '[]');
		const newlyUnlocked: typeof BADGES_FOR_THIS_QUIZ = [];
		if (!earnedBadges.includes('siaga_novice')) { earnedBadges.push('siaga_novice'); newlyUnlocked.push(BADGES_FOR_THIS_QUIZ[0]); }
		if (pct === 100 && !earnedBadges.includes('siaga_master')) { earnedBadges.push('siaga_master'); newlyUnlocked.push(BADGES_FOR_THIS_QUIZ[1]); }
		const totalXpNow = parseInt(localStorage.getItem('scout_xp') || '0');
		if (totalXpNow >= 500 && !earnedBadges.includes('scout_master')) earnedBadges.push('scout_master');
		localStorage.setItem('scout_badges', JSON.stringify(earnedBadges));
		const emoji = pct === 100 ? '🏆' : pct >= 80 ? '⭐' : pct >= 60 ? '👍' : '📚';
		getEl('result-emoji')!.textContent = emoji;
		getEl('result-title')!.textContent = pct === 100 ? 'Sempurna! Ahli Siaga!' : pct >= 80 ? 'Bagus Sekali!' : pct >= 60 ? 'Cukup Baik!' : 'Terus Belajar!';
		getEl('result-text')!.textContent = `Kamu menjawab ${score} dari ${QUESTIONS_PER_SESSION} soal dengan benar (${pct}%). ${pct >= 80 ? 'Kamu menguasai ketentuan Pramuka Siaga dengan sangat baik!' : 'Pelajari kembali Dwisatya, Dwidarma, SKU Siaga, serta pasal-pasal AD/ART yang mengatur golongan Siaga.'}`;
		getEl('result-xp')!.textContent = `+${totalXpEarned} XP`;
		getEl('result-score')!.textContent = `${pct}/100`;
		getEl('result-correct')!.textContent = `${score}/${QUESTIONS_PER_SESSION}`;
		if (newlyUnlocked.length > 0) {
			const bc = getEl<HTMLDivElement>('unlocked-badges'); const bl = getEl('badges-list-el');
			if (bc && bl) { bl.innerHTML = newlyUnlocked.map(b => `<div class="new-badge-item"><span class="new-badge-icon">${b.icon}</span><span class="new-badge-name">${b.name}</span></div>`).join(''); bc.style.display = 'block'; }
		}
		const overlay = getEl<HTMLDivElement>('result-overlay');
		if (overlay) overlay.style.display = 'flex';
		window.dispatchEvent(new Event('statsUpdated'));
	}

	getEl<HTMLButtonElement>('btn-submit-answer')?.addEventListener('click', submitAnswer);
	getEl<HTMLButtonElement>('btn-restart')?.addEventListener('click', () => {
		const overlay = getEl<HTMLDivElement>('result-overlay');
		if (overlay) overlay.style.display = 'none';
		startQuiz();
	});
	startQuiz();
</script>

<style>
	.quiz-container { display: flex; flex-direction: column; gap: 1.5rem; }

	.quiz-header { display: flex; align-items: center; gap: 1.5rem; padding: 1.25rem 1.75rem; flex-wrap: wrap; }

	.btn-back { display: flex; align-items: center; gap: 0.45rem; color: var(--color-text-muted); text-decoration: none; font-size: 0.88rem; font-weight: 500; white-space: nowrap; transition: color var(--transition-fast); }
	.btn-back:hover { color: var(--color-gold); }
	.btn-back svg { width: 16px; height: 16px; }

	.quiz-title-area { display: flex; align-items: center; gap: 0.85rem; flex-wrap: wrap; }
	.quiz-title-area h2 { font-size: 1.25rem; font-weight: 700; color: var(--color-text); }

	.quiz-difficulty { font-size: 0.72rem; font-weight: 700; padding: 0.25rem 0.65rem; border-radius: 4px; text-transform: uppercase; letter-spacing: 0.5px; }
	.quiz-difficulty.siaga { background: rgba(35,108,50,0.1); color: #236c32; border: 1px solid rgba(35,108,50,0.22); }

	.quiz-layout { display: grid; grid-template-columns: 1fr 300px; gap: 1.5rem; align-items: start; }

	.quiz-main-card { padding: 2rem; display: flex; flex-direction: column; gap: 1.5rem; }

	.progress-tracker { display: flex; flex-direction: column; gap: 0.5rem; }
	.progress-label { display: flex; justify-content: space-between; align-items: center; font-size: 0.8rem; color: var(--color-text-muted); font-weight: 500; }
	.pct-label { font-weight: 700; color: var(--color-primary-light); }
	.progress-bar-outer { height: 6px; background: var(--color-border); border-radius: var(--radius-full); overflow: hidden; }
	.progress-bar-inner { height: 100%; background: linear-gradient(90deg, var(--color-success), var(--color-gold)); border-radius: var(--radius-full); transition: width 0.4s ease; }

	.question-category { display: flex; }
	.cat-pill { background: rgba(35,108,50,0.08); color: #236c32; border: 1px solid rgba(35,108,50,0.2); padding: 0.28rem 0.75rem; border-radius: var(--radius-full); font-size: 0.75rem; font-weight: 700; }

	.question-text-area h3 { font-size: 1.1rem; font-weight: 700; color: var(--color-text); line-height: 1.55; }

	/* Options */
	.opt-btn { width: 100%; display: flex; align-items: center; gap: 0.85rem; padding: 0.9rem 1.1rem; background: var(--color-bg); border: 1.5px solid var(--color-border); border-radius: var(--radius-md); cursor: pointer; text-align: left; transition: all var(--transition-fast); animation: fadeSlideIn 0.25s ease both; }
	@keyframes fadeSlideIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }
	.opt-btn:hover:not(.is-answered) { border-color: rgba(35,108,50,0.35); background: rgba(35,108,50,0.04); }
	.opt-btn.is-selected { border-color: rgba(35,108,50,0.5); background: rgba(35,108,50,0.06); }
	.opt-letter { width: 28px; height: 28px; border-radius: 50%; background: var(--color-surface-solid); border: 1px solid var(--color-border); display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700; color: var(--color-text-muted); flex-shrink: 0; }
	.opt-text { flex: 1; font-size: 0.9rem; color: var(--color-text); line-height: 1.45; }
	.opt-indicator { width: 24px; height: 24px; position: relative; flex-shrink: 0; }
	.opt-radio { width: 18px; height: 18px; border-radius: 50%; border: 2px solid var(--color-border); position: absolute; top: 3px; left: 3px; transition: all var(--transition-fast); }
	.opt-btn.is-selected .opt-radio { border-color: #236c32; background: rgba(35,108,50,0.15); }
	.opt-icon { width: 24px; height: 24px; position: absolute; top: 0; left: 0; display: none; }
	.opt-btn.is-correct .opt-radio, .opt-btn.is-incorrect .opt-radio { display: none; }
	.opt-btn.is-correct .icon-check { display: block; }
	.opt-btn.is-incorrect .icon-cross { display: block; }
	.opt-btn.is-correct  { border-color: rgba(35,108,50,0.5);  background: rgba(35,108,50,0.08);  pointer-events: none; }
	.opt-btn.is-incorrect{ border-color: rgba(185,59,34,0.5);  background: rgba(185,59,34,0.08);  pointer-events: none; }
	.opt-btn.is-dimmed   { opacity: 0.45; pointer-events: none; }

	/* Education card */
	.education-card { display: flex; flex-direction: column; gap: 0.6rem; padding: 1rem 1.15rem; border-radius: var(--radius-md); border: 1px solid var(--color-border); background: var(--color-surface-solid); }
	.education-card.correct { border-color: rgba(35,108,50,0.3); background: rgba(35,108,50,0.05); }
	.education-card.incorrect { border-color: rgba(185,59,34,0.3); background: rgba(185,59,34,0.05); }
	.edu-header { display: flex; align-items: center; gap: 0.5rem; }
	.edu-icon { font-size: 1rem; }
	.edu-label { font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--color-text-muted); }
	#education-text { font-size: 0.85rem; line-height: 1.6; color: var(--color-text-muted); }

	/* Action footer */
	.action-footer { display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap; padding-top: 0.5rem; border-top: 1px solid var(--color-border); }
	.answer-hint { font-size: 0.82rem; color: var(--color-text-faint); }
	.answer-hint.chosen { color: var(--color-text-muted); }
	.answer-hint.correct-hint { color: #236c32; font-weight: 600; }
	.answer-hint.wrong-hint   { color: #a5301a; font-weight: 600; }

	/* Sidebar */
	.quiz-help-card { padding: 1.5rem; display: flex; flex-direction: column; gap: 0.85rem; position: sticky; top: 1.5rem; }
	.quiz-help-card h3 { font-size: 0.95rem; font-weight: 700; color: var(--color-text); }
	.help-subtitle { font-size: 0.78rem; color: var(--color-text-faint); margin-top: -0.5rem; }
	.help-divider { height: 1px; background: var(--color-border); margin: 0.25rem 0; }

	.oath-box { background: rgba(35,108,50,0.04); border: 1px solid rgba(35,108,50,0.15); border-radius: var(--radius-sm); padding: 0.75rem 1rem; }
	.oath-title { font-size: 0.78rem; color: var(--color-text-muted); font-style: italic; margin-bottom: 0.4rem; line-height: 1.4; }
	.oath-list { padding-left: 1.1rem; display: flex; flex-direction: column; gap: 0.35rem; }
	.oath-list li { font-size: 0.8rem; color: var(--color-text); line-height: 1.4; }

	.sku-table { display: flex; flex-direction: column; gap: 0.2rem; }
	.sku-row { display: flex; justify-content: space-between; align-items: center; font-size: 0.8rem; padding: 0.35rem 0; border-bottom: 1px solid var(--color-border); }
	.sku-row:last-child { border-bottom: none; }
	.sku-row.header { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--color-text-faint); padding-bottom: 0.4rem; }
	.sku-badge { font-size: 0.75rem; font-weight: 700; padding: 0.15rem 0.5rem; border-radius: 4px; }
	.sku-badge.mula  { background: rgba(35,108,50,0.1);  color: #236c32;  border: 1px solid rgba(35,108,50,0.2); }
	.sku-badge.bantu { background: rgba(212,163,43,0.1); color: #a07010;  border: 1px solid rgba(212,163,43,0.2); }
	.sku-badge.tata  { background: rgba(185,59,34,0.09); color: #c0513c;  border: 1px solid rgba(185,59,34,0.18); }

	.fact-box { display: flex; flex-direction: column; gap: 0.2rem; }
	.fact-row { display: flex; justify-content: space-between; align-items: center; font-size: 0.8rem; padding: 0.3rem 0; border-bottom: 1px solid var(--color-border); }
	.fact-row:last-child { border-bottom: none; }
	.fact-key { color: var(--color-text-muted); }
	.fact-val { font-weight: 700; color: var(--color-text); font-size: 0.78rem; }

	/* Result overlay */
	.result-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.55); display: flex; align-items: center; justify-content: center; z-index: 200; padding: 1rem; }
	.result-card { width: 100%; max-width: 480px; padding: 2.5rem 2rem; display: flex; flex-direction: column; align-items: center; gap: 1.25rem; text-align: center; }
	.result-emoji { font-size: 3rem; }
	.result-card h2 { font-size: 1.6rem; font-weight: 800; color: var(--color-text); }
	.result-summary { font-size: 0.9rem; color: var(--color-text-muted); line-height: 1.55; }
	.result-stats-details { display: flex; gap: 1.5rem; flex-wrap: wrap; justify-content: center; width: 100%; padding: 1.25rem; border-radius: var(--radius-md); background: var(--color-surface-solid); border: 1px solid var(--color-border); }
	.detail-item { display: flex; flex-direction: column; align-items: center; gap: 0.2rem; }
	.detail-item .label { font-size: 0.72rem; color: var(--color-text-faint); text-transform: uppercase; letter-spacing: 0.5px; }
	.detail-item .value { font-size: 1.25rem; font-weight: 800; color: var(--color-text); }
	.score-xp { color: var(--color-gold); }
	.unlocked-badges-container { width: 100%; padding: 1rem; border-radius: var(--radius-md); background: rgba(212,163,43,0.06); border: 1px solid rgba(212,163,43,0.2); }
	.unlocked-badges-container h3 { font-size: 0.9rem; font-weight: 700; margin-bottom: 0.75rem; color: var(--color-text); }
	.unlocked-badges-list { display: flex; flex-wrap: wrap; gap: 0.5rem; justify-content: center; }
	.new-badge-item { display: flex; align-items: center; gap: 0.5rem; padding: 0.4rem 0.85rem; border-radius: var(--radius-full); background: rgba(212,163,43,0.1); border: 1px solid rgba(212,163,43,0.25); }
	.new-badge-icon { font-size: 1.1rem; }
	.new-badge-name { font-size: 0.8rem; font-weight: 700; color: var(--color-text); }
	.result-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; justify-content: center; }

	@media (max-width: 900px) { .quiz-layout { grid-template-columns: 1fr; } .quiz-help-card { position: static; } }
	@media (max-width: 600px) { .quiz-main-card { padding: 1.25rem; } .quiz-header { padding: 1rem 1.25rem; } }
</style>
