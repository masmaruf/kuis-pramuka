---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Kuis Pramuka Siaga — UU, AD/ART & Jukran" description="Latihan soal Pramuka Siaga berdasarkan UU No.12/2010, AD/ART Gerakan Pramuka 2012, dan Jukran PP SKU SK 088/1974: Dwisatya, Dwidarma, SKU Mula-Bantu-Tata, dan satuan Siaga.">
	<div class="quiz-container">
		<header class="quiz-header glass-card">
			<a href="/" class="btn-back">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<line x1="19" y1="12" x2="5" y2="12"/>
					<polyline points="12 19 5 12 12 5"/>
				</svg>
				Kembali ke Dasbor
			</a>
			<div class="quiz-title-area">
				<h2>Kuis Pramuka Siaga</h2>
				<span class="quiz-difficulty siaga">UU · AD/ART · Jukran</span>
			</div>
		</header>

		<div class="quiz-layout">
			<!-- Main Quiz Card -->
			<div class="quiz-main-card glass-card">
				<div class="progress-tracker">
					<div class="progress-label">
						<span id="question-number">Soal 1 dari 10</span>
						<span id="progress-pct" class="pct-label">10%</span>
					</div>
					<div class="progress-bar-outer">
						<div id="quiz-progress-bar" class="progress-bar-inner" style="width: 10%"></div>
					</div>
				</div>

				<div class="question-category" id="question-category">
					<span class="cat-pill">🟢 Pramuka Siaga</span>
				</div>

				<div class="question-text-area">
					<h3 id="question-prompt">Soal akan dimuat...</h3>
				</div>

				<div class="flex flex-col gap-2.5" id="options-container"></div>

				<div class="education-card" id="education-card" style="display: none;">
					<div class="edu-header">
						<span class="edu-icon">📖</span>
						<span class="edu-label">Penjelasan &amp; Sumber</span>
					</div>
					<p id="education-text"></p>
				</div>

				<div class="action-footer">
					<span id="answer-hint" class="answer-hint">Pilih salah satu jawaban di atas</span>
					<button id="btn-submit-answer" class="btn btn-gold" disabled>Konfirmasi Jawaban</button>
				</div>
			</div>

			<!-- Reference Sidebar -->
			<div class="quiz-help-card glass-card">
				<h3>Dwisatya Pramuka Siaga</h3>
				<p class="help-subtitle">Janji anggota Siaga · AD Pasal 12</p>
				<div class="oath-box">
					<p class="oath-title">Demi kehormatanku aku berjanji akan bersungguh-sungguh:</p>
					<ol class="oath-list">
						<li>Menjalankan kewajibanku terhadap Tuhan, Negara Kesatuan Republik Indonesia <em>dan menurut aturan keluarga.</em></li>
						<li>Setiap hari berbuat kebaikan.</li>
					</ol>
				</div>

				<div class="help-divider"></div>

				<h3>Dwidarma Pramuka Siaga</h3>
				<p class="help-subtitle">Ketentuan moral Siaga · AD Pasal 12</p>
				<div class="oath-box">
					<ol class="oath-list">
						<li>Siaga itu patuh pada ayah dan ibunya.</li>
						<li>Siaga itu berani dan tidak putus asa.</li>
					</ol>
				</div>

				<div class="help-divider"></div>

				<h3>SKU Siaga — 3 Tingkat</h3>
				<p class="help-subtitle">Jukran PP SKU · SK 088/1974</p>
				<div class="sku-table">
					<div class="sku-row header">
						<span>Tingkat</span><span>Syarat Latihan</span>
					</div>
					<div class="sku-row">
						<span class="sku-badge mula">Mula</span>
						<span>6× berturut-turut</span>
					</div>
					<div class="sku-row">
						<span class="sku-badge bantu">Bantu</span>
						<span>10× sebagai Mula</span>
					</div>
					<div class="sku-row">
						<span class="sku-badge tata">Tata</span>
						<span>10× sebagai Bantu + 1 TKK</span>
					</div>
				</div>

				<div class="help-divider"></div>

				<h3>Satuan Pramuka Siaga</h3>
				<div class="fact-box">
					<div class="fact-row"><span class="fact-key">Usia</span><span class="fact-val">7–10 tahun</span></div>
					<div class="fact-row"><span class="fact-key">Satuan kecil</span><span class="fact-val">Barung</span></div>
					<div class="fact-row"><span class="fact-key">Satuan besar</span><span class="fact-val">Perindukan</span></div>
					<div class="fact-row"><span class="fact-key">Pembina putra</span><span class="fact-val">Yanda</span></div>
					<div class="fact-row"><span class="fact-key">Pembina putri</span><span class="fact-val">Bunda</span></div>
					<div class="fact-row"><span class="fact-key">Pasal AD</span><span class="fact-val">Ps. 12, 14, 15, 29</span></div>
				</div>
			</div>
		</div>

		<!-- Result Overlay -->
		<div class="result-overlay" id="result-overlay" style="display: none;">
			<div class="result-card glass-card">
				<div class="result-emoji" id="result-emoji">🏆</div>
				<h2 id="result-title">Kuis Selesai!</h2>
				<p class="result-summary" id="result-text">Anda menjawab soal dengan baik.</p>
				<div class="result-stats-details">
					<div class="detail-item">
						<span class="label">XP Diperoleh</span>
						<span class="value score-xp" id="result-xp">+100 XP</span>
					</div>
					<div class="detail-item">
						<span class="label">Skor Akhir</span>
						<span class="value" id="result-score">100/100</span>
					</div>
					<div class="detail-item">
						<span class="label">Jawaban Benar</span>
						<span class="value" id="result-correct">10/10</span>
					</div>
				</div>
				<div class="unlocked-badges-container" id="unlocked-badges" style="display: none;">
					<h3>🎖️ Lencana Baru Terbuka!</h3>
					<div class="unlocked-badges-list" id="badges-list-el"></div>
				</div>
				<div class="result-actions">
					<button id="btn-restart" class="btn btn-primary">Ulangi Kuis</button>
					<a href="/" class="btn btn-gold">Kembali ke Dasbor</a>
				</div>
			</div>
		</div>
	</div>
</Layout>

<script>
	// ─── Bank Soal Pramuka Siaga — UU, AD/ART, Jukran (30 soal) ────────────────

	interface Question {
		kategori: string;
		q: string;
		options: string[];
		correct: string;
		edu: string;
	}

	const QUESTIONS_POOL: Question[] = [

		// ── Dasar Hukum & Regulasi ───────────────────────────────────────────────
		{
			kategori: "Dasar Hukum",
			q: "Berdasarkan AD Gerakan Pramuka (Munaslub 2012) Pasal 14, jenjang pendidikan kepramukaan yang pertama (paling dasar) adalah...",
			options: ["Penggalang", "Pandega", "Siaga", "Penegak"],
			correct: "Siaga",
			edu: "AD Pasal 14 menyebutkan: 'Jenjang pendidikan kepramukaan terdiri atas jenjang pendidikan: a. siaga; b. penggalang; c. penegak; dan d. pandega.' Urutan ini mencerminkan tingkatan usia dari termuda (Siaga, 7–10 tahun) hingga tertua (Pandega, 21–25 tahun). Siaga menjadi jenjang pertama karena merupakan pintu masuk pendidikan kepramukaan bagi anak usia sekolah dasar."
		},
		{
			kategori: "Dasar Hukum",
			q: "Berdasarkan AD Pasal 29 ayat 2, gugus depan lengkap terdiri atas empat satuan. Satuan untuk Pramuka Siaga disebut...",
			options: ["Pasukan Siaga", "Perindukan Siaga", "Regu Siaga", "Ambalan Siaga"],
			correct: "Perindukan Siaga",
			edu: "AD Pasal 29 ayat (2) menyebutkan: 'Gugus depan lengkap terdiri atas: a. perindukan siaga; b. pasukan penggalang; c. ambalan penegak; dan d. racana pandega.' Setiap satuan memiliki nama kiasan yang berbeda — perindukan (Siaga), pasukan (Penggalang), ambalan (Penegak), dan racana (Pandega). Nama-nama ini bersumber dari kiasan dasar perjuangan bangsa."
		},
		{
			kategori: "Dasar Hukum",
			q: "Petunjuk Penyelenggaraan (Jukran) SKU yang mengatur tingkatan Siaga Mula, Bantu, dan Tata ditetapkan melalui...",
			options: [
				"SK Kwarnas No. 6 Tahun 1963",
				"SK Kwarnas No. 088 Tahun 1974",
				"SK Kwarnas No. 199 Tahun 2011",
				"Keppres No. 238 Tahun 1961"
			],
			correct: "SK Kwarnas No. 088 Tahun 1974",
			edu: "Petunjuk Penyelenggaraan Syarat Kecakapan Umum (PP SKU) ditetapkan melalui Keputusan Kwartir Nasional Gerakan Pramuka Nomor 088 Tahun 1974 tanggal 24 Oktober 1974. SK ini mencabut SK No. 6/1963 yang sudah tidak sesuai perkembangan. Jukran ini mengatur secara rinci syarat-syarat SKU untuk semua golongan: Siaga (3 tingkat), Penggalang (3 tingkat), Penegak (2 tingkat), dan Pandega (1 tingkat)."
		},
		{
			kategori: "Dasar Hukum",
			q: "Menurut AD Pasal 15, Pramuka Siaga termasuk dalam kategori anggota Gerakan Pramuka sebagai...",
			options: ["Anggota kehormatan", "Anggota dewasa", "Peserta didik", "Anggota tamu"],
			correct: "Peserta didik",
			edu: "AD Pasal 15 ayat (2) menyebutkan: 'Peserta didik terdiri dari: a. Pramuka Siaga; b. Pramuka Penggalang; c. Pramuka Penegak; dan d. Pramuka Pandega.' Selain peserta didik, anggota GP juga terdiri dari anggota dewasa (tenaga pendidik, andalan, dll.) dan anggota kehormatan. Peserta didik berusia 7–25 tahun sesuai AD Pasal 25."
		},
		{
			kategori: "Dasar Hukum",
			q: "Berdasarkan AD Pasal 26, siapakah yang berkedudukan sebagai Pramuka Utama dalam Gerakan Pramuka?",
			options: [
				"Ketua Kwartir Nasional terpilih",
				"Ketua Majelis Pembimbing Nasional",
				"Kepala Negara Republik Indonesia",
				"Menteri Pendidikan dan Kebudayaan"
			],
			correct: "Kepala Negara Republik Indonesia",
			edu: "AD Pasal 26 menyebutkan secara tegas: 'Kepala Negara Republik Indonesia adalah Pramuka Utama.' Ini berarti Presiden RI berkedudukan sebagai Pramuka Utama — pemimpin kehormatan tertinggi Gerakan Pramuka. Ketua Majelis Pembimbing Nasional juga dijabat oleh Presiden RI (AD Pasal 36 ayat 4a), sehingga Presiden menjadi pelindung sekaligus pramuka utama gerakan ini."
		},
		{
			kategori: "Dasar Hukum",
			q: "Tujuan SKU menurut Jukran PP SKU (SK 088/1974) Poin 3 adalah...",
			options: [
				"Mewajibkan setiap pramuka untuk mengikuti ujian resmi",
				"Merangsang dan mendorong para pramuka untuk giat meningkatkan kecakapan yang berguna bagi kehidupan dan kebaktian kepada masyarakat",
				"Menentukan golongan usia pramuka secara resmi",
				"Memberikan tanda penghargaan kepada pramuka berprestasi"
			],
			correct: "Merangsang dan mendorong para pramuka untuk giat meningkatkan kecakapan yang berguna bagi kehidupan dan kebaktian kepada masyarakat",
			edu: "Jukran PP SKU (SK 088/1974) Poin 3 menyebutkan: 'Tujuan SKU adalah merangsang dan mendorong para Pramuka untuk giat berusaha meningkatkan berbagai kecakapan yang berguna bagi kehidupannya dan bagi kebaktiannya kepada masyarakat.' SKU bukan sekadar ujian, melainkan alat motivasi agar pramuka terus berkembang. Tanda kecakapan yang diberikan setelah lulus SKU merupakan pengakuan atas kompetensi yang dicapai (AD Pasal 24)."
		},

		// ── Kode Kehormatan Siaga ────────────────────────────────────────────────
		{
			kategori: "Kode Kehormatan",
			q: "Berdasarkan AD Gerakan Pramuka Pasal 12 ayat 5, kode kehormatan Pramuka Siaga berupa janji disebut...",
			options: ["Trisatya", "Dwisatya", "Pancasatya", "Ikrar Siaga"],
			correct: "Dwisatya",
			edu: "AD Pasal 12 ayat (5a) menyebutkan: 'Kode kehormatan Pramuka siaga terdiri atas Dwisatya dan Dwidarma Pramuka.' Awalan 'Dwi' berarti dua — Dwisatya berarti janji yang terdiri dari dua butir ikrar, sedangkan Dwidarma berarti ketentuan moral yang terdiri dari dua darma. Ini berbeda dari Penggalang/Penegak yang menggunakan Trisatya (tiga butir) dan Dasadarma (sepuluh darma)."
		},
		{
			kategori: "Kode Kehormatan",
			q: "Isi butir PERTAMA dari Dwisatya yang diucapkan Pramuka Siaga adalah...",
			options: [
				"Setiap hari berbuat kebaikan",
				"Menjalankan kewajibanku terhadap Tuhan, Negara Kesatuan Republik Indonesia dan menurut aturan keluarga",
				"Menolong sesama hidup dan mempersiapkan diri membangun masyarakat",
				"Mengamalkan Pancasila dengan sepenuh hati"
			],
			correct: "Menjalankan kewajibanku terhadap Tuhan, Negara Kesatuan Republik Indonesia dan menurut aturan keluarga",
			edu: "Dwisatya berbunyi: 'Demi kehormatanku aku berjanji akan bersungguh-sungguh: (1) Menjalankan kewajibanku terhadap Tuhan, Negara Kesatuan Republik Indonesia dan menurut aturan keluarga. (2) Setiap hari berbuat kebaikan.' Butir pertama mencakup kewajiban vertikal (kepada Tuhan), kewajiban kebangsaan (terhadap NKRI), dan kewajiban keluarga. Frasa 'menurut aturan keluarga' — bukan 'mengamalkan Pancasila' — adalah khas Dwisatya, karena Siaga masih anak-anak yang berpusat pada keluarga."
		},
		{
			kategori: "Kode Kehormatan",
			q: "Isi butir KEDUA dari Dwisatya Pramuka Siaga adalah...",
			options: [
				"Menepati Dwidarma dengan sepenuh hati",
				"Menolong sesama hidup",
				"Setiap hari berbuat kebaikan",
				"Mengikuti latihan Perindukan dengan rajin"
			],
			correct: "Setiap hari berbuat kebaikan",
			edu: "Butir kedua Dwisatya adalah 'Setiap hari berbuat kebaikan.' Kalimat ini sederhana namun sangat bermakna — menanamkan kebiasaan berbuat baik setiap hari sebagai nilai utama. Ini sesuai dengan usia Siaga (7–10 tahun) yang masih dalam tahap pembentukan karakter dasar. Bandingkan dengan Trisatya Penggalang yang lebih kompleks: menolong sesama, mempersiapkan diri membangun masyarakat, dan menepati Dasadarma."
		},
		{
			kategori: "Kode Kehormatan",
			q: "Dwidarma PERTAMA Pramuka Siaga berbunyi...",
			options: [
				"Siaga itu berani dan tidak putus asa",
				"Siaga itu rajin dan giat mengikuti latihan",
				"Siaga itu patuh pada ayah dan ibunya",
				"Siaga itu hemat, cermat, dan bersahaja"
			],
			correct: "Siaga itu patuh pada ayah dan ibunya",
			edu: "Dwidarma pertama berbunyi: 'Siaga itu patuh pada ayah dan ibunya.' Darma ini menekankan nilai kepatuhan kepada orang tua sebagai pondasi moral anak usia 7–10 tahun. Ini selaras dengan butir pertama Dwisatya yang menyebutkan 'menurut aturan keluarga.' Filosofinya: seorang yang belum bisa menghormati orang tuanya sendiri belum siap untuk mengabdi kepada masyarakat dan bangsa."
		},
		{
			kategori: "Kode Kehormatan",
			q: "Dwidarma KEDUA Pramuka Siaga berbunyi...",
			options: [
				"Siaga itu disiplin, berani, dan setia",
				"Siaga itu berani dan tidak putus asa",
				"Siaga itu rajin, terampil, dan gembira",
				"Siaga itu suci dalam pikiran, perkataan, dan perbuatan"
			],
			correct: "Siaga itu berani dan tidak putus asa",
			edu: "Dwidarma kedua berbunyi: 'Siaga itu berani dan tidak putus asa.' Darma ini menanamkan keberanian dan keteguhan hati — karakter penting bagi anak usia Siaga yang sedang membentuk kepribadian. Perhatikan bahwa Dwidarma sangat ringkas (hanya 2 darma) dibanding Dasadarma Penggalang/Penegak (10 darma), karena disesuaikan dengan kemampuan pemahaman anak usia 7–10 tahun."
		},
		{
			kategori: "Kode Kehormatan",
			q: "Perbedaan kode kehormatan Pramuka Siaga dengan Pramuka Penggalang adalah...",
			options: [
				"Siaga menggunakan Trisatya, Penggalang menggunakan Dwisatya",
				"Siaga menggunakan Dwisatya & Dwidarma, Penggalang menggunakan Trisatya & Dasadarma",
				"Keduanya menggunakan Trisatya tetapi Dasadarma berbeda",
				"Siaga belum memiliki kode kehormatan karena masih terlalu muda"
			],
			correct: "Siaga menggunakan Dwisatya & Dwidarma, Penggalang menggunakan Trisatya & Dasadarma",
			edu: "AD Pasal 12 ayat (5) menetapkan kode kehormatan berbeda untuk tiap golongan: (a) Siaga: Dwisatya + Dwidarma; (b) Penggalang: Trisatya + Dasadarma; (c) Penegak, Pandega & anggota dewasa: Trisatya + Dasadarma (isi Trisatya sedikit berbeda: 'ikut serta membangun masyarakat' untuk Penegak/Pandega vs 'mempersiapkan diri membangun masyarakat' untuk Penggalang). Perbedaan ini disesuaikan dengan usia dan tingkat perkembangan jiwa serta jasmani masing-masing golongan."
		},

		// ── Satuan & Organisasi Siaga ────────────────────────────────────────────
		{
			kategori: "Satuan Siaga",
			q: "Satuan terkecil dalam golongan Pramuka Siaga yang terdiri atas beberapa orang Siaga disebut...",
			options: ["Regu", "Barung", "Sangga", "Umpi"],
			correct: "Barung",
			edu: "Satuan terkecil Pramuka Siaga disebut Barung, dipimpin oleh Ketua Barung (Pinrung — Pemimpin Barung). Nama 'barung' adalah kiasan dari budaya dan bahasa lokal Indonesia. Beberapa Barung bergabung membentuk Perindukan. Bandingkan: Penggalang → Regu + Pasukan; Penegak → Sangga + Ambalan; Pandega → Reka + Racana. Nama-nama kiasan ini merupakan bagian dari Kiasan Dasar kepramukaan (AD Pasal 10)."
		},
		{
			kategori: "Satuan Siaga",
			q: "Beberapa Barung bergabung membentuk satuan besar Pramuka Siaga yang disebut...",
			options: ["Pasukan", "Gugus Depan", "Perindukan", "Ambalan"],
			correct: "Perindukan",
			edu: "Beberapa Barung (satuan kecil) bergabung membentuk Perindukan (satuan besar). Ini sesuai AD Pasal 29 yang menyebut 'perindukan siaga' sebagai salah satu satuan dalam gugus depan lengkap. Perindukan dikoordinir oleh Pembina Siaga (Yanda/Bunda) dan Pembantu Pembina Siaga (Ayah/Ibu). Perindukan lengkap biasanya memiliki 3–5 Barung."
		},
		{
			kategori: "Satuan Siaga",
			q: "Pembina Pramuka Siaga putra dalam kegiatan latihan biasanya dipanggil dengan sebutan kiasan...",
			options: ["Kak", "Pak", "Yanda", "Abang"],
			correct: "Yanda",
			edu: "Pembina Siaga putra dipanggil 'Yanda' — kiasan dari 'Ayahanda' (ayah tercinta). Ini adalah bagian dari Kiasan Dasar Siaga yang menggunakan atmosfer keluarga: Pembina putra = Yanda (ayah), Pembina putri = Bunda (ibu), Pembantu Pembina putra = Ayah, Pembantu Pembina putri = Ibu. Penggunaan kiasan ini membuat anak-anak Siaga merasa nyaman seperti dalam lingkungan keluarga sendiri."
		},
		{
			kategori: "Satuan Siaga",
			q: "Pembina Pramuka Siaga putri biasanya dipanggil dengan sebutan kiasan...",
			options: ["Kak", "Bu", "Kakanda", "Bunda"],
			correct: "Bunda",
			edu: "Pembina Siaga putri dipanggil 'Bunda' — kiasan dari 'Ibunda' (ibu tercinta). Kiasan keluarga ini (Yanda/Bunda) sengaja dipilih untuk menciptakan suasana hangat dan akrab bagi anak-anak usia 7–10 tahun yang masih sangat dekat dengan lingkungan keluarga. Ini berbeda dari Pembina Penggalang/Penegak yang menggunakan sapaan 'Kakak'."
		},
		{
			kategori: "Satuan Siaga",
			q: "Batasan usia Pramuka Siaga berdasarkan ketentuan kepramukaan yang berlaku adalah...",
			options: ["5–7 tahun", "7–10 tahun", "10–12 tahun", "7–12 tahun"],
			correct: "7–10 tahun",
			edu: "Pramuka Siaga adalah peserta didik berusia 7–10 tahun. Batasan ini dirancang sesuai tahapan tumbuh kembang anak: (1) 7 tahun — anak mulai masuk sekolah dasar dan siap belajar dalam kelompok; (2) 10 tahun — batas atas Siaga sebelum naik ke Penggalang (11–15 tahun). UU No.12/2010 menyebut peserta didik berusia 7–25 tahun secara keseluruhan, sementara masing-masing jenjang memiliki batasan usia spesifik berdasarkan Jukran."
		},
		{
			kategori: "Satuan Siaga",
			q: "Seorang anak berusia 8 tahun mendaftar ke gugus depan. Berdasarkan usia, ia akan ditempatkan di satuan...",
			options: [
				"Perindukan Siaga — karena berusia 7–10 tahun",
				"Pasukan Penggalang — karena sudah sekolah dasar",
				"Ambalan Penegak — karena sudah remaja",
				"Boleh memilih satuan sendiri sesuai keinginan"
			],
			correct: "Perindukan Siaga — karena berusia 7–10 tahun",
			edu: "Anak berusia 8 tahun termasuk rentang usia Siaga (7–10 tahun), sehingga ditempatkan di Perindukan Siaga. Penempatan berdasarkan usia ini bukan sekadar administratif, melainkan pedagogis — program kepramukaan dirancang sesuai tahap perkembangan kognitif dan emosional anak. Bila anak berusia 8 tahun ingin mengikuti kegiatan Penggalang, ia perlu menunggu hingga berusia 11 tahun."
		},

		// ── SKU Siaga ────────────────────────────────────────────────────────────
		{
			kategori: "SKU Siaga",
			q: "Menurut Jukran PP SKU (SK 088/1974) Poin 5, SKU Pramuka Siaga terdiri atas berapa tingkat?",
			options: ["2 tingkat", "3 tingkat", "4 tingkat", "5 tingkat"],
			correct: "3 tingkat",
