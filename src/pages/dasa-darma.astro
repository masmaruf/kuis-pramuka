	// ─── Helpers ────────────────────────────────────────────────────────────────

	function getEl<T extends HTMLElement>(id: string) {
		return document.getElementById(id) as T | null;
	}

	function shuffle<T>(arr: T[]): T[] {
		const a = [...arr];
		for (let i = a.length - 1; i > 0; i--) {
			const j = Math.floor(Math.random() * (i + 1));
			[a[i], a[j]] = [a[j], a[i]];
		}
		return a;
	}

	// ─── State ──────────────────────────────────────────────────────────────────

	let questions: Question[] = [];
	let currentIndex = 0;
	let selectedAnswer = '';
	let score = 0;
	let totalXpEarned = 0;

	// ─── Init ───────────────────────────────────────────────────────────────────

	function startQuiz() {
		questions = shuffle(QUESTIONS_POOL).slice(0, QUESTIONS_PER_SESSION);
		currentIndex = 0;
		score = 0;
		totalXpEarned = 0;
		selectedAnswer = '';
		renderQuestion();
	}

	// ─── Render Soal ────────────────────────────────────────────────────────────

	function renderQuestion() {
		const q = questions[currentIndex];
		const num = currentIndex + 1;

		getEl('question-number')!.textContent = `Soal ${num} dari ${QUESTIONS_PER_SESSION}`;
		const pct = Math.round((num / QUESTIONS_PER_SESSION) * 100);
		getEl('progress-pct')!.textContent = `${pct}%`;
		(getEl('quiz-progress-bar') as HTMLElement).style.width = `${pct}%`;
		getEl('question-prompt')!.textContent = q.q;

		const catPill = getEl('question-category')?.querySelector('.cat-pill');
		if (catPill) catPill.textContent = `🌟 ${q.cat}`;

		const eduCard = getEl<HTMLDivElement>('education-card');
		if (eduCard) eduCard.style.display = 'none';

		const submitBtn = getEl<HTMLButtonElement>('btn-submit-answer');
		if (submitBtn) {
			submitBtn.disabled = true;
			submitBtn.textContent = 'Konfirmasi Jawaban';
			submitBtn.onclick = submitAnswer;
		}

		const hint = getEl('answer-hint');
		if (hint) { hint.textContent = 'Pilih salah satu jawaban di atas'; hint.className = 'answer-hint'; }

		selectedAnswer = '';
		renderOptions(q);
	}

	function renderOptions(q: Question) {
		const container = getEl<HTMLDivElement>('options-container');
		if (!container) return;
		const shuffled = shuffle(q.options);
		container.innerHTML = shuffled.map((opt, i) => `
			<button class="opt-btn" data-answer="${opt.replace(/"/g, '&quot;')}" style="animation-delay:${i * 0.07}s">
				<span class="opt-letter">${String.fromCharCode(65 + i)}</span>
				<span class="opt-text">${opt}</span>
			</button>`).join('');

		container.querySelectorAll('.opt-btn').forEach((btn, i) => {
			btn.addEventListener('click', () => {
				container.querySelectorAll('.opt-btn').forEach(b => b.classList.remove('is-selected'));
				btn.classList.add('is-selected');
				selectedAnswer = (btn as HTMLElement).dataset.answer || '';
				const submitBtn = getEl<HTMLButtonElement>('btn-submit-answer');
				if (submitBtn) submitBtn.disabled = false;
				const hint = getEl('answer-hint');
				if (hint) { hint.textContent = `Jawaban ${String.fromCharCode(65 + i)} dipilih — klik Konfirmasi untuk lanjut`; hint.className = 'answer-hint chosen'; }
			});
		});
	}

	// ─── Submit ─────────────────────────────────────────────────────────────────

	function submitAnswer() {
		const q = questions[currentIndex];
		const isCorrect = selectedAnswer === q.correct;
		if (isCorrect) { score++; totalXpEarned += XP_PER_CORRECT; }

		const container = getEl<HTMLDivElement>('options-container');
		container?.querySelectorAll('.opt-btn').forEach(btn => {
			const el = btn as HTMLElement;
			const ans = el.dataset.answer || '';
			el.classList.add('is-answered');
			el.classList.remove('is-selected');
			if (ans === q.correct)                          el.classList.add('is-correct');
			else if (ans === selectedAnswer && !isCorrect)  el.classList.add('is-incorrect');
			else                                            el.classList.add('is-dimmed');
		});

		const eduCard = getEl<HTMLDivElement>('education-card');
		const eduText = getEl('education-text');
		if (eduCard && eduText) {
			eduText.textContent = q.edu;
			eduCard.style.display = 'flex';
			eduCard.className = `education-card ${isCorrect ? 'correct' : 'incorrect'}`;
		}

		const hint = getEl('answer-hint');
		if (hint) {
			hint.textContent = isCorrect ? '✓ Jawaban benar!' : '✗ Jawaban salah — lihat penjelasan di bawah.';
			hint.className = `answer-hint ${isCorrect ? 'correct-hint' : 'wrong-hint'}`;
		}

		const submitBtn = getEl<HTMLButtonElement>('btn-submit-answer');
		if (submitBtn) {
			submitBtn.textContent = currentIndex < QUESTIONS_PER_SESSION - 1 ? 'Soal Berikutnya →' : 'Lihat Hasil';
			submitBtn.disabled = false;
			submitBtn.onclick = nextQuestion;
		}
	}

	function nextQuestion() {
		currentIndex++;
		if (currentIndex < QUESTIONS_PER_SESSION) {
			renderQuestion();
			const submitBtn = getEl<HTMLButtonElement>('btn-submit-answer');
			if (submitBtn) submitBtn.onclick = submitAnswer;
		} else {
			showResult();
		}
	}

	// ─── Hasil ──────────────────────────────────────────────────────────────────

	function showResult() {
		const pct = Math.round((score / QUESTIONS_PER_SESSION) * 100);

		const currentXp = parseInt(localStorage.getItem('scout_xp') || '0');
		localStorage.setItem('scout_xp', (currentXp + totalXpEarned).toString());

		const earnedBadges: string[] = JSON.parse(localStorage.getItem('scout_badges') || '[]');
		const newlyUnlocked: typeof BADGES_FOR_THIS_QUIZ = [];

		if (!earnedBadges.includes('dasa_novice')) {
			earnedBadges.push('dasa_novice');
			newlyUnlocked.push(BADGES_FOR_THIS_QUIZ[0]);
		}
		if (pct === 100 && !earnedBadges.includes('dasa_master')) {
			earnedBadges.push('dasa_master');
			newlyUnlocked.push(BADGES_FOR_THIS_QUIZ[1]);
		}
		localStorage.setItem('scout_badges', JSON.stringify(earnedBadges));

		getEl('result-emoji')!.textContent = pct === 100 ? '🏅' : pct >= 70 ? '🌟' : '📖';
		getEl('result-title')!.textContent  = pct === 100 ? 'Sempurna! Kamu Teladan Dharma!' : pct >= 70 ? 'Bagus! Kamu Memahami Nilai Pramuka' : 'Terus Belajar!';
		getEl('result-text')!.textContent   = `Kamu menjawab ${score} dari ${QUESTIONS_PER_SESSION} soal dengan benar (${pct}%). ${pct >= 80 ? 'Kamu memahami Dasadarma dan Trisatya dengan baik!' : 'Pelajari kembali 10 Dasadarma dan isi Trisatya.'}`;
		getEl('result-xp')!.textContent     = `+${totalXpEarned} XP`;
		getEl('result-score')!.textContent  = `${pct}/100`;
		getEl('result-correct')!.textContent= `${score}/${QUESTIONS_PER_SESSION}`;

		if (newlyUnlocked.length > 0) {
			const badgesCtr = getEl('unlocked-badges');
			const badgesList = getEl('badges-list-el');
			if (badgesCtr && badgesList) {
				badgesList.innerHTML = newlyUnlocked.map(b => `<div class="badge-item-result">${b.icon} <strong>${b.name}</strong></div>`).join('');
				badgesCtr.style.display = 'block';
			}
		}

		const overlay = getEl<HTMLDivElement>('result-overlay');
		if (overlay) overlay.style.display = 'flex';

		window.dispatchEvent(new Event('statsUpdated'));
	}

	getEl<HTMLButtonElement>('btn-submit-answer')?.addEventListener('click', submitAnswer);
	getEl<HTMLButtonElement>('btn-restart')?.addEventListener('click', () => {
		const overlay = getEl<HTMLDivElement>('result-overlay');
		if (overlay) overlay.style.display = 'none';
		startQuiz();
	});

	startQuiz();
</script>

