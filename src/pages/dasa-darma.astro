---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Kuis Dasa Darma & Trisatya Pramuka" description="Latihan Dasa Darma, Trisatya, Dwisatya, dan Dwidarma pramuka. Hafal dan pahami 10 Dasa Darma serta nilai-nilai luhur Gerakan Pramuka.">
	<div class="quiz-container">
		<header class="quiz-header glass-card">
			<a href="/" class="btn-back">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<line x1="19" y1="12" x2="5" y2="12"/>
					<polyline points="12 19 5 12 12 5"/>
				</svg>
				Kembali ke Dasbor
			</a>
			<div class="quiz-title-area">
				<h2>Kuis Dasa Darma &amp; Tri Satya</h2>
				<span class="quiz-difficulty medium">Nilai &amp; Janji Kepramukaan</span>
			</div>
		</header>

		<div class="quiz-layout">
			<!-- Main Quiz Card -->
			<div class="quiz-main-card glass-card">
				<!-- Progress Tracker -->
				<div class="progress-tracker">
					<div class="progress-label">
						<span id="question-number">Soal 1 dari 10</span>
						<span id="progress-pct" class="pct-label">10%</span>
					</div>
					<div class="progress-bar-outer">
						<div id="quiz-progress-bar" class="progress-bar-inner" style="width: 10%"></div>
					</div>
				</div>

				<div class="question-category" id="question-category">
					<span class="cat-pill">🌟 Dasa Darma &amp; Tri Satya</span>
				</div>

				<div class="question-text-area">
					<h3 id="question-prompt">Soal akan dimuat...</h3>
				</div>

				<div class="flex flex-col gap-2.5" id="options-container"></div>

				<div class="education-card" id="education-card" style="display: none;">
					<div class="edu-header">
						<span class="edu-icon">💡</span>
						<span class="edu-label">Penjelasan</span>
					</div>
					<p id="education-text"></p>
				</div>

				<div class="action-footer">
					<span id="answer-hint" class="answer-hint">Pilih salah satu jawaban di atas</span>
					<button id="btn-submit-answer" class="btn btn-gold" disabled>Konfirmasi Jawaban</button>
				</div>
			</div>

			<!-- Reference Sidebar -->
			<div class="quiz-help-card glass-card">
				<h3>10 Dasa Darma</h3>
				<p class="help-subtitle">Pedoman moral &amp; perilaku Pramuka</p>
				<ol class="darma-list">
					<li>Takwa kepada Tuhan Yang Maha Esa</li>
					<li>Cinta alam dan kasih sayang sesama manusia</li>
					<li>Patriot yang sopan dan kesatria</li>
					<li>Patuh dan suka bermusyawarah</li>
					<li>Rela menolong dan tabah</li>
					<li>Rajin, terampil, dan gembira</li>
					<li>Hemat, cermat, dan bersahaja</li>
					<li>Disiplin, berani, dan setia</li>
					<li>Bertanggung jawab dan dapat dipercaya</li>
					<li>Suci dalam pikiran, perkataan, dan perbuatan</li>
				</ol>

				<div class="help-divider"></div>

				<h3>Tri Satya</h3>
				<p class="help-subtitle">Janji Penggalang · Penegak · Pandega</p>
				<div class="trisatya-text">
					<p><em>Demi kehormatanku aku berjanji akan bersungguh-sungguh:</em></p>
					<ol>
						<li>Menjalankan kewajibanku terhadap Tuhan YME, NKRI, dan mengamalkan Pancasila;</li>
						<li>Menolong sesama hidup dan mempersiapkan diri membangun masyarakat;</li>
						<li>Menepati Dasadarma.</li>
					</ol>
				</div>

				<div class="help-divider"></div>

				<h3>Dwi Satya &amp; Dwi Darma</h3>
				<p class="help-subtitle">Khusus golongan Siaga (7–10 tahun)</p>
				<div class="trisatya-text">
					<p><strong>Dwisatya</strong> — 2 ikrar janji Siaga</p>
					<p><strong>Dwidarma</strong> — 2 darma:</p>
					<ol>
						<li>Siaga berbakti kepada ayah dan bundanya</li>
						<li>Siaga berani dan tidak putus asa</li>
					</ol>
				</div>
			</div>
		</div>

		<!-- Result Overlay -->
		<div class="result-overlay" id="result-overlay" style="display: none;">
			<div class="result-card glass-card">
				<div class="result-emoji" id="result-emoji">🏆</div>
				<h2 id="result-title">Kuis Selesai!</h2>
				<p class="result-summary" id="result-text">Anda menjawab soal dengan baik.</p>
				<div class="result-stats-details">
					<div class="detail-item">
						<span class="label">XP Diperoleh</span>
						<span class="value score-xp" id="result-xp">+0 XP</span>
					</div>
					<div class="detail-item">
						<span class="label">Skor Akhir</span>
						<span class="value" id="result-score">0/100</span>
					</div>
					<div class="detail-item">
						<span class="label">Jawaban Benar</span>
						<span class="value" id="result-correct">0/10</span>
					</div>
				</div>
				<div class="unlocked-badges-container" id="unlocked-badges" style="display: none;">
					<h3>🎖️ Lencana Baru Terbuka!</h3>
					<div class="unlocked-badges-list" id="badges-list-el"></div>
				</div>
				<div class="result-actions">
					<button id="btn-restart" class="btn btn-primary">Ulangi Kuis</button>
					<a href="/" class="btn btn-gold">Kembali ke Dasbor</a>
				</div>
			</div>
		</div>
	</div>
</Layout>

