<script>
	const BADGE_LIST = [
		{ id: 'morse_novice',       name: 'Kadet Morse',       desc: 'Selesaikan 1 kuis Morse',                icon: '⚡' },
		{ id: 'morse_master',       name: 'Master Morse',       desc: 'Skor 100% pada kuis Morse',              icon: '🚀' },
		{ id: 'semaphore_novice',   name: 'Isyarat Angin',     desc: 'Selesaikan 1 kuis Semaphore',            icon: '🚩' },
		{ id: 'sandi_breaker',      name: 'Pecah Sandi',       desc: 'Selesaikan 1 kuis Sandi',                icon: '🔑' },
		{ id: 'sku_siaga',          name: 'Pandu Mula',        desc: 'Selesaikan kuis SKU Siaga',              icon: '🟢' },
		{ id: 'sku_penggalang',     name: 'Pandu Ramu',        desc: 'Selesaikan kuis SKU Penggalang',         icon: '🔴' },
		{ id: 'sku_penegak',        name: 'Pandu Bantara',     desc: 'Selesaikan kuis SKU Penegak',            icon: '🟡' },
		{ id: 'scout_master',       name: 'Pengembara Ulung',  desc: 'Capai total 500 XP',                     icon: '⚜️' },
		{ id: 'uu_pramuka_novice',  name: 'Pandu Hukum',       desc: 'Selesaikan 1 kuis UU No. 12/2010',       icon: '⚖️' },
		{ id: 'uu_pramuka_master',  name: 'Ahli Perundangan',  desc: 'Skor 100% pada kuis UU Pramuka',         icon: '📜' },
		{ id: 'simpul_novice',      name: 'Pengikat Muda',     desc: 'Selesaikan 1 kuis Simpul & Ikatan',      icon: '🪢' },
		{ id: 'simpul_master',      name: 'Ahli Tali Temali',  desc: 'Skor 100% pada kuis Simpul & Ikatan',    icon: '🏅' },
		{ id: 'sejarah_novice',     name: 'Penjelajah Sejarah',desc: 'Selesaikan 1 kuis Sejarah Kepramukaan',  icon: '📜' },
		{ id: 'sejarah_master',     name: 'Sejarawan Pramuka', desc: 'Skor 100% pada kuis Sejarah',            icon: '🏛️' },
		{ id: 'p3k_novice',         name: 'Penolong Pertama',  desc: 'Selesaikan 1 kuis P3K',                  icon: '🩺' },
		{ id: 'p3k_master',         name: 'Ahli P3K',          desc: 'Skor 100% pada kuis P3K',                icon: '❤️‍🩹' },
		{ id: 'kompas_novice',      name: 'Penjelajah Muda',   desc: 'Selesaikan 1 kuis Kompas & Navigasi',    icon: '🧭' },
		{ id: 'kompas_master',      name: 'Navigator Handal',  desc: 'Skor 100% pada kuis Kompas & Navigasi',  icon: '🗺️' },
		{ id: 'pbb_novice',         name: 'Pandu Berbaris',    desc: 'Selesaikan 1 kuis Baris-Berbaris (PBB)', icon: '🪖' },
		{ id: 'pbb_master',         name: 'Komandan Barisan',  desc: 'Skor 100% pada kuis Baris-Berbaris',     icon: '🎖️' },
		{ id: 'kemah_novice',       name: 'Pendaki Muda',      desc: 'Selesaikan 1 kuis Perkemahan',           icon: '⛺' },
		{ id: 'kemah_master',       name: 'Ahli Perkemahan',   desc: 'Skor 100% pada kuis Perkemahan',         icon: '🏕️' },
		{ id: 'tanda_novice',       name: 'Pandu Berpengenal', desc: 'Selesaikan 1 kuis Tanda Pengenal',       icon: '🎗️' },
		{ id: 'tanda_master',       name: 'Ahli Tanda Pengenal',desc:'Skor 100% pada kuis Tanda Pengenal',    icon: '🏵️' },
		{ id: 'pionir_novice',      name: 'Pionir Muda',       desc: 'Selesaikan 1 kuis Pioniring',            icon: '🪵' },
		{ id: 'pionir_master',      name: 'Ahli Pioniring',    desc: 'Skor 100% pada kuis Pioniring',          icon: '🏗️' },
		{ id: 'org_novice',         name: 'Pandu Organisasi',  desc: 'Selesaikan 1 kuis Organisasi Pramuka',   icon: '🏛️' },
		{ id: 'org_master',         name: 'Ahli Keorganisasian',desc:'Skor 100% pada kuis Organisasi Pramuka', icon: '📋' },
		{ id: 'dasa_novice',        name: 'Pramuka Berakhlak',  desc: 'Selesaikan 1 kuis Dasa Darma',          icon: '🌟' },
		{ id: 'dasa_master',        name: 'Teladan Dharma',     desc: 'Skor 100% pada kuis Dasa Darma',        icon: '🏅' },
		{ id: 'survival_novice',    name: 'Survivor Muda',      desc: 'Selesaikan 1 kuis Survival',            icon: '🏕️' },
		{ id: 'survival_master',    name: 'Ahli Survival',      desc: 'Skor 100% pada kuis Survival',          icon: '🌿' },
		{ id: 'siaga_novice',       name: 'Pandu Siaga',        desc: 'Selesaikan 1 kuis Pramuka Siaga',       icon: '🟢' },
		{ id: 'siaga_master',       name: 'Ahli Siaga',         desc: 'Skor 100% pada kuis Pramuka Siaga',     icon: '⭐' },
	];

	const RANK_NAMES: Record<number, string> = {
		1: 'Pandu Mula',
		2: 'Pandu Ramu',
		3: 'Pandu Rakit',
		4: 'Pandu Penegak',
	};

	function calcLevel(xp: number) {
		if (xp >= 1000) {
			const lvl = 5 + Math.floor((xp - 1000) / 500);
			return { level: lvl, rankTitle: `Pandu Laksana (Lv. ${lvl})` };
		}
		if (xp >= 600) return { level: 4, rankTitle: RANK_NAMES[4] };
		if (xp >= 300) return { level: 3, rankTitle: RANK_NAMES[3] };
		if (xp >= 100) return { level: 2, rankTitle: RANK_NAMES[2] };
		return { level: 1, rankTitle: RANK_NAMES[1] };
	}

	function updateHeroGreeting() {
		const username = localStorage.getItem('scout_username');
		const heading = document.getElementById('hero-heading');
		if (heading && username) {
			heading.textContent = `Selamat datang kembali, Kak ${username}! 👋`;
		}
	}

	function renderDashboard() {
		const xp = parseInt(localStorage.getItem('scout_xp') || '0');
		const badges: string[] = JSON.parse(localStorage.getItem('scout_badges') || '[]');
		const { level, rankTitle } = calcLevel(xp);

		const xpEl = document.getElementById('stats-xp-val');
		const lvlEl = document.getElementById('stats-level-val');
		const rankEl = document.getElementById('stats-rank-title');
		const badgesEl = document.getElementById('stats-badges-val');

		if (xpEl) xpEl.textContent = `${xp} XP`;
		if (lvlEl) lvlEl.textContent = `Level ${level}`;
		if (rankEl) rankEl.textContent = rankTitle;
		if (badgesEl) badgesEl.textContent = `${badges.length} / ${BADGE_LIST.length}`;

		renderBadges(badges);
		updateHeroGreeting();
	}

	const FEATURED_BADGE_IDS = ['scout_master','morse_novice','p3k_master','kompas_master','simpul_master','pionir_master'];

	function renderBadges(unlocked: string[]) {
		const grid = document.getElementById('badges-grid');
		const countEl = document.getElementById('badges-count-text');
		if (!grid) return;

		if (countEl) countEl.textContent = `${unlocked.length} / ${BADGE_LIST.length}`;

		const featured = BADGE_LIST.filter(b => FEATURED_BADGE_IDS.includes(b.id));
		grid.innerHTML = featured.map(badge => {
			const isUnlocked = unlocked.includes(badge.id);
			return `
				<div class="badge-item ${isUnlocked ? 'unlocked' : 'locked'}">
					<div class="badge-icon-wrap">${badge.icon}</div>
					<div class="badge-info">
						<h4>${badge.name}</h4>
						<p>${badge.desc}</p>
					</div>
					<span class="badge-status">${isUnlocked ? 'Terbuka' : 'Terkunci'}</span>
				</div>
			`;
		}).join('');
	}

	// Reset button
	document.getElementById('btn-reset-data')?.addEventListener('click', () => {
		if (confirm('Hapus semua kemajuan kuis, XP, dan lencana? Tindakan ini tidak dapat dibatalkan.')) {
			localStorage.setItem('scout_xp', '0');
			localStorage.setItem('scout_badges', '[]');
			window.dispatchEvent(new Event('statsUpdated'));
			renderDashboard();
		}
	});

	renderDashboard();
	window.addEventListener('statsUpdated', renderDashboard);
</script>

