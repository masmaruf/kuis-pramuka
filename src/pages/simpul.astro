---
import Layout from '../layouts/Layout.astro';
import SimpulQuiz from '../components/SimpulQuiz.astro';
---

<Layout title="Kuis Simpul & Ikatan Pramuka" description="Latihan tali-temali pramuka: simpul mati, anyam, tiang, pangkal, delapan, ikatan segi empat, silang, dan kaki tiga. 30 soal acak per sesi.">
	<SimpulQuiz quizId="simpul" totalQuestions={10} />
		<header class="quiz-header glass-card">
			<a href="/" class="btn-back">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<line x1="19" y1="12" x2="5" y2="12"/>
					<polyline points="12 19 5 12 12 5"/>
				</svg>
				Kembali ke Dasbor
			</a>
			<div class="quiz-title-area">
				<h2>Kuis Simpul &amp; Ikatan</h2>
				<span class="quiz-difficulty medium">Keterampilan Tali Temali</span>
			</div>
		</header>

		<div class="quiz-layout">
			<!-- Main Quiz Card -->
			<div class="quiz-main-card glass-card">
				<!-- Progress Tracker -->
				<div class="progress-tracker">
					<div class="progress-label">
						<span id="question-number">Soal 1 dari 10</span>
						<span id="progress-pct" class="pct-label">10%</span>
					</div>
					<div class="progress-bar-outer">
						<div id="quiz-progress-bar" class="progress-bar-inner" style="width: 10%"></div>
					</div>
				</div>

				<!-- Category Badge -->
				<div class="question-category" id="question-category">
					<span class="cat-pill">🪢 Tali Temali Pramuka</span>
				</div>

				<!-- Question Image (optional) -->
				<div class="question-image-area" id="question-image-area" style="display:none;">
					<img id="question-image" src="" alt="Gambar simpul/ikatan" loading="lazy" />
					<p class="image-caption" id="image-caption"></p>
				</div>

				<!-- Question -->
				<div class="question-text-area">
					<h3 id="question-prompt">Soal akan dimuat...</h3>
				</div>

				<!-- Options -->
				<div class="flex flex-col gap-2.5" id="options-container">
					<!-- dibuat oleh JavaScript -->
				</div>

				<!-- Education Card -->
				<div class="education-card" id="education-card" style="display: none;">
					<div class="edu-header">
						<span class="edu-icon">📖</span>
						<span class="edu-label">Penjelasan</span>
					</div>
					<p id="education-text"></p>
				</div>

				<!-- Actions -->
				<div class="action-footer">
					<span id="answer-hint" class="answer-hint">Pilih salah satu jawaban di atas</span>
					<button id="btn-submit-answer" class="btn btn-gold" disabled>Konfirmasi Jawaban</button>
				</div>
			</div>

			<!-- Reference Sidebar -->
			<div class="quiz-help-card glass-card">
				<h3>Simpul &amp; Ikatan Dasar</h3>
				<p class="help-subtitle">Tali temali wajib dalam Gerakan Pramuka Indonesia</p>

				<div class="knot-list">
					<div class="knot-section-title">Simpul (Knots)</div>
					<div class="knot-item">
						<span class="knot-name">Simpul Mati</span>
						<span class="knot-use">Menyambung 2 tali sama besar</span>
					</div>
					<div class="knot-item">
						<span class="knot-name">Simpul Hidup</span>
						<span class="knot-use">Mudah dibuka, bersifat sementara</span>
					</div>
					<div class="knot-item">
						<span class="knot-name">Simpul Tiang</span>
						<span class="knot-use">Lingkaran tetap, tidak mencekik</span>
					</div>
					<div class="knot-item">
						<span class="knot-name">Simpul Pangkal</span>
						<span class="knot-use">Memulai / mengakhiri ikatan</span>
					</div>
					<div class="knot-item">
						<span class="knot-name">Simpul Anyam</span>
						<span class="knot-use">Menyambung 2 tali beda ukuran</span>
					</div>
					<div class="knot-item">
						<span class="knot-name">Simpul Anyam Berganda</span>
						<span class="knot-use">Tali sangat berbeda ukuran</span>
					</div>
					<div class="knot-item">
						<span class="knot-name">Simpul Delapan</span>
						<span class="knot-use">Stopper, mencegah tali lepas</span>
					</div>
					<div class="knot-item">
						<span class="knot-name">Simpul Kembar</span>
						<span class="knot-use">Menyambung tali licin / nilon</span>
					</div>
					<div class="knot-section-title" style="margin-top:.75rem">Ikatan (Lashings)</div>
					<div class="knot-item">
						<span class="knot-name">Ikatan Segi Empat</span>
						<span class="knot-use">Membuat sudut 90° antar tongkat</span>
					</div>
					<div class="knot-item">
						<span class="knot-name">Ikatan Silang</span>
						<span class="knot-use">Memperkuat ikatan bersilang</span>
					</div>
					<div class="knot-item">
						<span class="knot-name">Ikatan Kaki Tiga</span>
						<span class="knot-use">Membuat tripod / kaki tiga</span>
					</div>
				</div>

				<div class="knot-fact-box">
					<div class="fact-row">
						<span class="fact-key">Nama internasional</span>
						<span class="fact-val">Knot, Hitch, Lashing</span>
					</div>
					<div class="fact-row">
						<span class="fact-key">Pangkal = Clove hitch</span>
						<span class="fact-val">Memulai ikatan</span>
					</div>
					<div class="fact-row">
						<span class="fact-key">Lilitan pengikat</span>
						<span class="fact-val">Frapping turns</span>
					</div>
					<div class="fact-row">
						<span class="fact-key">Ujung aktif</span>
						<span class="fact-val">Working end</span>
					</div>
				</div>
			</div>
		</div>

		<!-- Result Overlay -->
		<div class="result-overlay" id="result-overlay" style="display: none;">
			<div class="result-card glass-card">
				<div class="result-emoji" id="result-emoji">🏆</div>
				<h2 id="result-title">Kuis Selesai!</h2>
				<p class="result-summary" id="result-text">Anda menjawab soal dengan baik.</p>

				<div class="result-stats-details">
					<div class="detail-item">
						<span class="label">XP Diperoleh</span>
						<span class="value score-xp" id="result-xp">+100 XP</span>
					</div>
					<div class="detail-item">
						<span class="label">Skor Akhir</span>
						<span class="value" id="result-score">100/100</span>
					</div>
					<div class="detail-item">
						<span class="label">Jawaban Benar</span>
						<span class="value" id="result-correct">10/10</span>
					</div>
				</div>

				<div class="unlocked-badges-container" id="unlocked-badges" style="display: none;">
					<h3>🎖️ Lencana Baru Terbuka!</h3>
					<div class="unlocked-badges-list" id="badges-list-el"></div>
				</div>

				<div class="result-actions">
					<button id="btn-restart" class="btn btn-primary">Ulangi Kuis</button>
					<a href="/" class="btn btn-gold">Kembali ke Dasbor</a>
				</div>
			</div>
		</div>
	</div>
</Layout>

<script>
	// ─── Bank Soal Simpul & Ikatan (30 soal, pilih 10 acak per sesi) ─────────

	interface Question {
		kategori: string;
		q: string;
		options: string[];
		correct: string;
		edu: string;
		img?: string;
		imgCaption?: string;
	}

	const QUESTIONS_POOL: Question[] = [
		// ── Simpul Mati ─────────────────────────────────────────────────────────
		{
			kategori: "Simpul Mati",
			q: "Simpul Mati digunakan untuk...",
			options: [
				"Menyambung dua tali yang berbeda ukurannya",
				"Menyambung dua tali yang sama ukurannya",
				"Membuat lingkaran tetap di ujung tali",
				"Mengakhiri sebuah ikatan pada tongkat"
			],
			correct: "Menyambung dua tali yang sama ukurannya",
			edu: "Simpul Mati (Reef Knot / Square Knot) adalah simpul untuk menyambung dua tali yang sama ukuran dan bahannya. Ciri khasnya: ujung-ujung tali keluar sejajar di kedua sisi. Jika tidak sejajar, maka simpul tersebut menjadi Simpul Hidup yang mudah lepas.",
			img: "https://upload.wikimedia.org/wikipedia/commons/8/84/Reef_knot.svg",
			imgCaption: "Simpul Mati (Reef Knot)"
		},
		{
			kategori: "Simpul Mati",
			q: "Perhatikan gambar berikut. Simpul apa yang terlihat pada gambar?",
			options: [
				"Simpul Mati (Reef Knot)",
				"Simpul Hidup (Granny Knot)",
				"Simpul Anyam (Sheet Bend)",
				"Simpul Kembar (Double Fisherman's)"
			],
			correct: "Simpul Mati (Reef Knot)",
			edu: "Gambar menunjukkan Simpul Mati (Reef Knot). Ciri khasnya: kedua ujung tali (working end) keluar sejajar dan searah dengan tali utamanya di kedua sisi simpul. Simpul ini simetris dan kuat untuk menyambung dua tali dengan diameter sama.",
			img: "https://upload.wikimedia.org/wikipedia/commons/8/84/Reef_knot.svg",
			imgCaption: "Identifikasi simpul ini"
		},
		{
			kategori: "Simpul Hidup",
			q: "Simpul Hidup (Granny Knot) berbeda dari Simpul Mati karena...",
			options: [
				"Simpul Hidup lebih kuat dan tidak mudah lepas",
				"Ujung tali pada Simpul Hidup tidak sejajar, sehingga mudah lepas saat ditarik",
				"Simpul Hidup digunakan untuk tali yang berbeda ukuran",
				"Simpul Hidup hanya boleh digunakan untuk tali nilon"
			],
			correct: "Ujung tali pada Simpul Hidup tidak sejajar, sehingga mudah lepas saat ditarik",
			edu: "Simpul Hidup (Granny Knot) terbentuk ketika kedua putaran tali dibuat searah (bukan berlawanan arah). Akibatnya ujung tali tidak sejajar dan simpul mudah tergelincir saat diberi beban. Untuk mengenali: jika ujung tali menyilang, itu Simpul Hidup; jika sejajar, itu Simpul Mati."
		},
		// ── Simpul Tiang ────────────────────────────────────────────────────────
		{
			kategori: "Simpul Tiang",
			q: "Simpul Tiang (Bowline) paling tepat digunakan untuk...",
			options: [
				"Menyambung dua tali yang berbeda ukuran",
				"Membuat lingkaran tetap yang tidak mencekik di ujung tali",
				"Memulai sebuah ikatan pada tongkat",
				"Mencegah ujung tali berburai"
			],
			correct: "Membuat lingkaran tetap yang tidak mencekik di ujung tali",
			edu: "Simpul Tiang (Bowline) menghasilkan lingkaran (loop) tetap di ujung tali yang tidak akan mengencang atau mencekik saat dibebani. Keunggulannya: ukuran lingkaran tidak berubah saat ditarik. Simpul ini banyak digunakan dalam operasi penyelamatan dan mendaki.",
			img: "https://upload.wikimedia.org/wikipedia/commons/7/77/Bowline.svg",
			imgCaption: "Simpul Tiang (Bowline)"
		},
		{
			kategori: "Simpul Tiang",
			q: "Perhatikan gambar simpul berikut. Simpul ini sering dipakai dalam kegiatan penyelamatan karena...",
			options: [
				"Mudah dibuat dan mudah dibuka walaupun dalam kondisi basah dan tegang",
				"Ukuran lingkarannya mengecil saat dibebani sehingga mencengkeram kuat",
				"Hanya membutuhkan satu tali untuk membuatnya",
				"Bisa digunakan untuk menyambung dua tali yang berbeda diameter"
			],
			correct: "Mudah dibuat dan mudah dibuka walaupun dalam kondisi basah dan tegang",
			edu: "Simpul Tiang (Bowline) digunakan dalam penyelamatan karena membentuk lingkaran yang tidak mencekik dan relatif mudah dibuka kembali meskipun sudah diberi beban besar. Inilah yang membedakannya dari simpul laso atau slip knot yang justru mengencang.",
			img: "https://upload.wikimedia.org/wikipedia/commons/7/77/Bowline.svg",
			imgCaption: "Simpul untuk penyelamatan"
		},
		// ── Simpul Pangkal ──────────────────────────────────────────────────────
		{
			kategori: "Simpul Pangkal",
			q: "Simpul Pangkal (Clove Hitch) paling sering digunakan untuk...",
			options: [
				"Menyambung dua tali yang putus",
				"Memulai dan mengakhiri ikatan pada tongkat atau tiang",
				"Membuat simpul darurat tanpa alat bantu",
				"Menyambung tali pada benda bergerak"
			],
			correct: "Memulai dan mengakhiri ikatan pada tongkat atau tiang",
			edu: "Simpul Pangkal (Clove Hitch) adalah simpul yang digunakan untuk memulai dan mengakhiri ikatan pada sebuah tongkat, tiang, atau spar. Saat dibuat dengan benar, tekanan tali pada tongkat mengunci simpul ini dengan kuat. Hampir semua ikatan (lashing) dimulai dan diakhiri dengan Simpul Pangkal.",
			img: "https://upload.wikimedia.org/wikipedia/commons/a/a4/Webeleinenstek3.svg",
			imgCaption: "Simpul Pangkal (Clove Hitch)"
		},
		{
			kategori: "Simpul Pangkal",
			q: "Gambar berikut menunjukkan simpul yang digunakan saat memulai ikatan segi empat. Simpul apakah ini?",
			options: [
				"Simpul Tiang",
				"Simpul Mati",
				"Simpul Pangkal (Clove Hitch)",
				"Simpul Anyam"
			],
			correct: "Simpul Pangkal (Clove Hitch)",
			edu: "Gambar menunjukkan Simpul Pangkal (Clove Hitch), yang selalu digunakan sebagai simpul awal dan akhir dalam semua jenis ikatan pramuka. Cirinya: dua putaran tali yang saling mengunci pada sebuah tongkat, dengan masing-masing putaran berjalan di bawah yang sebelumnya.",
			img: "https://upload.wikimedia.org/wikipedia/commons/a/a4/Webeleinenstek3.svg",
			imgCaption: "Simpul awal/akhir ikatan"
		},
		// ── Simpul Anyam ────────────────────────────────────────────────────────
		{
			kategori: "Simpul Anyam",
			q: "Kapan Simpul Anyam (Sheet Bend) digunakan?",
			options: [
				"Untuk membuat tiang bendera yang kuat",
				"Untuk menyambung dua tali yang berbeda ukuran atau bahan",
				"Untuk mengikat perahu ke dermaga",
				"Untuk membuat simpul di tengah tali"
			],
			correct: "Untuk menyambung dua tali yang berbeda ukuran atau bahan",
			edu: "Simpul Anyam (Sheet Bend) digunakan untuk menyambung dua tali yang berbeda ukuran (diameter) atau berbeda bahan. Simpul Anyam Berganda (Double Sheet Bend) digunakan jika perbedaan ukuran tali sangat besar. Ini adalah solusi terbaik saat Simpul Mati tidak bisa dipakai karena ukuran tali berbeda.",
			img: "https://upload.wikimedia.org/wikipedia/commons/4/42/Sheet_bend.svg",
			imgCaption: "Simpul Anyam (Sheet Bend)"
		},
		{
			kategori: "Simpul Anyam",
			q: "Pada gambar, terlihat simpul yang menghubungkan dua tali berbeda ketebalan. Simpul apakah ini?",
			options: [
				"Simpul Kembar",
				"Simpul Mati",
				"Simpul Anyam (Sheet Bend)",
				"Simpul Pangkal"
			],
			correct: "Simpul Anyam (Sheet Bend)",
			edu: "Simpul Anyam (Sheet Bend) dapat dikenali dari cara tali yang lebih tipis melingkar melalui dan di sekitar lingkaran yang dibuat oleh tali yang lebih tebal. Tali tipis menembus dari bawah lingkaran, melilit luarnya, kemudian masuk di bawah dirinya sendiri.",
			img: "https://upload.wikimedia.org/wikipedia/commons/4/42/Sheet_bend.svg",
			imgCaption: "Menyambung tali beda ukuran"
		},
		// ── Simpul Delapan ──────────────────────────────────────────────────────
		{
			kategori: "Simpul Delapan",
			q: "Simpul Delapan (Figure-Eight Knot) termasuk kategori simpul...",
			options: [
				"Simpul sambung — untuk menyambung dua tali",
				"Simpul stopper — mencegah ujung tali melolos dari lubang atau blok",
				"Simpul ikatan — untuk mengikat pada tiang",
				"Simpul penyelamat — untuk operasi rescue"
			],
			correct: "Simpul stopper — mencegah ujung tali melolos dari lubang atau blok",
			edu: "Simpul Delapan (Figure-Eight Knot) adalah simpul stopper. Fungsinya mencegah ujung tali melolos melewati lubang pada katrol, blok, atau lubang lainnya. Simpul ini lebih besar dan lebih mudah dibuka dibanding Simpul Setengah Mati, sehingga lebih disukai dalam panjat tebing dan kepramukaan.",
			img: "https://upload.wikimedia.org/wikipedia/commons/d/db/Figure-eight_knot.svg",
			imgCaption: "Simpul Delapan (Figure-Eight)"
		},
		{
			kategori: "Simpul Delapan",
			q: "Gambar menunjukkan simpul yang berbentuk seperti angka 8. Apa nama dan fungsi utamanya?",
			options: [
				"Simpul Mati — menyambung dua tali sama besar",
				"Simpul Pangkal — memulai ikatan",
				"Simpul Delapan — stopper untuk mencegah tali melolos",
				"Simpul Kembar — menyambung tali nilon"
			],
			correct: "Simpul Delapan — stopper untuk mencegah tali melolos",
			edu: "Simpul Delapan (Figure-Eight Knot) dinamai demikian karena bila dilihat dari samping membentuk pola angka 8. Sebagai simpul stopper, ia lebih andal dari simpul setengah mati biasa karena lebih besar dan lebih mudah dibuka setelah dibebani.",
			img: "https://upload.wikimedia.org/wikipedia/commons/d/db/Figure-eight_knot.svg",
			imgCaption: "Identifikasi simpul ini"
		},
		// ── Simpul Kembar ───────────────────────────────────────────────────────
		{
			kategori: "Simpul Kembar",
			q: "Simpul Kembar (Double Fisherman's Knot) paling cocok digunakan untuk menyambung...",
			options: [
				"Dua tali manila yang besar dan kaku",
				"Dua tali nilon atau tali licin yang sulit diikat",
				"Dua tali yang sangat berbeda ukurannya",
				"Tali pada tiang atau pohon besar"
			],
			correct: "Dua tali nilon atau tali licin yang sulit diikat",
			edu: "Simpul Kembar (Double Fisherman's Knot / Barrel Knot) dirancang khusus untuk menyambung tali yang licin seperti nilon, benang pancing, atau tali sintetis yang mudah terurai jika diikat dengan simpul biasa. Simpul ini sangat kuat dan hampir tidak bisa dibuka setelah dibebani berat."
		},
		// ── Ikatan Segi Empat ───────────────────────────────────────────────────
		{
			kategori: "Ikatan Segi Empat",
			q: "Ikatan Segi Empat (Square Lashing) digunakan untuk...",
			options: [
				"Membuat dua tongkat bersilang dengan sudut sembarang",
				"Mengikat dua tongkat yang membentuk sudut siku-siku (90°)",
				"Menyambung dua tongkat yang sejajar secara memanjang",
				"Membuat tripod dengan tiga tongkat"
			],
			correct: "Mengikat dua tongkat yang membentuk sudut siku-siku (90°)",
			edu: "Ikatan Segi Empat (Square Lashing) digunakan untuk mengikat dua tongkat yang membentuk sudut 90° (siku-siku) satu sama lain. Ikatan ini terdiri dari: (1) Simpul Pangkal sebagai awal, (2) putaran (wrapping turns) melilit kedua tongkat secara bergantian, (3) lilitan pengikat (frapping turns) di antara tongkat, dan (4) Simpul Pangkal sebagai penutup.",
			img: "https://upload.wikimedia.org/wikipedia/commons/5/59/Lashing_square.jpg",
			imgCaption: "Ikatan Segi Empat (Square Lashing)"
		},
		{
			kategori: "Ikatan Segi Empat",
			q: "Gambar menunjukkan ikatan pada dua tongkat yang bersudut 90°. Ini adalah...",
			options: [
				"Ikatan Silang (Diagonal Lashing)",
				"Ikatan Kaki Tiga (Shear Lashing)",
				"Ikatan Segi Empat (Square Lashing)",
				"Ikatan Palang"
			],
			correct: "Ikatan Segi Empat (Square Lashing)",
			edu: "Gambar menunjukkan Ikatan Segi Empat (Square Lashing). Ciri khasnya: dimulai dengan Simpul Pangkal, dilanjutkan putaran melilit kedua sisi tongkat secara bergantian, kemudian frapping turns di antara kedua tongkat, dan ditutup dengan Simpul Pangkal. Digunakan untuk membuat konstruksi berbentuk bingkai atau jembatan sederhana.",
			img: "https://upload.wikimedia.org/wikipedia/commons/5/59/Lashing_square.jpg",
			imgCaption: "Identifikasi ikatan ini"
		},
		// ── Ikatan Silang ───────────────────────────────────────────────────────
		{
			kategori: "Ikatan Silang",
			q: "Ikatan Silang (Diagonal Lashing) paling tepat digunakan pada situasi berikut, yaitu...",
			options: [
				"Dua tongkat bersilang sudut siku-siku yang perlu dikuatkan secara diagonal",
				"Dua tongkat yang sejajar dan perlu disambung memanjang",
				"Tiga tongkat yang perlu dijadikan tripod",
				"Dua tongkat yang bersilang tetapi awalnya saling berjauhan dan tidak bersentuhan"
			],
			correct: "Dua tongkat yang bersilang tetapi awalnya saling berjauhan dan tidak bersentuhan",
			edu: "Ikatan Silang (Diagonal Lashing) dimulai dengan Simpul Tiang (bukan Simpul Pangkal), lalu putaran awal mendekatkan dan mengikat kedua tongkat, dilanjutkan putaran kedua arah diagonal, dan frapping turns. Digunakan saat dua tongkat bersilang tetapi tidak bersentuhan karena ada jarak, sehingga perlu ditarik bersamaan dahulu.",
			img: "https://upload.wikimedia.org/wikipedia/commons/7/75/Lashing_diagonal.jpg",
			imgCaption: "Ikatan Silang (Diagonal Lashing)"
		},
		{
			kategori: "Ikatan Silang",
			q: "Apa perbedaan utama antara Ikatan Segi Empat dan Ikatan Silang?",
			options: [
				"Ikatan Segi Empat lebih kuat dari Ikatan Silang dalam segala kondisi",
