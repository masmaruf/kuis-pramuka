---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Kuis Survival & Teknik Bertahan Pramuka" description="Latihan survival pramuka: akronim STOP dan SURVIVAL, bivak, air, makanan, api, gangguan binatang, dan survival kit. 30 soal acak per sesi.">
	<div class="quiz-container">
		<header class="quiz-header glass-card">
			<a href="/" class="btn-back">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<line x1="19" y1="12" x2="5" y2="12"/>
					<polyline points="12 19 5 12 12 5"/>
				</svg>
				Kembali ke Dasbor
			</a>
			<div class="quiz-title-area">
				<h2>Kuis Survival &amp; Teknik Bertahan</h2>
				<span class="quiz-difficulty hard">Teknik Bertahan Hidup</span>
			</div>
		</header>

		<div class="quiz-layout">
			<!-- Main Quiz Card -->
			<div class="quiz-main-card glass-card">
				<!-- Progress Tracker -->
				<div class="progress-tracker">
					<div class="progress-label">
						<span id="question-number">Soal 1 dari 10</span>
						<span id="progress-pct" class="pct-label">10%</span>
					</div>
					<div class="progress-bar-outer">
						<div id="quiz-progress-bar" class="progress-bar-inner" style="width: 10%"></div>
					</div>
				</div>

				<div class="question-category" id="question-category">
					<span class="cat-pill">🏕️ Survival</span>
				</div>

				<div class="question-text-area">
					<h3 id="question-prompt">Soal akan dimuat...</h3>
				</div>

				<div class="flex flex-col gap-2.5" id="options-container"></div>

				<div class="education-card" id="education-card" style="display: none;">
					<div class="edu-header">
						<span class="edu-icon">💡</span>
						<span class="edu-label">Penjelasan</span>
					</div>
					<p id="education-text"></p>
				</div>

				<div class="action-footer">
					<span id="answer-hint" class="answer-hint">Pilih salah satu jawaban di atas</span>
					<button id="btn-submit-answer" class="btn btn-gold" disabled>Konfirmasi Jawaban</button>
				</div>
			</div>

			<!-- Reference Sidebar -->
			<div class="quiz-help-card glass-card">
				<h3>Akronim SURVIVAL</h3>
				<p class="help-subtitle">Panduan bertahan di alam bebas</p>
				<div class="survival-list">
					<div class="sv-row"><span class="sv-letter">S</span><span class="sv-text">Sadar dalam keadaan gawat darurat</span></div>
					<div class="sv-row"><span class="sv-letter">U</span><span class="sv-text">Usahakan tetap tenang, gunakan akal sehat</span></div>
					<div class="sv-row"><span class="sv-letter">R</span><span class="sv-text">Rasa takut dan putus asa hilangkan</span></div>
					<div class="sv-row"><span class="sv-letter">V</span><span class="sv-text">Vitalitas tingkatkan</span></div>
					<div class="sv-row"><span class="sv-letter">I</span><span class="sv-text">Ingin tetap hidup dan selamat itu tujuannya</span></div>
					<div class="sv-row"><span class="sv-letter">V</span><span class="sv-text">Variasi alam bisa dimanfaatkan</span></div>
					<div class="sv-row"><span class="sv-letter">A</span><span class="sv-text">Asal mengerti, berlatih, dan tahu caranya</span></div>
					<div class="sv-row"><span class="sv-letter">L</span><span class="sv-text">Lancar, slaman, slumun, slamet</span></div>
				</div>

				<div class="help-divider"></div>

				<h3>Akronim STOP</h3>
				<p class="help-subtitle">Tindakan pertama saat tersesat</p>
				<div class="survival-list">
					<div class="sv-row"><span class="sv-letter">S</span><span class="sv-text">Stop &amp; Seating — berhenti dan duduk</span></div>
					<div class="sv-row"><span class="sv-letter">T</span><span class="sv-text">Thinking — berpikirlah</span></div>
					<div class="sv-row"><span class="sv-letter">O</span><span class="sv-text">Observe — amati keadaan sekitar</span></div>
					<div class="sv-row"><span class="sv-letter">P</span><span class="sv-text">Planning — buat rencana tindakan</span></div>
				</div>

				<div class="help-divider"></div>

				<h3>Ketahanan Tanpa Air &amp; Makanan</h3>
				<div class="fact-box">
					<div class="fact-row"><span class="fact-key">Tanpa air</span><span class="fact-val">3–5 hari</span></div>
					<div class="fact-row"><span class="fact-key">Tanpa makanan</span><span class="fact-val">20–30 hari</span></div>
					<div class="fact-row"><span class="fact-key">Faktor mental</span><span class="fact-val">~80% kesiapan</span></div>
				</div>
			</div>
		</div>

		<!-- Result Overlay -->
		<div class="result-overlay" id="result-overlay" style="display: none;">
			<div class="result-card glass-card">
				<div class="result-emoji" id="result-emoji">🏆</div>
				<h2 id="result-title">Kuis Selesai!</h2>
				<p class="result-summary" id="result-text">Anda menjawab soal dengan baik.</p>

				<div class="result-stats-details">
					<div class="detail-item">
						<span class="label">XP Diperoleh</span>
						<span class="value score-xp" id="result-xp">+100 XP</span>
					</div>
					<div class="detail-item">
						<span class="label">Skor Akhir</span>
						<span class="value" id="result-score">100/100</span>
					</div>
					<div class="detail-item">
						<span class="label">Jawaban Benar</span>
						<span class="value" id="result-correct">10/10</span>
					</div>
				</div>

				<div class="unlocked-badges-container" id="unlocked-badges" style="display: none;">
					<h3>🎖️ Lencana Baru Terbuka!</h3>
					<div class="unlocked-badges-list" id="badges-list-el"></div>
				</div>

				<div class="result-actions">
					<button id="btn-restart" class="btn btn-primary">Ulangi Kuis</button>
					<a href="/" class="btn btn-gold">Kembali ke Dasbor</a>
				</div>
			</div>
		</div>
	</div>
</Layout>

<script>
	// ─── Bank Soal Survival (30 soal, pilih 10 acak per sesi) ───────────────────

	interface Question {
		kategori: string;
		q: string;
		options: string[];
		correct: string;
		edu: string;
	}

	const QUESTIONS_POOL: Question[] = [
		// ── Definisi & Konsep ─────────────────────────────────────────────────────
		{
			kategori: "Definisi Survival",
			q: "Kata 'survive' dalam konteks kepramukaan berarti...",
			options: [
				"Berlari menjauh dari bahaya secepatnya",
				"Mampu mempertahankan diri dari keadaan yang buruk dan kritis",
				"Mencari pertolongan dari orang lain",
				"Membuat peta dan kompas dari bahan alam"
			],
			correct: "Mampu mempertahankan diri dari keadaan yang buruk dan kritis",
			edu: "Survival berasal dari kata 'survive' yang berarti mampu mempertahankan diri dari keadaan tertentu — khususnya dari keadaan buruk dan kritis. Seorang 'survivor' adalah orang yang sedang dalam proses mempertahankan dirinya. Survival bukan sekadar bertahan fisik, tetapi juga mencakup ketahanan mental dan kemampuan memanfaatkan sumber daya alam."
		},
		{
			kategori: "Definisi Survival",
			q: "Faktor manakah yang paling menentukan kemampuan seorang survivor untuk bertahan, sekitar 80% kesiapan survival bergantung pada faktor ini?",
			options: ["Perlengkapan yang dibawa", "Mental dan kejiwaan", "Kondisi fisik dan kesehatan", "Teknik survival yang dikuasai"],
			correct: "Mental dan kejiwaan",
			edu: "Sekitar 80% kesiapan survival terletak pada faktor mental. Kepanikan, rasa putus asa, dan kehilangan akal sehat adalah musuh terbesar seorang survivor. Faktor lainnya adalah perlengkapan, teknik survival, dan kondisi fisik — namun semuanya bergantung pada kekuatan mental yang menjadi landasan utama kemampuan bertahan."
		},
		{
			kategori: "Definisi Survival",
			q: "Mengapa kebutuhan survival bisa timbul? Penyebab utamanya adalah...",
			options: [
				"Cuaca yang selalu tidak menentu di hutan",
				"Adanya usaha manusia untuk keluar dari kesulitan akibat keadaan alam, makhluk hidup sekitar, dan kondisi diri sendiri",
				"Minimnya perlengkapan yang dibawa saat berkemah",
				"Kurangnya pengalaman dalam kegiatan pramuka"
			],
			correct: "Adanya usaha manusia untuk keluar dari kesulitan akibat keadaan alam, makhluk hidup sekitar, dan kondisi diri sendiri",
			edu: "Kebutuhan survival timbul karena adanya usaha manusia untuk keluar dari tiga jenis kesulitan: (1) Keadaan alam — cuaca dan medan; (2) Keadaan makhluk hidup sekitar — binatang dan tumbuhan; (3) Keadaan diri sendiri — mental, fisik, dan kesehatan. Banyak kesulitan tersebut sebenarnya timbul akibat kesalahan diri sendiri, seperti tidak mempersiapkan diri dengan baik."
		},
		{
			kategori: "Definisi Survival",
			q: "Seorang survivor wajib memiliki pengetahuan tentang beberapa hal berikut, KECUALI...",
			options: [
				"Cara membuat bivak dan memperoleh air",
				"Pengetahuan orientasi medan",
				"Cara menghafal nama-nama latin tumbuhan hutan",
				"Cara mendapatkan makanan dan membuat api"
			],
			correct: "Cara menghafal nama-nama latin tumbuhan hutan",
			edu: "Pengetahuan survival yang diperlukan meliputi: cara membuat bivak, cara memperoleh air, cara mendapatkan makanan, cara membuat api, pengetahuan orientasi medan, cara mengatasi gangguan binatang, dan cara mencari pertolongan. Menghafal nama latin tumbuhan bukan prioritas survival — yang penting adalah mengenali tumbuhan yang dapat dan tidak dapat dimakan secara praktis."
		},
		{
			kategori: "Definisi Survival",
			q: "Langkah pertama yang harus dilakukan bila kelompok tersesat di alam bebas adalah...",
			options: [
				"Langsung berpencar untuk mencari jalan keluar",
				"Memanjat pohon tertinggi untuk orientasi",
				"Mengkoordinasi anggota dan melakukan pertolongan pertama",
				"Menyalakan api besar sebagai sinyal darurat"
			],
			correct: "Mengkoordinasi anggota dan melakukan pertolongan pertama",
			edu: "Langkah yang harus ditempuh bila tersesat: (1) Mengkoordinasi anggota — pastikan semua orang berkumpul dan tidak ada yang panik; (2) Melakukan pertolongan pertama bila ada yang terluka; (3) Melihat kemampuan anggota; (4) Mengadakan orientasi medan; (5) Mengadakan penjatahan makanan; (6) Membuat rencana dan pembagian tugas; (7) Berusaha menyambung komunikasi; (8) Membuat jejak dan perhatian; (9) Mendapatkan pertolongan."
		},
		// ── Akronim STOP & SURVIVAL ───────────────────────────────────────────────
		{
			kategori: "Akronim STOP",
			q: "Saat tersesat di hutan, hal pertama yang harus dilakukan sesuai akronim STOP adalah...",
			options: [
				"Segera berlari mencari jalan besar",
				"Stop & Seating — berhenti dan duduk",
				"Send signal — kirim sinyal darurat",
				"Seek water — cari sumber air"
			],
			correct: "Stop & Seating — berhenti dan duduk",
			edu: "Huruf S dalam STOP berarti Stop & Seating — berhenti dan duduk. Ini adalah langkah terpenting karena orang yang panik cenderung berlari tak tentu arah dan memperparah situasi. Dengan berhenti dan duduk, tubuh beristirahat, panik mulai mereda, dan pikiran dapat lebih jernih untuk langkah berikutnya."
		},
		{
			kategori: "Akronim STOP",
			q: "Huruf O dalam akronim STOP saat tersesat berarti...",
			options: [
				"Order — berikan perintah kepada anggota",
				"Open — buka jalur komunikasi",
				"Observe — amati keadaan sekitar",
				"Orientate — tentukan arah utara"
			],
			correct: "Observe — amati keadaan sekitar",
			edu: "O dalam STOP adalah Observe — amati keadaan sekitar. Setelah berhenti (S) dan berpikir (T), langkah berikutnya adalah mengamati lingkungan dengan cermat: arah matahari, tanda-tanda peradaban, aliran sungai, suara-suara di sekitar, dan kondisi anggota kelompok. Hasil observasi inilah yang menjadi dasar perencanaan (P) selanjutnya."
		},
		{
			kategori: "Akronim SURVIVAL",
			q: "Dalam akronim SURVIVAL, huruf R berarti...",
			options: [
				"Rencanakan jalur evakuasi",
				"Rasa takut dan putus asa hilangkan",
				"Rehat dan tidur untuk memulihkan tenaga",
				"Radiasikan sinyal kepada penyelamat"
			],
			correct: "Rasa takut dan putus asa hilangkan",
			edu: "R dalam SURVIVAL adalah 'Rasa takut dan putus asa hilangkan'. Rasa takut dan putus asa adalah musuh utama survival — keduanya menguras energi mental dan fisik, menghambat pengambilan keputusan yang tepat. Survivor yang berhasil adalah mereka yang mampu mengelola rasa takut dan tetap optimis meskipun berada dalam kondisi kritis."
		},
		{
			kategori: "Akronim SURVIVAL",
			q: "Huruf I dalam akronim SURVIVAL kepanjangannya adalah...",
			options: [
				"Identifikasi bahaya di sekitar",
				"Ingin tetap hidup dan selamat itu tujuannya",
				"Ikuti jalur aliran sungai",
				"Isi survival kit sebelum berangkat"
			],
			correct: "Ingin tetap hidup dan selamat itu tujuannya",
			edu: "I dalam SURVIVAL adalah 'Ingin tetap hidup dan selamat itu tujuannya'. Ini menekankan pentingnya motivasi dan keinginan yang kuat untuk selamat. Riset psikologi survival menunjukkan bahwa korban yang paling besar kemungkinan selamatnya adalah mereka yang memiliki alasan kuat untuk tetap hidup — bisa berupa keluarga, tanggung jawab, atau nilai-nilai yang dipegang teguh."
		},
		{
			kategori: "Akronim SURVIVAL",
			q: "Huruf V kedua (ke-6) dalam akronim SURVIVAL berarti...",
			options: [
				"Ventilasi — buat lubang udara di bivak",
				"Variasi alam bisa dimanfaatkan",
				"Verifikasi posisi dengan kompas",
				"Visi — tetapkan target untuk esok hari"
			],
			correct: "Variasi alam bisa dimanfaatkan",
			edu: "V kedua dalam SURVIVAL adalah 'Variasi alam bisa dimanfaatkan'. Alam menyediakan berbagai sumber daya yang dapat dimanfaatkan untuk bertahan hidup — dari tumbuhan yang dapat dimakan, air dari berbagai sumber, bahan untuk membuat api, hingga material untuk membuat shelter. Kreativitas dalam memanfaatkan variasi alam adalah kunci survival yang sukses."
		},
		// ── Shelter & Bivak ───────────────────────────────────────────────────────
		{
			kategori: "Shelter & Bivak",
			q: "Tujuan utama membuat bivak (shelter) dalam survival adalah...",
			options: [
				"Sebagai tempat menyimpan makanan dan perlengkapan",
				"Untuk melindungi dari angin, panas, hujan, dan dingin",
				"Sebagai pos pengintaian di ketinggian",
				"Agar mudah ditemukan oleh tim penyelamat"
			],
			correct: "Untuk melindungi dari angin, panas, hujan, dan dingin",
			edu: "Tujuan utama membuat bivak/shelter dalam survival adalah untuk melindungi diri dari elemen alam: angin, panas matahari, hujan, dan dingin. Paparan berlebihan terhadap elemen-elemen ini dapat menyebabkan hipotermia, heat stroke, atau kelelahan ekstrem yang mengancam jiwa. Shelter yang baik mempertahankan suhu tubuh dan melindungi dari cuaca ekstrem."
		},
		{
			kategori: "Shelter & Bivak",
			q: "Manakah lokasi yang HARUS DIHINDARI saat memilih tempat mendirikan bivak?",
			options: [
				"Di bawah pohon yang rindang",
				"Di daerah aliran air atau lembah sungai",
				"Di tempat yang terlindung dari angin langsung",
				"Di dekat sumber air bersih yang mengalir"
			],
			correct: "Di daerah aliran air atau lembah sungai",
			edu: "Daerah aliran air harus dihindari saat memilih lokasi bivak karena risiko banjir bandang yang bisa datang tiba-tiba, terutama saat hujan deras di hulu. Selain itu, daerah lembah dan aliran air cenderung menjadi sarang nyamuk dan serangga. Syarat bivak yang benar: hindari daerah aliran air, pastikan tidak ada dahan mati di atas, bukan sarang nyamuk/serangga, bahan kuat, dan terlindung dari angin."
		},
		{
			kategori: "Shelter & Bivak",
			q: "Jenis shelter yang menggunakan gua alam sebagai tempat berlindung memiliki syarat penting yaitu...",
			options: [
				"Gua harus menghadap ke arah utara",
				"Gua bukan tempat persembunyian binatang, tidak ada gas beracun, dan tidak mudah longsor",
				"Gua harus memiliki aliran air di dalamnya",
				"Gua harus cukup dalam minimal 10 meter"
			],
			correct: "Gua bukan tempat persembunyian binatang, tidak ada gas beracun, dan tidak mudah longsor",
			edu: "Sebelum menggunakan gua sebagai shelter, periksa tiga hal: (1) Bukan tempat persembunyian binatang berbahaya seperti ular, kelelawar, atau hewan buas; (2) Tidak ada gas beracun — gunakan lilin atau nyala api kecil untuk mendeteksi gas berbahaya; (3) Tidak mudah longsor — periksa struktur atap dan dinding gua. Gua yang memenuhi syarat ini menjadi shelter alam terbaik."
		},
		{
			kategori: "Shelter & Bivak",
			q: "Salah satu syarat penting bivak adalah 'di atas shelter tidak ada dahan pohon mati atau rapuh'. Mengapa?",
			options: [
				"Agar cahaya matahari bisa masuk ke dalam bivak",
				"Dahan mati bisa jatuh sewaktu-waktu dan membahayakan orang di dalam bivak",
				"Agar sinyal darurat bisa terlihat dari udara",
				"Dahan mati biasanya menjadi sarang lebah dan tawon"
			],
			correct: "Dahan mati bisa jatuh sewaktu-waktu dan membahayakan orang di dalam bivak",
			edu: "Dahan pohon yang mati atau rapuh bisa jatuh kapan saja, terutama saat angin kencang atau hujan lebat — kondisi yang justru sering terjadi saat kita membutuhkan shelter. Kejatuhan dahan besar dapat menyebabkan cedera serius atau bahkan kematian. Ini adalah salah satu syarat utama pemilihan lokasi bivak yang aman selain menghindari daerah aliran air dan sarang serangga."
		},
		// ── Air & Makanan ─────────────────────────────────────────────────────────
		{
			kategori: "Air & Makanan",
			q: "Berapa lama seseorang dalam kondisi normal dapat bertahan hidup TANPA AIR?",
			options: ["1–2 hari", "3–5 hari", "7–10 hari", "14–20 hari"],
			correct: "3–5 hari",
			edu: "Seseorang dalam kondisi normal hanya dapat bertahan 3–5 hari tanpa air. Ini jauh lebih singkat dibandingkan tanpa makanan (20–30 hari). Air sangat vital untuk semua fungsi tubuh: mengatur suhu tubuh, melancarkan metabolisme, dan mengangkut nutrisi. Dalam kondisi panas atau aktivitas fisik tinggi, tubuh bisa mengalami dehidrasi kritis dalam hitungan jam."
		},
		{
			kategori: "Air & Makanan",
			q: "Air dari sumber mana yang TIDAK perlu dimurnikan terlebih dahulu sebelum diminum?",
			options: [
				"Air sungai besar yang mengalir deras",
				"Air yang ditampung dari hujan langsung",
				"Air dari genangan di lembah",
				"Air yang digali dari pasir pantai"
			],
			correct: "Air yang ditampung dari hujan langsung",
			edu: "Air hujan yang ditampung langsung (sebelum menyentuh tanah atau permukaan lain) adalah satu-satunya sumber air yang tidak perlu dimurnikan. Cara menampungnya: gunakan ponco, daun lebar, atau buat cekungan dari daun untuk mengalirkan air hujan ke wadah penampungan. Sumber air lainnya seperti sungai, genangan, atau air galian pantai harus dimurnikan terlebih dahulu."
		},
		{
			kategori: "Air & Makanan",
			q: "Cara mendapatkan air dari tanaman rambat atau rotan di hutan adalah...",
			options: [
				"Kupas kulitnya dan peras ke dalam wadah",
				"Potong setinggi mungkin lalu potong bagian dekat tanah, tampung air yang menetes",
				"Rebus batangnya hingga menghasilkan uap air",
				"Tumbuk batangnya hingga halus kemudian peras"
			],
			correct: "Potong setinggi mungkin lalu potong bagian dekat tanah, tampung air yang menetes",
			edu: "Cara mendapatkan air dari tanaman rambat/rotan: potong setinggi mungkin (dari atas), lalu potong pada bagian yang dekat dengan tanah. Air yang ada di dalam batang akan menetes karena gravitasi dan dapat ditampung atau diteteskan langsung ke mulut. Jangan memotong dari bawah dulu — tekanan udara akan mencegah air mengalir keluar."
		},
		{
			kategori: "Air & Makanan",
			q: "Patokan yang benar dalam memilih makanan dari alam saat survival adalah...",
			options: [
				"Pilih makanan yang paling mudah dijangkau dan berlimpah",
				"Makanan yang dimakan kera juga bisa dimakan manusia, dan hindari makanan berwarna mencolok",
				"Pilih tumbuhan yang paling hijau dan segar daunnya",
				"Semua buah yang sudah matang aman untuk dimakan"
