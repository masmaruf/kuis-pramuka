---
import Layout from '../layouts/Layout.astro';
import KompasQuiz from '../components/KompasQuiz.astro';
---

<Layout title="Kuis Kompas & Navigasi Pramuka" description="Latihan kompas dan navigasi pramuka: arah mata angin, azimuth, back azimuth, peta topografi, garis kontur, skala peta, dan teknik resection.">
	<KompasQuiz quizId="kompas" totalQuestions={10} />
		<header class="quiz-header glass-card">
			<a href="/" class="btn-back">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<line x1="19" y1="12" x2="5" y2="12"/>
					<polyline points="12 19 5 12 12 5"/>
				</svg>
				Kembali ke Dasbor
			</a>
			<div class="quiz-title-area">
				<h2>Kuis Kompas &amp; Navigasi</h2>
				<span class="quiz-difficulty medium">Navigasi Darat</span>
			</div>
		</header>

		<div class="quiz-layout">
			<div class="quiz-main-card glass-card">
				<div class="progress-tracker">
					<div class="progress-label">
						<span id="question-number">Soal 1 dari 10</span>
						<span id="progress-pct" class="pct-label">10%</span>
					</div>
					<div class="progress-bar-outer">
						<div id="quiz-progress-bar" class="progress-bar-inner" style="width:10%"></div>
					</div>
				</div>
				<div class="question-category" id="question-category">
					<span class="cat-pill">🧭 Kompas &amp; Navigasi</span>
				</div>
				<div class="question-text-area">
					<h3 id="question-prompt">Soal akan dimuat...</h3>
				</div>
				<div class="flex flex-col gap-2.5" id="options-container"></div>
				<div class="education-card" id="education-card" style="display:none;">
					<div class="edu-header">
						<span class="edu-icon">🗺️</span>
						<span class="edu-label">Penjelasan Navigasi</span>
					</div>
					<p id="education-text"></p>
				</div>
				<div class="action-footer">
					<span id="answer-hint" class="answer-hint">Pilih salah satu jawaban di atas</span>
					<button id="btn-submit-answer" class="btn btn-gold" disabled>Konfirmasi Jawaban</button>
				</div>
			</div>

			<div class="quiz-help-card glass-card">
				<h3>Referensi Kompas</h3>
				<p class="help-subtitle">Arah mata angin &amp; nilai derajat</p>

				<div class="compass-grid">
					<div class="compass-item main"><span class="dir">U (Utara)</span><span class="deg">0° / 360°</span></div>
					<div class="compass-item sub"><span class="dir">TL (Timur Laut)</span><span class="deg">45°</span></div>
					<div class="compass-item main"><span class="dir">T (Timur)</span><span class="deg">90°</span></div>
					<div class="compass-item sub"><span class="dir">TG (Tenggara)</span><span class="deg">135°</span></div>
					<div class="compass-item main"><span class="dir">S (Selatan)</span><span class="deg">180°</span></div>
					<div class="compass-item sub"><span class="dir">BD (Barat Daya)</span><span class="deg">225°</span></div>
					<div class="compass-item main"><span class="dir">B (Barat)</span><span class="deg">270°</span></div>
					<div class="compass-item sub"><span class="dir">BL (Barat Laut)</span><span class="deg">315°</span></div>
				</div>

				<div class="nav-formula-box">
					<div class="formula-row">
						<span class="formula-label">Back Azimuth</span>
						<span class="formula-val">Az &lt; 180° → +180°<br>Az ≥ 180° → −180°</span>
					</div>
					<div class="formula-row">
						<span class="formula-label">Skala peta</span>
						<span class="formula-val">Jarak peta ÷ Skala = Jarak nyata</span>
					</div>
					<div class="formula-row">
						<span class="formula-label">Resection</span>
						<span class="formula-val">2 titik dikenal → tentukan posisi sendiri</span>
					</div>
					<div class="formula-row">
						<span class="formula-label">Intersection</span>
						<span class="formula-val">1 titik dikenal → tentukan posisi objek</span>
					</div>
				</div>
			</div>
		</div>

		<div class="result-overlay" id="result-overlay" style="display:none;">
			<div class="result-card glass-card">
				<div class="result-emoji" id="result-emoji">🏆</div>
				<h2 id="result-title">Kuis Selesai!</h2>
				<p class="result-summary" id="result-text"></p>
				<div class="result-stats-details">
					<div class="detail-item"><span class="label">XP Diperoleh</span><span class="value score-xp" id="result-xp">+100 XP</span></div>
					<div class="detail-item"><span class="label">Skor Akhir</span><span class="value" id="result-score">100/100</span></div>
					<div class="detail-item"><span class="label">Jawaban Benar</span><span class="value" id="result-correct">10/10</span></div>
				</div>
				<div class="unlocked-badges-container" id="unlocked-badges" style="display:none;">
					<h3>🎖️ Lencana Baru Terbuka!</h3>
					<div class="unlocked-badges-list" id="badges-list-el"></div>
				</div>
				<div class="result-actions">
					<button id="btn-restart" class="btn btn-primary">Ulangi Kuis</button>
					<a href="/" class="btn btn-gold">Kembali ke Dasbor</a>
				</div>
			</div>
		</div>
	</div>
</Layout>

<script>
	interface Question { kategori:string; q:string; options:string[]; correct:string; edu:string; }

	const QUESTIONS_POOL: Question[] = [
		// ── Arah Mata Angin ─────────────────────────────────────────────────────
		{ kategori:"Arah Mata Angin", q:"Berapa derajat arah Timur pada kompas?", options:["45°","90°","135°","180°"], correct:"90°", edu:"Kompas menggunakan sistem 360 derajat searah jarum jam dari Utara. Utara = 0°/360°, Timur = 90°, Selatan = 180°, Barat = 270°. Keempat arah ini disebut arah kardinal (Cardinal Directions) atau arah mata angin utama." },
		{ kategori:"Arah Mata Angin", q:"Arah Tenggara pada kompas berada di antara arah...", options:["Utara dan Timur","Timur dan Selatan","Selatan dan Barat","Barat dan Utara"], correct:"Timur dan Selatan", edu:"Tenggara (SE/South-East) berada di antara Timur (90°) dan Selatan (180°), yaitu pada 135°. Delapan arah mata angin: U(0°), TL(45°), T(90°), TG(135°), S(180°), BD(225°), B(270°), BL(315°). Dalam bahasa Inggris: N, NE, E, SE, S, SW, W, NW." },
		{ kategori:"Arah Mata Angin", q:"Berapa jumlah arah mata angin jika menggunakan sistem 16 arah (termasuk arah antara)?", options:["8 arah","12 arah","16 arah","32 arah"], correct:"16 arah", edu:"Sistem 16 arah membagi lingkaran menjadi 16 bagian dengan interval 22,5°. Di antara 8 arah utama (U,TL,T,TG,S,BD,B,BL) ditambahkan 8 arah antara: UUTl (NNE), TlT (ENE), TTG (ESE), TGS (SSE), SBD (SSW), BDB (WSW), BBL (WNW), BLU (NNW). Sistem ini dipakai dalam navigasi laut dan udara." },
		{ kategori:"Arah Mata Angin", q:"Azimuth 225° setara dengan arah mata angin...", options:["Tenggara","Barat Daya","Barat Laut","Timur Laut"], correct:"Barat Daya", edu:"Barat Daya (SW/South-West) berada pada 225°, tepat di antara Selatan (180°) dan Barat (270°). Cara menghafal derajat 8 arah: bayangkan jam dengan angka 0/360 di atas (Utara), lalu hitung searah jarum jam dengan interval 45° untuk setiap arah berikutnya." },
		// ── Membaca Kompas ──────────────────────────────────────────────────────
		{ kategori:"Membaca Kompas", q:"Bagian kompas yang selalu menunjuk ke arah Utara Magnetik adalah...", options:["Jarum merah/berwarna kompas","Lingkaran derajat (bezel)","Kaca penutup kompas","Pegangan kompas"], correct:"Jarum merah/berwarna kompas", edu:"Jarum kompas (biasanya berwarna merah di ujung yang menunjuk Utara) adalah magnet kecil yang bebas berputar dan selalu sejajar dengan medan magnet bumi, menunjuk ke arah Utara Magnetik. Penting: Utara Magnetik berbeda dengan Utara Geografis (True North) akibat deklinasi magnetik." },
		{ kategori:"Membaca Kompas", q:"Cara memegang kompas yang benar saat membaca azimuth adalah...", options:["Pegang di atas kepala agar jauh dari logam","Pegang setinggi pinggang dengan satu tangan","Pegang setinggi dada, posisi datar, jauh dari logam/besi","Letakkan di tanah lalu membungkuk untuk membaca"], correct:"Pegang setinggi dada, posisi datar, jauh dari logam/besi", edu:"Cara memegang kompas yang benar: (1) Genggam kompas dengan kedua tangan, tahan di depan dada setinggi dada. (2) Pastikan kompas dalam posisi datar/horizontal agar jarum bisa berputar bebas. (3) Jauhkan dari benda logam/besi, ponsel, dan kabel listrik yang dapat mempengaruhi jarum magnet. (4) Baca derajat saat jarum sudah berhenti bergerak." },
		{ kategori:"Membaca Kompas", q:"Deklinasi magnetik adalah...", options:["Sudut antara Utara Magnetik dan Utara Geografis (True North)","Kemampuan kompas untuk menunjuk arah di dalam air","Perbedaan derajat antara dua kompas yang berbeda merek","Kesalahan baca kompas akibat tangan yang bergetar"], correct:"Sudut antara Utara Magnetik dan Utara Geografis (True North)", edu:"Deklinasi magnetik adalah selisih sudut antara Utara Magnetik (yang ditunjuk jarum kompas) dan Utara Geografis (arah kutub utara bumi yang sebenarnya). Nilainya berbeda di setiap lokasi di bumi dan berubah dari waktu ke waktu. Di Indonesia, deklinasi magnetik berkisar 0–3° ke Timur, relatif kecil sehingga sering diabaikan untuk navigasi sederhana." },
		{ kategori:"Membaca Kompas", q:"Azimuth (sudut kompas) 310° dibaca sebagai arah...", options:["Barat Daya","Barat","Barat Laut","Utara Barat Laut"], correct:"Barat Laut", edu:"310° berada antara Barat (270°) dan Utara (360°/0°), tepatnya di kuadran Barat Laut (315° ± sekitar 45°). Barat Laut sendiri tepat di 315°, jadi 310° sangat dekat dengan Barat Laut, sedikit ke arah Barat. Untuk navigasi lapangan, pembulatan ke arah terdekat cukup akurat." },
		// ── Back Azimuth ────────────────────────────────────────────────────────
		{ kategori:"Back Azimuth", q:"Back azimuth (azimuth balik) dari 60° adalah...", options:["120°","180°","240°","300°"], correct:"240°", edu:"Back azimuth adalah arah berlawanan dari azimuth. Rumus: jika azimuth < 180°, maka back azimuth = azimuth + 180°. Jika azimuth ≥ 180°, maka back azimuth = azimuth − 180°. Jadi 60° + 180° = 240°. Back azimuth berguna untuk kembali ke titik awal mengikuti jalur yang sama (backtrack)." },
		{ kategori:"Back Azimuth", q:"Jika azimuth dari titik A ke titik B adalah 270° (Barat), maka back azimuth dari B ke A adalah...", options:["90°","180°","0°","360°"], correct:"90°", edu:"270° ≥ 180°, jadi back azimuth = 270° − 180° = 90° (arah Timur). Ini logis: jika kamu berjalan ke Barat dari A ke B, maka untuk kembali dari B ke A kamu harus berjalan ke Timur. Back azimuth selalu berlawanan 180° dengan azimuth asli." },
		{ kategori:"Back Azimuth", q:"Azimuth 180° (Selatan) memiliki back azimuth...", options:["0°","90°","270°","360°"], correct:"0°", edu:"180° ≥ 180°, jadi back azimuth = 180° − 180° = 0° (Utara). Arah Selatan dan Utara adalah tepat berlawanan 180°. Nilai 0° dan 360° adalah sama dalam kompas — keduanya merujuk ke arah Utara." },
		// ── Peta Topografi ──────────────────────────────────────────────────────
		{ kategori:"Peta Topografi", q:"Skala peta 1:50.000 berarti...", options:["1 cm di peta = 50 meter di lapangan","1 cm di peta = 500 meter di lapangan","1 cm di peta = 5 km di lapangan","1 mm di peta = 50 cm di lapangan"], correct:"1 cm di peta = 500 meter di lapangan", edu:"Skala 1:50.000 berarti 1 satuan di peta = 50.000 satuan yang sama di lapangan. Jadi 1 cm di peta = 50.000 cm = 500 meter di lapangan nyata. Peta skala 1:25.000 lebih detail (1 cm = 250 m), dipakai untuk navigasi hiking. Peta 1:50.000 dipakai TNI/pramuka untuk orientasi daerah." },
		{ kategori:"Peta Topografi", q:"Garis kontur pada peta topografi menghubungkan titik-titik yang...", options:["Memiliki jenis tanah yang sama","Memiliki ketinggian yang sama di atas permukaan laut","Memiliki jarak yang sama dari sumber air","Berjarak sama dari batas kota"], correct:"Memiliki ketinggian yang sama di atas permukaan laut", edu:"Garis kontur adalah garis khayal pada peta yang menghubungkan semua titik dengan ketinggian yang sama di atas muka laut. Ciri-ciri: (1) Garis kontur yang rapat = lereng curam. (2) Garis kontur yang jarang = lereng landai. (3) Garis kontur membentuk lingkaran tertutup = puncak bukit. (4) Garis kontur berbentuk V mengarah ke hulu = lembah/sungai." },
		{ kategori:"Peta Topografi", q:"Contour interval (interval kontur) adalah...", options:["Jarak horizontal antara dua garis kontur di peta","Beda ketinggian antara dua garis kontur yang berdekatan","Tebal garis kontur pada peta","Jumlah garis kontur dalam satu lembar peta"], correct:"Beda ketinggian antara dua garis kontur yang berdekatan", edu:"Contour interval (CI) adalah beda ketinggian antara dua garis kontur yang berurutan. Contoh: jika CI = 25 meter, setiap garis kontur lebih tinggi 25 meter dari garis di bawahnya. CI tercantum di legenda peta. Peta dengan CI kecil lebih detail dalam menggambarkan relief. Peta 1:25.000 biasanya CI = 12.5 m; peta 1:50.000 biasanya CI = 25 m." },
		{ kategori:"Peta Topografi", q:"Simbol garis biru berliku-liku pada peta topografi biasanya mewakili...", options:["Jalan raya","Batas wilayah administrasi","Sungai atau aliran air","Jalur listrik tegangan tinggi"], correct:"Sungai atau aliran air", edu:"Pada peta topografi standar, warna biru digunakan untuk unsur-unsur air: sungai (garis biru), danau/waduk (area biru), rawa (simbol biru). Warna lain: hijau = vegetasi, cokelat = garis kontur, merah/hitam = jalan dan bangunan, kuning = lahan pertanian. Pengenalan simbol peta (legenda) adalah keterampilan dasar navigasi." },
		{ kategori:"Peta Topografi", q:"Legenda peta adalah...", options:["Nama pembuat peta","Kumpulan simbol beserta penjelasannya yang tertera di tepi peta","Skala yang ditunjukkan dalam bentuk grafis","Tahun pembuatan peta"], correct:"Kumpulan simbol beserta penjelasannya yang tertera di tepi peta", edu:"Legenda (keterangan) peta adalah daftar simbol yang digunakan dalam peta beserta artinya, biasanya terletak di bagian tepi atau sudut peta. Tanpa legenda, simbol pada peta tidak bisa dibaca dengan benar. Legenda mencakup: simbol topografi, jenis jalan, jenis bangunan, simbol vegetasi, batas wilayah, dan unsur-unsur lainnya." },
		// ── Orientasi & Teknik Navigasi ─────────────────────────────────────────
		{ kategori:"Orientasi Peta", q:"Orientasi peta (map orientation) artinya...", options:["Membuat peta baru berdasarkan pengamatan lapangan","Menyesuaikan arah peta dengan kondisi medan yang sebenarnya menggunakan kompas","Menggambar ulang peta yang sudah rusak","Memilih rute perjalanan di atas peta"], correct:"Menyesuaikan arah peta dengan kondisi medan yang sebenarnya menggunakan kompas", edu:"Orientasi peta adalah proses memutar peta sehingga arah Utara peta sesuai dengan arah Utara kompas (dan kondisi medan nyata). Cara: (1) Letakkan kompas di atas peta. (2) Putar peta + kompas bersamaan hingga jarum kompas sejajar dengan garis grid utara pada peta. (3) Sekarang peta sudah terorientasi — objek di depanmu akan sesuai dengan gambar di peta." },
		{ kategori:"Teknik Navigasi", q:"Teknik resection dalam navigasi darat digunakan untuk...", options:["Menentukan arah ke tujuan menggunakan dua titik yang sudah dikenal","Menentukan posisi diri sendiri di peta dengan mengambil azimuth ke dua atau lebih titik yang dikenal","Memperkirakan jarak dengan menghitung langkah","Membaca ketinggian dari garis kontur peta"], correct:"Menentukan posisi diri sendiri di peta dengan mengambil azimuth ke dua atau lebih titik yang dikenal", edu:"Resection: teknik menentukan posisi diri. Caranya: (1) Identifikasi dua atau tiga titik yang bisa dilihat dan ada di peta (puncak gunung, menara, dll). (2) Ukur back azimuth dari tiap titik ke posisimu. (3) Tarik garis di peta dari titik-titik tersebut sesuai azimuth. (4) Perpotongan garis-garis itu adalah posisimu. Berbeda dengan intersection yang dipakai untuk menentukan posisi objek yang tidak ada di peta." },
		{ kategori:"Teknik Navigasi", q:"Dalam navigasi darat, 'dead reckoning' adalah teknik...", options:["Navigasi menggunakan bintang di malam hari","Memperkirakan posisi terkini berdasarkan posisi awal, kecepatan, arah, dan waktu tempuh","Membaca peta menggunakan senter di malam hari","Navigasi dengan mempertahankan jalur yang sudah dikenal tanpa peta"], correct:"Memperkirakan posisi terkini berdasarkan posisi awal, kecepatan, arah, dan waktu tempuh", edu:"Dead reckoning adalah teknik navigasi dengan menghitung posisi terkini dari posisi yang diketahui terakhir, dengan mempertimbangkan kecepatan jalan, waktu yang ditempuh, dan arah. Contoh: jika kamu tahu posisimu pukul 08.00, berjalan dengan kecepatan 4 km/jam ke arah Timur (90°) selama 1.5 jam, maka posisimu sekarang adalah 6 km ke arah Timur dari posisi awal." },
		{ kategori:"Teknik Navigasi", q:"Handrail dalam navigasi darat merujuk pada...", options:["Pegangan besi di lereng gunung","Fitur medan linear (sungai, jalan, punggungan) yang diikuti sebagai panduan arah","Tali pemandu yang dipasang di jalur pendakian berbahaya","Kompas yang dipegang dengan kedua tangan"], correct:"Fitur medan linear (sungai, jalan, punggungan) yang diikuti sebagai panduan arah", edu:"Handrail adalah fitur alami atau buatan yang memanjang dan digunakan sebagai panduan navigasi. Contoh handrail: sungai, jalan setapak, punggungan bukit, pagar, tepi hutan. Dengan mengikuti handrail, navigator tidak perlu terus-menerus memeriksa kompas. Teknik ini sangat berguna di medan berkabut atau hutan lebat." },
		{ kategori:"Teknik Navigasi", q:"Catching feature (attack point / fitur penyergap) dalam navigasi adalah...", options:["Titik koordinat GPS yang ditandai di peta","Fitur medan yang mudah dikenali sebagai 'batas' agar tahu sudah melewati tujuan","Jalur evakuasi darurat saat tersesat","Metode untuk mengikuti peta di malam hari"], correct:"Fitur medan yang mudah dikenali sebagai 'batas' agar tahu sudah melewati tujuan", edu:"Catching feature adalah fitur medan yang terletak di luar/melewati tujuanmu — jika mencapainya, kamu tahu sudah melewati titik tujuan. Contoh: sungai di seberang bukit yang ingin kamu capai. Jika kamu sudah mencapai sungai, berarti kamu sudah melewati bukit tujuan. Ini mencegah navigasi tanpa akhir saat melewatkan tujuan." },
		// ── Langkah & Jarak ────────────────────────────────────────────────────
		{ kategori:"Mengukur Jarak", q:"Cara paling sederhana mengukur jarak di lapangan (tanpa alat elektronik) adalah...", options:["Menggunakan bayangan matahari","Menghitung jumlah langkah kaki (pace count)","Mengukur dengan tali","Memperkirakan berdasarkan waktu tempuh saja"], correct:"Menghitung jumlah langkah kaki (pace count)", edu:"Pace count adalah teknik mengukur jarak dengan menghitung langkah kaki. Pertama, kalibrasi: hitung berapa langkah (atau pasang langkah / double step) kamu butuhkan untuk berjalan 100 meter di medan datar. Rata-rata orang dewasa = sekitar 60-65 langkah per 100 meter. Gunakan pace bead (rosario navigasi) untuk membantu menghitung. Metode ini akurat hingga ±5-10% di medan terbuka." },
		{ kategori:"Mengukur Jarak", q:"Jika skala peta 1:25.000 dan jarak di peta adalah 4 cm, berapa jarak sebenarnya di lapangan?", options:["25 meter","100 meter","500 meter","1.000 meter"], correct:"1.000 meter", edu:"Perhitungan: jarak nyata = jarak peta × skala = 4 cm × 25.000 = 100.000 cm = 1.000 meter = 1 km. Rumus mudah untuk peta 1:25.000: kalikan cm di peta dengan 250 untuk mendapatkan meter. Untuk peta 1:50.000: kalikan cm di peta dengan 500 untuk mendapatkan meter." },
		// ── Kompas di Alam ──────────────────────────────────────────────────────
		{ kategori:"Navigasi Alam", q:"Cara menentukan arah Utara menggunakan posisi matahari di belahan bumi selatan (Indonesia) pada siang hari adalah...", options:["Matahari selalu berada tepat di Utara saat tengah hari","Matahari berada di arah Utara saat tepat tengah hari (pukul 12 siang) di Indonesia","Bayangan benda menunjuk ke Selatan saat tengah hari di Indonesia","Matahari terbenam di arah Barat lalu bergerak ke Utara"], correct:"Bayangan benda menunjuk ke Selatan saat tengah hari di Indonesia", edu:"Di Indonesia (yang berada antara 6°LU dan 11°LS), matahari berada di sisi Utara ekuator saat tengah hari untuk lokasi di selatan khatulistiwa. Saat tepat tengah hari, bayangan benda tegak menunjuk ke Selatan (karena matahari ada di Utara). Jadi jika punggungmu ke bayangan, kamu menghadap Utara. Namun ini tidak tepat akurat sepanjang tahun karena posisi matahari berubah." },
		{ kategori:"Navigasi Alam", q:"Rasi bintang yang digunakan untuk menentukan arah Selatan di belahan bumi selatan (termasuk Indonesia bagian selatan) adalah...", options:["Orion (Waluku)","Crux (Bintang Pari / Salib Selatan)","Scorpius (Kalajengking)","Ursa Major (Beruang Besar)"], correct:"Crux (Bintang Pari / Salib Selatan)", edu:"Crux (Southern Cross / Bintang Pari) adalah rasi bintang yang digunakan untuk menentukan arah Selatan di belahan bumi selatan. Cara: perpanjang sumbu panjang Crux sejauh 4,5 kali panjangnya — ujungnya menunjuk ke arah Selatan. Berbeda dengan belahan bumi utara yang menggunakan Bintang Utara (Polaris) untuk menentukan Utara. Indonesia terletak di kedua belahan bumi sehingga bisa menggunakan keduanya." },
		{ kategori:"Navigasi Alam", q:"Teknik 'watch method' (metode jam tangan) untuk menentukan arah menggunakan...", options:["Jam tangan digital dengan fitur kompas","Jam tangan analog (jarum jam) diarahkan ke matahari untuk menemukan Selatan","Jam tangan sebagai alat ukur jarak","Waktu lokal dibandingkan GMT untuk menentukan bujur"], correct:"Jam tangan analog (jarum jam) diarahkan ke matahari untuk menemukan Selatan", edu:"Metode jam tangan (untuk belahan bumi utara): arahkan jarum jam ke matahari, garis bagi sudut antara jarum jam dan angka 12 menunjuk ke Selatan. Di belahan bumi selatan (termasuk sebagian Indonesia): arahkan angka 12 ke matahari, garis bagi antara angka 12 dan jarum jam menunjuk ke Utara. Metode ini kurang akurat di daerah tropis seperti Indonesia karena matahari hampir tepat di atas kepala." },
		// ── GPS & Teknologi ─────────────────────────────────────────────────────
		{ kategori:"GPS & Teknologi", q:"Kelemahan utama GPS dibandingkan kompas magnetik dalam kegiatan pramuka di lapangan adalah...", options:["GPS tidak bisa menunjukkan arah sama sekali","GPS membutuhkan baterai, sinyal satelit, dan bisa mati — kompas tidak butuh keduanya","GPS hanya bisa digunakan di kota besar","GPS tidak bisa menunjukkan posisi di peta topografi"], correct:"GPS membutuhkan baterai, sinyal satelit, dan bisa mati — kompas tidak butuh keduanya", edu:"GPS (Global Positioning System) sangat akurat namun memiliki kelemahan: (1) Membutuhkan baterai yang bisa habis. (2) Sinyal lemah di hutan lebat, lembah, atau saat cuaca buruk. (3) Rentan rusak akibat jatuh atau terkena air. Kompas magnetik tidak membutuhkan baterai, tahan cuaca, dan berfungsi selama ada medan magnet bumi. Dalam kepramukaan, keterampilan navigasi manual (peta + kompas) tetap wajib dikuasai sebagai backup." },
		{ kategori:"GPS & Teknologi", q:"Koordinat 'UTM' (Universal Transverse Mercator) berbeda dari koordinat 'lintang-bujur' (lat-long) karena...", options:["UTM menggunakan derajat-menit-detik, lat-long menggunakan angka desimal","UTM menggunakan sistem grid meter yang lebih mudah untuk mengukur jarak di peta topografi","UTM hanya untuk navigasi laut, lat-long untuk navigasi darat","Keduanya identik, hanya penyebutan yang berbeda"], correct:"UTM menggunakan sistem grid meter yang lebih mudah untuk mengukur jarak di peta topografi", edu:"Koordinat lintang-bujur (latitude-longitude) menggunakan derajat dan memerlukan perhitungan kompleks untuk jarak. Koordinat UTM membagi dunia menjadi zona-zona dengan sistem grid meter, sehingga mengukur jarak di peta menjadi sederhana: hitung selisih angka koordinat dalam meter. Peta topografi militer dan hiking Indonesia umumnya menggunakan grid UTM. Contoh koordinat UTM: 49S 0693542 9163847." },
	];

	const XP_PER_CORRECT = 12;
	const QUESTIONS_PER_SESSION = 10;
	const BADGES_FOR_THIS_QUIZ = [
		{ id:'kompas_novice', name:'Penjelajah Muda', icon:'🧭' },
		{ id:'kompas_master', name:'Navigator Handal', icon:'🗺️' },
	];

	let questions: Question[] = [], currentIndex=0, selectedAnswer='', score=0, totalXpEarned=0;

	function shuffle<T>(arr:T[]):T[] { return [...arr].sort(()=>Math.random()-.5); }
	function getEl<T extends HTMLElement>(id:string){ return document.getElementById(id) as T|null; }

	function startQuiz() { questions=shuffle(QUESTIONS_POOL).slice(0,QUESTIONS_PER_SESSION); currentIndex=0; score=0; totalXpEarned=0; selectedAnswer=''; renderQuestion(); }

	function renderQuestion() {
		const q=questions[currentIndex], num=currentIndex+1, pct=(num/QUESTIONS_PER_SESSION)*100;
		getEl('question-number')!.textContent=`Soal ${num} dari ${QUESTIONS_PER_SESSION}`;
		(getEl('progress-pct') as HTMLElement).textContent=`${Math.round(pct)}%`;
		getEl<HTMLDivElement>('quiz-progress-bar')!.style.width=`${pct}%`;
		const catEl=getEl('question-category'); if(catEl) catEl.innerHTML=`<span class="cat-pill">🧭 ${q.kategori}</span>`;
		getEl('question-prompt')!.textContent=q.q;
		const eduCard=getEl<HTMLDivElement>('education-card'); if(eduCard) eduCard.style.display='none';
		const submitBtn=getEl<HTMLButtonElement>('btn-submit-answer');
		if(submitBtn){submitBtn.disabled=true;submitBtn.textContent='Konfirmasi Jawaban';submitBtn.onclick=submitAnswer;}
		const hint=getEl('answer-hint'); if(hint){hint.textContent='Pilih salah satu jawaban di atas';hint.className='answer-hint';}
		selectedAnswer=''; renderOptions(q);
	}

	function renderOptions(q:Question) {
		const container=getEl<HTMLDivElement>('options-container'); if(!container) return;
		container.innerHTML=shuffle(q.options).map((opt,i)=>{
			const letter=String.fromCharCode(65+i);
			return `<button class="opt-btn" data-answer="${opt.replace(/"/g,'&quot;')}" style="animation-delay:${i*.07}s">
				<span class="opt-letter">${letter}</span><span class="opt-text">${opt}</span>
				<span class="opt-indicator"><span class="opt-radio"></span>
				<svg class="opt-icon icon-check" viewBox="0 0 24 24" fill="none" stroke="#236c32" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
				<svg class="opt-icon icon-cross" viewBox="0 0 24 24" fill="none" stroke="#a5301a" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
				</span></button>`;
		}).join('');
		container.querySelectorAll('.opt-btn').forEach((btn,i)=>{
			btn.addEventListener('click',()=>{
				container.querySelectorAll('.opt-btn').forEach(b=>b.classList.remove('is-selected'));
				btn.classList.add('is-selected'); selectedAnswer=(btn as HTMLElement).dataset.answer||'';
				const s=getEl<HTMLButtonElement>('btn-submit-answer'); if(s) s.disabled=false;
				const h=getEl('answer-hint'); if(h){h.textContent=`Jawaban ${String.fromCharCode(65+i)} dipilih — klik Konfirmasi untuk lanjut`;h.className='answer-hint chosen';}
			});
		});
	}

	function submitAnswer() {
		const q=questions[currentIndex], isCorrect=selectedAnswer===q.correct;
		if(isCorrect){score++;totalXpEarned+=XP_PER_CORRECT;}
		const container=getEl<HTMLDivElement>('options-container');
		container?.querySelectorAll('.opt-btn').forEach(btn=>{
			const el=btn as HTMLElement, ans=el.dataset.answer||'';
			el.classList.add('is-answered'); el.classList.remove('is-selected');
			if(ans===q.correct) el.classList.add('is-correct');
			else if(ans===selectedAnswer&&!isCorrect) el.classList.add('is-incorrect');
			else el.classList.add('is-dimmed');
		});
		const eduCard=getEl<HTMLDivElement>('education-card'), eduText=getEl('education-text');
		if(eduCard&&eduText){eduText.textContent=q.edu;eduCard.style.display='flex';eduCard.className=`education-card ${isCorrect?'correct':'incorrect'}`;}
		const hint=getEl('answer-hint'); if(hint){hint.textContent=isCorrect?'✓ Jawaban benar!':'✗ Jawaban salah — lihat penjelasan di bawah.';hint.className=`answer-hint ${isCorrect?'correct-hint':'wrong-hint'}`;}
		const submitBtn=getEl<HTMLButtonElement>('btn-submit-answer');
		if(submitBtn){submitBtn.textContent=currentIndex<QUESTIONS_PER_SESSION-1?'Soal Berikutnya →':'Lihat Hasil';submitBtn.disabled=false;submitBtn.onclick=nextQuestion;}
	}

	function nextQuestion() {
		currentIndex++;
		if(currentIndex<QUESTIONS_PER_SESSION){renderQuestion();const s=getEl<HTMLButtonElement>('btn-submit-answer');if(s)s.onclick=submitAnswer;}
		else showResult();
	}

	function showResult() {
		const pct=Math.round((score/QUESTIONS_PER_SESSION)*100);
		const currentXp=parseInt(localStorage.getItem('scout_xp')||'0');
		localStorage.setItem('scout_xp',(currentXp+totalXpEarned).toString());
		const earnedBadges:string[]=JSON.parse(localStorage.getItem('scout_badges')||'[]');
		const newlyUnlocked:typeof BADGES_FOR_THIS_QUIZ=[];
		if(!earnedBadges.includes('kompas_novice')){earnedBadges.push('kompas_novice');newlyUnlocked.push(BADGES_FOR_THIS_QUIZ[0]);}
		if(pct===100&&!earnedBadges.includes('kompas_master')){earnedBadges.push('kompas_master');newlyUnlocked.push(BADGES_FOR_THIS_QUIZ[1]);}
		if(parseInt(localStorage.getItem('scout_xp')||'0')>=500&&!earnedBadges.includes('scout_master')) earnedBadges.push('scout_master');
		localStorage.setItem('scout_badges',JSON.stringify(earnedBadges));
		getEl('result-emoji')!.textContent=pct===100?'🏆':pct>=80?'⭐':pct>=60?'👍':'📚';
		const t=getEl('result-title'); if(t) t.textContent=pct===100?'Sempurna! Navigator Handal!':pct>=80?'Bagus Sekali!':pct>=60?'Cukup Baik!':'Terus Belajar!';
		getEl('result-text')!.textContent=`Kamu menjawab ${score} dari ${QUESTIONS_PER_SESSION} soal dengan benar (${pct}%). ${pct>=80?'Kamu siap navigasi di lapangan!':'Pelajari kembali cara membaca kompas dan peta.'}`;
		getEl('result-xp')!.textContent=`+${totalXpEarned} XP`;
		getEl('result-score')!.textContent=`${pct}/100`;
		getEl('result-correct')!.textContent=`${score}/${QUESTIONS_PER_SESSION}`;
		if(newlyUnlocked.length>0){
			const bc=getEl<HTMLDivElement>('unlocked-badges'),bl=getEl('badges-list-el');
			if(bc&&bl){bl.innerHTML=newlyUnlocked.map(b=>`<div class="new-badge-item"><span class="new-badge-icon">${b.icon}</span><span class="new-badge-name">${b.name}</span></div>`).join('');bc.style.display='block';}
		}
		const overlay=getEl<HTMLDivElement>('result-overlay'); if(overlay) overlay.style.display='flex';
		window.dispatchEvent(new Event('statsUpdated'));
	}

	getEl<HTMLButtonElement>('btn-submit-answer')?.addEventListener('click',submitAnswer);
	getEl<HTMLButtonElement>('btn-restart')?.addEventListener('click',()=>{const o=getEl<HTMLDivElement>('result-overlay');if(o)o.style.display='none';startQuiz();});
	startQuiz();
</script>

<style>
	.quiz-container{display:flex;flex-direction:column;gap:1.5rem}
	.quiz-header{display:flex;align-items:center;gap:1.5rem;padding:1.25rem 1.75rem;flex-wrap:wrap}
	.btn-back{display:flex;align-items:center;gap:.45rem;color:var(--color-text-muted);text-decoration:none;font-size:.88rem;font-weight:500;white-space:nowrap;transition:color var(--transition-fast)}
	.btn-back:hover{color:var(--color-gold)} .btn-back svg{width:15px;height:15px}
	.quiz-title-area{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:.75rem;flex:1}
	.quiz-title-area h2{font-size:1.4rem;font-weight:800;color:var(--color-text)}
	.quiz-difficulty{font-size:.72rem;font-weight:700;padding:.28rem .75rem;border-radius:4px;text-transform:uppercase;letter-spacing:.5px}
	.quiz-difficulty.medium{background:rgba(27,77,50,.1);color:var(--color-primary-light);border:1px solid rgba(27,77,50,.2)}
	.quiz-layout{display:grid;grid-template-columns:1.9fr 1fr;gap:1.5rem;align-items:start}
	.quiz-main-card{padding:2rem;display:flex;flex-direction:column;gap:1.75rem}
	.progress-tracker{display:flex;flex-direction:column;gap:.5rem}
	.progress-label{display:flex;justify-content:space-between;align-items:center}
	.progress-label span{font-size:.82rem;font-weight:600;color:var(--color-text-muted)}
	.pct-label{color:var(--color-primary-light)!important}
	.progress-bar-outer{height:6px;background:rgba(27,77,50,.1);border-radius:var(--radius-full);overflow:hidden}
	.progress-bar-inner{height:100%;background:linear-gradient(90deg,#1b6b8a,#2eb8c8);border-radius:var(--radius-full);transition:width var(--transition-normal)}
	.cat-pill{display:inline-flex;align-items:center;gap:.35rem;background:rgba(27,107,138,.07);color:#1b6b8a;border:1px solid rgba(27,107,138,.18);padding:.28rem .75rem;border-radius:var(--radius-full);font-size:.75rem;font-weight:600}
	.question-text-area h3{font-size:1.1rem;font-weight:700;color:var(--color-text);line-height:1.55}
	.education-card{border-radius:var(--radius-md);padding:1rem 1.1rem;display:flex;flex-direction:column;gap:.5rem;animation:slide-in .2s ease}
	.education-card.correct{background:rgba(35,108,50,.07);border:1px solid rgba(35,108,50,.2)}
	.education-card.incorrect{background:rgba(165,48,26,.06);border:1px solid rgba(165,48,26,.18)}
	@keyframes slide-in{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:translateY(0)}}
	.edu-header{display:flex;align-items:center;gap:.45rem}
	.edu-icon{font-size:1rem}
	.edu-label{font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:#1b6b8a}
	.education-card.incorrect .edu-label{color:var(--color-danger)}
	#education-text{font-size:.85rem;color:var(--color-text);line-height:1.55}
	.action-footer{display:flex;align-items:center;justify-content:space-between;gap:1rem;padding-top:.5rem;border-top:1px solid var(--color-border)}
	.answer-hint{font-size:.8rem;color:var(--color-text-faint);font-style:italic}
	.answer-hint.chosen{color:var(--color-primary-light);font-style:normal;font-weight:600}
	.answer-hint.correct-hint{color:var(--color-success);font-style:normal;font-weight:600}
	.answer-hint.wrong-hint{color:var(--color-danger,#c0392b);font-style:normal;font-weight:600}
	#btn-submit-answer{padding:.8rem 2rem;border-radius:var(--radius-sm);font-size:.95rem;transition:all var(--transition-fast)}
	#btn-submit-answer:not(:disabled){box-shadow:0 4px 14px rgba(178,131,27,.3)}
	#btn-submit-answer:not(:disabled):hover{transform:translateY(-2px);box-shadow:0 6px 18px rgba(178,131,27,.4)}

	/* sidebar */
	.quiz-help-card{padding:1.5rem;display:flex;flex-direction:column;gap:1rem}
	.quiz-help-card h3{font-size:1.05rem;font-weight:700;color:var(--color-text)}
	.help-subtitle{font-size:.78rem;color:var(--color-text-muted);line-height:1.4;margin-top:-.5rem}
	.compass-grid{display:grid;grid-template-columns:1fr 1fr;gap:.3rem}
	.compass-item{display:flex;justify-content:space-between;align-items:center;padding:.3rem .6rem;border-radius:var(--radius-sm);border:1px solid var(--color-border);background:var(--color-bg)}
	.compass-item.main{border-left:3px solid #1b6b8a}
	.compass-item.sub{border-left:3px solid #7cc8d4;opacity:.85}
	.dir{font-size:.72rem;font-weight:700;color:var(--color-text)}
	.deg{font-size:.72rem;color:#1b6b8a;font-weight:700}
	.nav-formula-box{background:rgba(27,107,138,.05);border:1px solid var(--color-border);border-radius:var(--radius-sm);padding:.85rem;display:flex;flex-direction:column;gap:.5rem}
	.formula-row{display:flex;flex-direction:column;gap:.15rem;padding:.35rem 0;border-bottom:1px solid var(--color-border)}
	.formula-row:last-child{border-bottom:none}
	.formula-label{font-size:.7rem;font-weight:800;text-transform:uppercase;letter-spacing:.6px;color:#1b6b8a}
	.formula-val{font-size:.72rem;color:var(--color-text-muted);line-height:1.4}

	/* result */
	.result-overlay{position:fixed;inset:0;background:rgba(10,25,16,.88);backdrop-filter:blur(18px);-webkit-backdrop-filter:blur(18px);display:flex;align-items:center;justify-content:center;z-index:1000;padding:1.5rem}
	.result-card{width:100%;max-width:520px;padding:2.5rem;text-align:center;display:flex;flex-direction:column;align-items:center;gap:1.25rem;animation:pop-in .3s cubic-bezier(.34,1.56,.64,1)}
	@keyframes pop-in{from{transform:scale(.88);opacity:0}to{transform:scale(1);opacity:1}}
	.result-emoji{font-size:3.5rem;line-height:1}
	.result-card h2{font-size:1.75rem;font-weight:800;color:#f0f5f2}
	.result-summary{font-size:.95rem;color:rgba(255,255,255,.65);line-height:1.55}
	.result-stats-details{display:flex;width:100%;gap:.85rem}
	.detail-item{flex:1;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);padding:1rem;border-radius:var(--radius-md);display:flex;flex-direction:column;gap:.25rem}
	.detail-item .label{font-size:.72rem;color:rgba(255,255,255,.5);text-transform:uppercase;font-weight:600;letter-spacing:.5px}
	.detail-item .value{font-size:1.4rem;font-weight:800;color:#f0f5f2}
	.detail-item .value.score-xp{color:var(--color-gold-light)}
	.unlocked-badges-container{width:100%;background:rgba(212,163,43,.06);border:1px solid rgba(212,163,43,.25);border-radius:var(--radius-md);padding:1rem;text-align:left}
	.unlocked-badges-container h3{font-size:.9rem;font-weight:700;color:var(--color-gold-light);margin-bottom:.65rem}
	.unlocked-badges-list{display:flex;gap:.75rem;flex-wrap:wrap}
	.new-badge-item{display:flex;align-items:center;gap:.5rem;background:rgba(212,163,43,.1);border:1px solid rgba(212,163,43,.25);border-radius:var(--radius-sm);padding:.4rem .75rem}
	.new-badge-icon{font-size:1.1rem}
	.new-badge-name{font-size:.82rem;font-weight:700;color:var(--color-gold-light)}
	.result-actions{display:flex;gap:.85rem;flex-wrap:wrap;justify-content:center;width:100%}
	.result-actions .btn{flex:1;min-width:140px}

	@media(max-width:900px){.quiz-layout{grid-template-columns:1fr}.quiz-help-card{order:-1}.compass-grid{grid-template-columns:repeat(4,1fr)}}
	@media(max-width:600px){.quiz-main-card{padding:1.25rem}.quiz-header{padding:1rem}.compass-grid{grid-template-columns:repeat(2,1fr)}.result-stats-details{flex-wrap:wrap}.detail-item{flex-basis:calc(50% - .4rem)}}
</style>
