---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Kuis Tanda Pengenal Pramuka" description="Latihan tanda pengenal pramuka: golongan & usia, TKU (Mula–Bantu–Tata, Ramu–Rakit–Terap, Bantara–Laksana), TKK, satuan, dan seragam.">
	<div class="quiz-container">
		<header class="quiz-header glass-card">
			<a href="/" class="btn-back">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<line x1="19" y1="12" x2="5" y2="12"/>
					<polyline points="12 19 5 12 12 5"/>
				</svg>
				Kembali ke Dasbor
			</a>
			<div class="quiz-title-area">
				<h2>Kuis Tanda Pengenal Pramuka</h2>
				<span class="quiz-difficulty medium">Golongan, TKU, TKK &amp; Satuan</span>
			</div>
		</header>

		<div class="quiz-layout">
			<div class="quiz-main-card glass-card">
				<div class="progress-tracker">
					<div class="progress-label">
						<span id="question-number">Soal 1 dari 10</span>
						<span id="progress-pct" class="pct-label">10%</span>
					</div>
					<div class="progress-bar-outer">
						<div id="quiz-progress-bar" class="progress-bar-inner" style="width:10%"></div>
					</div>
				</div>
				<div class="question-category" id="question-category">
					<span class="cat-pill">🎗️ Tanda Pengenal</span>
				</div>
				<div class="question-text-area">
					<h3 id="question-prompt">Soal akan dimuat...</h3>
				</div>
				<div class="flex flex-col gap-2.5" id="options-container"></div>
				<div class="education-card" id="education-card" style="display:none;">
					<div class="edu-header">
						<span class="edu-icon">🎗️</span>
						<span class="edu-label">Penjelasan</span>
					</div>
					<p id="education-text"></p>
				</div>
				<div class="action-footer">
					<span id="answer-hint" class="answer-hint">Pilih salah satu jawaban di atas</span>
					<button id="btn-submit-answer" class="btn btn-gold" disabled>Konfirmasi Jawaban</button>
				</div>
			</div>

			<div class="quiz-help-card glass-card">
				<h3>📋 Referensi Tanda Pengenal</h3>
				<p class="help-subtitle">Golongan, TKU, TKK, Satuan &amp; Seragam Pramuka</p>

				<div class="tanda-section">
					<div class="tanda-title">Golongan &amp; TKU</div>
					<div class="tanda-item"><span class="tanda-key">Siaga (7-10 th)</span><span class="tanda-val">Mula → Bantu → Tata</span></div>
					<div class="tanda-item"><span class="tanda-key">Penggalang (11-15)</span><span class="tanda-val">Ramu → Rakit → Terap</span></div>
					<div class="tanda-item"><span class="tanda-key">Penegak (16-20)</span><span class="tanda-val">Bantara → Laksana</span></div>
					<div class="tanda-item"><span class="tanda-key">Pandega (21-25)</span><span class="tanda-val">Pandega → Garuda</span></div>
				</div>

				<div class="tanda-section">
					<div class="tanda-title">Bentuk &amp; Tingkat TKK</div>
					<div class="tanda-item"><span class="tanda-key">Siaga</span><span class="tanda-val">Segitiga sama sisi</span></div>
					<div class="tanda-item"><span class="tanda-key">Penggalang</span><span class="tanda-val">Persegi / bujur sangkar</span></div>
					<div class="tanda-item"><span class="tanda-key">Penegak/Pandega</span><span class="tanda-val">Lingkaran</span></div>
					<div class="tanda-item"><span class="tanda-key">Tingkat Purwa</span><span class="tanda-val">Warna Putih</span></div>
					<div class="tanda-item"><span class="tanda-key">Tingkat Madya</span><span class="tanda-val">Warna Kuning</span></div>
					<div class="tanda-item"><span class="tanda-key">Tingkat Utama</span><span class="tanda-val">Warna Merah</span></div>
				</div>

				<div class="tanda-section">
					<div class="tanda-title">Satuan Terkecil</div>
					<div class="tanda-item"><span class="tanda-key">Siaga</span><span class="tanda-val">Barung → Perindukan</span></div>
					<div class="tanda-item"><span class="tanda-key">Penggalang</span><span class="tanda-val">Regu → Pasukan</span></div>
					<div class="tanda-item"><span class="tanda-key">Penegak</span><span class="tanda-val">Sangga → Ambalan</span></div>
					<div class="tanda-item"><span class="tanda-key">Pandega</span><span class="tanda-val">Reka → Racana</span></div>
				</div>

				<div class="tanda-section">
					<div class="tanda-title">Posisi Tanda di Seragam</div>
					<div class="tanda-item"><span class="tanda-key">Lengan kiri</span><span class="tanda-val">TKU &amp; tanda satuan</span></div>
					<div class="tanda-item"><span class="tanda-key">Lengan kanan</span><span class="tanda-val">TKK</span></div>
					<div class="tanda-item"><span class="tanda-key">Dada kiri</span><span class="tanda-val">Tanda jabatan &amp; nama</span></div>
					<div class="tanda-item"><span class="tanda-key">Bahu kiri</span><span class="tanda-val">Tanda daerah / kwartir</span></div>
				</div>
			</div>
		</div>

		<div class="result-overlay" id="result-overlay" style="display:none;">
			<div class="result-card glass-card">
				<div class="result-emoji" id="result-emoji">🏆</div>
				<h2 id="result-title">Kuis Selesai!</h2>
				<p class="result-summary" id="result-text"></p>
				<div class="result-stats-details">
					<div class="detail-item"><span class="label">XP Diperoleh</span><span class="value score-xp" id="result-xp">+0 XP</span></div>
					<div class="detail-item"><span class="label">Skor Akhir</span><span class="value" id="result-score">0/100</span></div>
					<div class="detail-item"><span class="label">Jawaban Benar</span><span class="value" id="result-correct">0/10</span></div>
				</div>
				<div class="unlocked-badges-container" id="unlocked-badges" style="display:none;">
					<h3>🎖️ Lencana Baru Terbuka!</h3>
					<div class="unlocked-badges-list" id="badges-list-el"></div>
				</div>
				<div class="result-actions">
					<button id="btn-restart" class="btn btn-primary">Ulangi Kuis</button>
					<a href="/" class="btn btn-gold">Kembali ke Dasbor</a>
				</div>
			</div>
		</div>
	</div>
</Layout>

<script>
	interface Question { kategori:string; q:string; options:string[]; correct:string; edu:string; }

	const QUESTIONS_POOL: Question[] = [
		{ kategori:"Golongan Siaga", q:"Pramuka Siaga adalah anggota Pramuka yang berusia...", options:["7-10 tahun","11-15 tahun","6-8 tahun","10-12 tahun"], correct:"7-10 tahun", edu:"Pramuka Siaga adalah golongan Pramuka untuk anak usia 7-10 tahun. Satuan terkecilnya disebut Barung, dan beberapa Barung membentuk Perindukan." },
		{ kategori:"Golongan Penggalang", q:"Pramuka Penggalang adalah anggota Pramuka yang berusia...", options:["11-15 tahun","7-10 tahun","16-20 tahun","10-12 tahun"], correct:"11-15 tahun", edu:"Pramuka Penggalang adalah golongan untuk usia 11-15 tahun. Nama 'Penggalang' mencerminkan semangat menggalang persatuan. Satuan terkecilnya disebut Regu." },
		{ kategori:"Golongan Penegak", q:"Pramuka Penegak adalah anggota Pramuka yang berusia...", options:["16-20 tahun","11-15 tahun","21-25 tahun","18-22 tahun"], correct:"16-20 tahun", edu:"Pramuka Penegak adalah golongan untuk usia 16-20 tahun. Nama 'Penegak' mencerminkan semangat menegakkan dan mempertahankan kemerdekaan Indonesia. Satuan terkecilnya Sangga." },
		{ kategori:"Golongan Pandega", q:"Pramuka Pandega adalah anggota Pramuka yang berusia...", options:["21-25 tahun","16-20 tahun","25-30 tahun","18-25 tahun"], correct:"21-25 tahun", edu:"Pramuka Pandega adalah golongan untuk usia 21-25 tahun (umumnya mahasiswa/pemuda dewasa). 'Pandega' berasal dari kata Jawa kuno yang berarti pemimpin atau pakar." },
		{ kategori:"TKU Siaga", q:"Urutan tingkat TKU Pramuka Siaga dari terendah ke tertinggi adalah...", options:["Siaga Mula → Siaga Bantu → Siaga Tata","Siaga Tata → Siaga Bantu → Siaga Mula","Siaga Ramu → Siaga Rakit → Siaga Terap","Siaga Bantara → Siaga Laksana → Siaga Garuda"], correct:"Siaga Mula → Siaga Bantu → Siaga Tata", edu:"TKU Siaga: Siaga Mula (tingkat pertama/terendah) → Siaga Bantu → Siaga Tata (tertinggi dalam golongan Siaga, sebelum naik ke golongan Penggalang)." },
		{ kategori:"TKU Penggalang", q:"Urutan tingkat TKU Pramuka Penggalang dari terendah ke tertinggi adalah...", options:["Penggalang Ramu → Penggalang Rakit → Penggalang Terap","Penggalang Terap → Penggalang Rakit → Penggalang Ramu","Penggalang Bantara → Penggalang Laksana","Penggalang Mula → Penggalang Bantu → Penggalang Tata"], correct:"Penggalang Ramu → Penggalang Rakit → Penggalang Terap", edu:"TKU Penggalang: Ramu (pertama) → Rakit → Terap (tertinggi). Setelah Terap, Penggalang berprestasi dapat meraih gelar Pramuka Garuda sebagai pencapaian puncak." },
		{ kategori:"TKU Penegak", q:"Urutan tingkat TKU Pramuka Penegak dari terendah ke tertinggi adalah...", options:["Penegak Bantara → Penegak Laksana","Penegak Laksana → Penegak Bantara","Penegak Ramu → Penegak Rakit → Penegak Terap","Penegak Mula → Penegak Bantu → Penegak Tata"], correct:"Penegak Bantara → Penegak Laksana", edu:"TKU Penegak hanya terdiri dari dua tingkat: Penegak Bantara (pertama) → Penegak Laksana. Setelah Laksana, dapat meraih gelar Pramuka Garuda sebagai puncak pencapaian." },
		{ kategori:"Pramuka Garuda", q:"Pramuka Garuda adalah predikat yang diberikan kepada Pramuka yang...", options:["Berhasil memenuhi semua syarat TKU tertinggi beserta persyaratan tambahan Garuda","Mengikuti Jambore Nasional","Berusia paling tua dalam satuan","Mendapat nilai terbaik dalam ujian tertulis tahunan"], correct:"Berhasil memenuhi semua syarat TKU tertinggi beserta persyaratan tambahan Garuda", edu:"Pramuka Garuda adalah pencapaian tertinggi di setiap golongan. Syaratnya: menyelesaikan TKU tertinggi + memiliki TKK tertentu + aktif bermasyarakat + lulus uji kecakapan khusus Garuda." },
		{ kategori:"TKK", q:"TKK adalah singkatan dari...", options:["Tanda Kecakapan Khusus","Tanda Kepanduan Khusus","Tingkat Kecakapan Kepramukaan","Tanda Keahlian Kepramukaan"], correct:"Tanda Kecakapan Khusus", edu:"TKK (Tanda Kecakapan Khusus) adalah tanda yang diperoleh setelah menyelesaikan syarat kecakapan di bidang tertentu seperti memasak, P3K, pertanian, atau kerajinan. TKK bersifat pilihan." },
		{ kategori:"TKK", q:"Bentuk TKK untuk Pramuka Siaga adalah...", options:["Segitiga sama sisi","Lingkaran","Persegi/bujur sangkar","Belah ketupat"], correct:"Segitiga sama sisi", edu:"Bentuk TKK berbeda per golongan: Siaga = segitiga sama sisi, Penggalang = persegi/bujur sangkar, Penegak & Pandega = lingkaran. Perbedaan bentuk ini memudahkan identifikasi golongan." },
		{ kategori:"TKK", q:"Bentuk TKK untuk Pramuka Penggalang adalah...", options:["Persegi/bujur sangkar","Segitiga sama sisi","Lingkaran","Oval"], correct:"Persegi/bujur sangkar", edu:"TKK Penggalang berbentuk persegi (bujur sangkar). TKK Siaga = segitiga, TKK Penggalang = persegi, TKK Penegak/Pandega = lingkaran. Ukuran TKK persegi biasanya 4×4 cm." },
		{ kategori:"TKK", q:"Bentuk TKK untuk Pramuka Penegak dan Pandega adalah...", options:["Lingkaran","Segitiga sama sisi","Persegi","Belah ketupat"], correct:"Lingkaran", edu:"TKK Penegak dan Pandega berbentuk lingkaran, berbeda dari Siaga (segitiga) dan Penggalang (persegi). Diameter TKK lingkaran Penegak/Pandega biasanya sekitar 4 cm." },
		{ kategori:"TKK", q:"Warna latar belakang TKK tingkat Utama (tingkat tertinggi TKK) adalah...", options:["Merah","Putih","Kuning","Hijau"], correct:"Merah", edu:"Tingkat TKK: Purwa (putih/perak, pertama) → Madya (kuning/emas) → Utama (merah, tertinggi). Tingkat Utama adalah yang paling tinggi, disimbolkan warna merah yang mencolok." },
		{ kategori:"Satuan Siaga", q:"Satuan terkecil dalam Pramuka Siaga disebut...", options:["Barung","Regu","Sangga","Reka"], correct:"Barung", edu:"Barung adalah satuan terkecil Pramuka Siaga, beranggotakan 5-10 anak, diberi nama warna (Barung Merah, Kuning, dll.). Beberapa Barung membentuk Perindukan Pramuka Siaga." },
		{ kategori:"Satuan Penggalang", q:"Satuan terkecil dalam Pramuka Penggalang disebut...", options:["Regu","Barung","Sangga","Reka"], correct:"Regu", edu:"Regu adalah satuan terkecil Pramuka Penggalang, beranggotakan 5-10 orang, dipimpin Pemimpin Regu. Biasanya diberi nama hewan. Beberapa Regu membentuk Pasukan Penggalang." },
		{ kategori:"Satuan Penegak", q:"Satuan terkecil dalam Pramuka Penegak disebut...", options:["Sangga","Regu","Barung","Reka"], correct:"Sangga", edu:"Sangga adalah satuan terkecil Pramuka Penegak, beranggotakan 5-10 orang. Biasanya diberi nama nilai/sifat. Beberapa Sangga bergabung membentuk Ambalan Pramuka Penegak." },
		{ kategori:"Satuan Pandega", q:"Satuan terkecil dalam Pramuka Pandega disebut...", options:["Reka","Barung","Regu","Sangga"], correct:"Reka", edu:"Reka adalah satuan terkecil Pramuka Pandega. Beberapa Reka bergabung membentuk Racana Pramuka Pandega. Pembina Pandega umumnya berasal dari kalangan perguruan tinggi." },
		{ kategori:"Satuan Penggalang", q:"Beberapa Regu Penggalang yang bergabung membentuk satuan yang disebut...", options:["Pasukan","Perindukan","Ambalan","Racana"], correct:"Pasukan", edu:"Pasukan adalah satuan Penggalang yang terdiri dari beberapa Regu (biasanya 2-4 Regu). Dipimpin Pemimpin Pasukan (Pratama) dan dibina oleh Pembina Penggalang." },
		{ kategori:"Satuan Penegak", q:"Beberapa Sangga Penegak yang bergabung membentuk satuan yang disebut...", options:["Ambalan","Pasukan","Perindukan","Racana"], correct:"Ambalan", edu:"Ambalan adalah satuan Penegak yang terdiri dari beberapa Sangga (biasanya 2-4 Sangga). Biasanya diberi nama pahlawan. Dipimpin Pradana dan dibina Pembina Penegak." },
		{ kategori:"Satuan Siaga", q:"Beberapa Barung Siaga yang bergabung membentuk satuan yang disebut...", options:["Perindukan","Pasukan","Ambalan","Racana"], correct:"Perindukan", edu:"Perindukan adalah satuan Siaga yang terdiri dari beberapa Barung (biasanya 2-4 Barung). Dipimpin Pimpinan Perindukan dan dibina Pembina Siaga. Beberapa Perindukan membentuk Gugus Depan." },
		{ kategori:"Lambang", q:"Lambang Gerakan Pramuka Indonesia adalah...", options:["Tunas kelapa","Pohon beringin","Bintang dan bulan","Garuda Pancasila"], correct:"Tunas kelapa", edu:"Lambang Gerakan Pramuka adalah 'Tunas Kelapa' (siluet tunas/cikal kelapa) yang diciptakan Bapak Sunardjo Atmodipuro. Tunas kelapa melambangkan Pramuka yang serba guna dan tumbuh berkembang." },
		{ kategori:"Seragam", q:"Warna seragam resmi Pramuka Indonesia adalah...", options:["Cokelat muda (khaki)","Hijau tua","Biru dongker","Abu-abu"], correct:"Cokelat muda (khaki)", edu:"Seragam Pramuka Indonesia berwarna cokelat muda/khaki, digunakan oleh semua golongan (Siaga, Penggalang, Penegak, Pandega). Warna cokelat mencerminkan kedekatan dengan alam." },
		{ kategori:"Gugus Depan", q:"Nomor gugus depan untuk putra menggunakan nomor...", options:["Ganjil","Genap","Bebas tanpa ketentuan","Selalu tiga digit"], correct:"Ganjil", edu:"Gugus depan putra menggunakan nomor ganjil (1, 3, 5, 7, dst.), sedangkan gugus depan putri menggunakan nomor genap (2, 4, 6, 8, dst.). Ketentuan ini berlaku secara nasional di Indonesia." },
		{ kategori:"Posisi Tanda", q:"TKU pada seragam Pramuka dikenakan di...", options:["Lengan kiri atas","Lengan kanan atas","Saku kiri dada","Kerah seragam"], correct:"Lengan kiri atas", edu:"TKU dikenakan di lengan kiri bagian atas. TKK di lengan kanan. Tanda jabatan dan nama di dada kiri. Tanda daerah/kwartir di bahu kiri. Ini adalah penempatan standar nasional." },
		{ kategori:"Posisi Tanda", q:"TKK pada seragam Pramuka dikenakan di...", options:["Lengan kanan","Lengan kiri","Saku kiri","Saku kanan"], correct:"Lengan kanan", edu:"TKK (Tanda Kecakapan Khusus) dikenakan di lengan kanan seragam. TKU di lengan kiri, tanda jabatan di dada kiri, tanda daerah di bahu kiri. Penempatan ini memudahkan identifikasi pencapaian." },
		{ kategori:"Tanda Jabatan", q:"Tanda yang menunjukkan posisi atau fungsi seseorang dalam organisasi Pramuka disebut...", options:["Tanda jabatan","Tanda satuan","TKK","Tanda penghargaan"], correct:"Tanda jabatan", edu:"Tanda jabatan (position badge) menunjukkan peran dalam organisasi: Pemimpin Regu, Pradana, Pembina, Pelatih, Andalan, dll. Berbeda dari TKU yang menunjukkan kecakapan umum." },
		{ kategori:"Tanda Satuan", q:"Tanda yang menunjukkan identitas gugus depan atau kwartir asal Pramuka disebut...", options:["Tanda satuan","Tanda jabatan","TKU","Tanda pelantikan"], correct:"Tanda satuan", edu:"Tanda satuan menunjukkan identitas gugus depan (nomor gugusdepan) atau kwartir (provinsi/kabupaten/kota) tempat Pramuka tersebut terdaftar. Dikenakan di lengan kiri bersama TKU." },
		{ kategori:"Seragam", q:"Hasduk (dasi pramuka) berbentuk...", options:["Segitiga","Persegi panjang","Lingkaran","Oval"], correct:"Segitiga", edu:"Hasduk (neckerchief) Pramuka berbentuk segitiga sama kaki yang dilipat dan dikenakan di leher. Warna hasduk bervariasi antar kwartir; warna merah-putih digunakan pada tingkat nasional." },
		{ kategori:"Pelantikan", q:"Yang dimaksud dengan pelantikan (investiture) dalam kepramukaan adalah...", options:["Upacara resmi pengangkatan seseorang menjadi anggota Pramuka atau naik tingkat TKU","Ujian tulis tentang pengetahuan kepramukaan","Kegiatan perkemahan yang wajib dilakukan setahun sekali","Pemberian tugas khusus oleh Pembina selama satu bulan"], correct:"Upacara resmi pengangkatan seseorang menjadi anggota Pramuka atau naik tingkat TKU", edu:"Pelantikan adalah upacara formal yang menandai masuknya seseorang ke keanggotaan Pramuka atau kenaikan tingkat TKU-nya, dilakukan dengan ikrar/janji dan ditandai dengan penyematan tanda." },
		{ kategori:"Gugus Depan", q:"Gugus depan lengkap dalam kepramukaan adalah gugus depan yang memiliki satuan...", options:["Siaga, Penggalang, Penegak, dan Pandega","Hanya Penggalang dan Penegak","Hanya Siaga dan Penggalang","Penggalang, Penegak, dan Pandega saja"], correct:"Siaga, Penggalang, Penegak, dan Pandega", edu:"Gugus depan lengkap memiliki semua empat golongan: Siaga (7-10 th), Penggalang (11-15 th), Penegak (16-20 th), dan Pandega (21-25 th). Ini ideal untuk pembinaan kepramukaan yang berkelanjutan." },
	];

	const XP_PER_CORRECT = 12;
	const QUESTIONS_PER_SESSION = 10;
	const BADGES_FOR_THIS_QUIZ = [
		{ id:'tanda_novice', name:'Pandu Berpengenal', icon:'🎗️' },
		{ id:'tanda_master', name:'Ahli Tanda Pengenal', icon:'🏵️' },
	];

	let questions:Question[]=[], currentIndex=0, selectedAnswer='', score=0, totalXpEarned=0;

	function shuffle<T>(arr:T[]):T[]{return [...arr].sort(()=>Math.random()-.5);}
	function getEl<T extends HTMLElement>(id:string){return document.getElementById(id) as T|null;}

	function startQuiz(){questions=shuffle(QUESTIONS_POOL).slice(0,QUESTIONS_PER_SESSION);currentIndex=0;score=0;totalXpEarned=0;selectedAnswer='';renderQuestion();}

	function renderQuestion(){
		const q=questions[currentIndex],num=currentIndex+1,pct=(num/QUESTIONS_PER_SESSION)*100;
		getEl('question-number')!.textContent=`Soal ${num} dari ${QUESTIONS_PER_SESSION}`;
		(getEl('progress-pct') as HTMLElement).textContent=`${Math.round(pct)}%`;
		getEl<HTMLDivElement>('quiz-progress-bar')!.style.width=`${pct}%`;
		const catEl=getEl('question-category');if(catEl)catEl.innerHTML=`<span class="cat-pill">🎗️ ${q.kategori}</span>`;
		getEl('question-prompt')!.textContent=q.q;
		const eduCard=getEl<HTMLDivElement>('education-card');if(eduCard)eduCard.style.display='none';
		const submitBtn=getEl<HTMLButtonElement>('btn-submit-answer');
		if(submitBtn){submitBtn.disabled=true;submitBtn.textContent='Konfirmasi Jawaban';submitBtn.onclick=submitAnswer;}
		const hint=getEl('answer-hint');if(hint){hint.textContent='Pilih salah satu jawaban di atas';hint.className='answer-hint';}
		selectedAnswer='';renderOptions(q);
	}

	function renderOptions(q:Question){
		const container=getEl<HTMLDivElement>('options-container');if(!container)return;
		container.innerHTML=shuffle(q.options).map((opt,i)=>{
			const letter=String.fromCharCode(65+i);
			return `<button class="opt-btn" data-answer="${opt.replace(/"/g,'&quot;')}" style="animation-delay:${i*.07}s">
				<span class="opt-letter">${letter}</span><span class="opt-text">${opt}</span>
				<span class="opt-indicator"><span class="opt-radio"></span>
				<svg class="opt-icon icon-check" viewBox="0 0 24 24" fill="none" stroke="#236c32" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
				<svg class="opt-icon icon-cross" viewBox="0 0 24 24" fill="none" stroke="#a5301a" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
				</span></button>`;
		}).join('');
		container.querySelectorAll('.opt-btn').forEach((btn,i)=>{
			btn.addEventListener('click',()=>{
				container.querySelectorAll('.opt-btn').forEach(b=>b.classList.remove('is-selected'));
				btn.classList.add('is-selected');selectedAnswer=(btn as HTMLElement).dataset.answer||'';
				const s=getEl<HTMLButtonElement>('btn-submit-answer');if(s)s.disabled=false;
				const h=getEl('answer-hint');if(h){h.textContent=`Jawaban ${String.fromCharCode(65+i)} dipilih — klik Konfirmasi untuk lanjut`;h.className='answer-hint chosen';}
			});
		});
	}

	function submitAnswer(){
		const q=questions[currentIndex],isCorrect=selectedAnswer===q.correct;
		if(isCorrect){score++;totalXpEarned+=XP_PER_CORRECT;}
		const container=getEl<HTMLDivElement>('options-container');
		container?.querySelectorAll('.opt-btn').forEach(btn=>{
			const el=btn as HTMLElement,ans=el.dataset.answer||'';
			el.classList.add('is-answered');el.classList.remove('is-selected');
			if(ans===q.correct)el.classList.add('is-correct');
			else if(ans===selectedAnswer&&!isCorrect)el.classList.add('is-incorrect');
			else el.classList.add('is-dimmed');
		});
		const eduCard=getEl<HTMLDivElement>('education-card'),eduText=getEl('education-text');
		if(eduCard&&eduText){eduText.textContent=q.edu;eduCard.style.display='flex';eduCard.className=`education-card ${isCorrect?'correct':'incorrect'}`;}
		const hint=getEl('answer-hint');if(hint){hint.textContent=isCorrect?'✓ Jawaban benar!':'✗ Jawaban salah — lihat penjelasan di bawah.';hint.className=`answer-hint ${isCorrect?'correct-hint':'wrong-hint'}`;}
		const submitBtn=getEl<HTMLButtonElement>('btn-submit-answer');
		if(submitBtn){submitBtn.textContent=currentIndex<QUESTIONS_PER_SESSION-1?'Soal Berikutnya →':'Lihat Hasil';submitBtn.disabled=false;submitBtn.onclick=nextQuestion;}
	}

	function nextQuestion(){
		currentIndex++;
		if(currentIndex<QUESTIONS_PER_SESSION){renderQuestion();const s=getEl<HTMLButtonElement>('btn-submit-answer');if(s)s.onclick=submitAnswer;}
		else showResult();
	}

	function showResult(){
		const pct=Math.round((score/QUESTIONS_PER_SESSION)*100);
		const currentXp=parseInt(localStorage.getItem('scout_xp')||'0');
		localStorage.setItem('scout_xp',(currentXp+totalXpEarned).toString());
		const earnedBadges:string[]=JSON.parse(localStorage.getItem('scout_badges')||'[]');
		const newlyUnlocked:typeof BADGES_FOR_THIS_QUIZ=[];
		if(!earnedBadges.includes('tanda_novice')){earnedBadges.push('tanda_novice');newlyUnlocked.push(BADGES_FOR_THIS_QUIZ[0]);}
		if(pct===100&&!earnedBadges.includes('tanda_master')){earnedBadges.push('tanda_master');newlyUnlocked.push(BADGES_FOR_THIS_QUIZ[1]);}
		if(parseInt(localStorage.getItem('scout_xp')||'0')>=500&&!earnedBadges.includes('scout_master'))earnedBadges.push('scout_master');
		localStorage.setItem('scout_badges',JSON.stringify(earnedBadges));
		getEl('result-emoji')!.textContent=pct===100?'🏆':pct>=80?'⭐':pct>=60?'👍':'📚';
		const t=getEl('result-title');if(t)t.textContent=pct===100?'Sempurna! Ahli Tanda Pengenal!':pct>=80?'Bagus Sekali!':pct>=60?'Cukup Baik!':'Terus Belajar!';
		getEl('result-text')!.textContent=`Kamu menjawab ${score} dari ${QUESTIONS_PER_SESSION} soal dengan benar (${pct}%). ${pct>=80?'Kamu menguasai tanda pengenal dan golongan Pramuka dengan baik!':'Pelajari kembali urutan TKU, bentuk TKK, dan satuan di setiap golongan.'}`;
		getEl('result-xp')!.textContent=`+${totalXpEarned} XP`;
		getEl('result-score')!.textContent=`${pct}/100`;
		getEl('result-correct')!.textContent=`${score}/${QUESTIONS_PER_SESSION}`;
		if(newlyUnlocked.length>0){
			const bc=getEl<HTMLDivElement>('unlocked-badges'),bl=getEl('badges-list-el');
			if(bc&&bl){bl.innerHTML=newlyUnlocked.map(b=>`<div class="new-badge-item"><span class="new-badge-icon">${b.icon}</span><span class="new-badge-name">${b.name}</span></div>`).join('');bc.style.display='block';}
		}
		const overlay=getEl<HTMLDivElement>('result-overlay');if(overlay)overlay.style.display='flex';
		window.dispatchEvent(new Event('statsUpdated'));
	}

	getEl<HTMLButtonElement>('btn-submit-answer')?.addEventListener('click',submitAnswer);
	getEl<HTMLButtonElement>('btn-restart')?.addEventListener('click',()=>{const o=getEl<HTMLDivElement>('result-overlay');if(o)o.style.display='none';startQuiz();});
	startQuiz();
</script>

<style>
