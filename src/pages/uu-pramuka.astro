---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Kuis UU Pramuka No. 12 Tahun 2010" description="Latihan Undang-Undang Gerakan Pramuka No. 12 Tahun 2010: asas, tujuan, keanggotaan, kwartir, dan pendidikan kepramukaan. 30 soal acak.">
	<div class="quiz-container">
		<header class="quiz-header glass-card">
			<a href="/" class="btn-back">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<line x1="19" y1="12" x2="5" y2="12"/>
					<polyline points="12 19 5 12 12 5"/>
				</svg>
				Kembali ke Dasbor
			</a>
			<div class="quiz-title-area">
				<h2>Kuis UU No. 12 Tahun 2010</h2>
				<span class="quiz-difficulty medium">Hukum Kepramukaan</span>
			</div>
		</header>

		<div class="quiz-layout">
			<!-- Main Quiz Card -->
			<div class="quiz-main-card glass-card">
				<!-- Progress Tracker -->
				<div class="progress-tracker">
					<div class="progress-label">
						<span id="question-number">Soal 1 dari 10</span>
						<span id="progress-pct" class="pct-label">10%</span>
					</div>
					<div class="progress-bar-outer">
						<div id="quiz-progress-bar" class="progress-bar-inner" style="width: 10%"></div>
					</div>
				</div>

				<!-- Category Badge -->
				<div class="question-category" id="question-category">
					<span class="cat-pill">📜 UU No. 12 Tahun 2010</span>
				</div>

				<!-- Question -->
				<div class="question-text-area">
					<h3 id="question-prompt">Soal akan dimuat...</h3>
				</div>

				<!-- Options -->
				<div class="flex flex-col gap-2.5" id="options-container">
					<!-- dibuat oleh JavaScript -->
				</div>

				<!-- Education Card -->
				<div class="education-card" id="education-card" style="display: none;">
					<div class="edu-header">
						<span class="edu-icon">📖</span>
						<span class="edu-label">Penjelasan Pasal</span>
					</div>
					<p id="education-text"></p>
				</div>

				<!-- Actions -->
				<div class="action-footer">
					<span id="answer-hint" class="answer-hint">Pilih salah satu jawaban di atas</span>
					<button id="btn-submit-answer" class="btn btn-gold" disabled>Konfirmasi Jawaban</button>
				</div>
			</div>

			<!-- Reference Sidebar -->
			<div class="quiz-help-card glass-card">
				<h3>Struktur UU No. 12/2010</h3>
				<p class="help-subtitle">Undang-Undang Republik Indonesia tentang Gerakan Pramuka</p>

				<div class="law-structure">
					<div class="law-chapter">
						<div class="chapter-title">Bab I — Ketentuan Umum</div>
						<div class="chapter-content">Pasal 1: Definisi Pramuka, Gerakan Pramuka, Pendidikan Kepramukaan</div>
					</div>
					<div class="law-chapter">
						<div class="chapter-title">Bab II — Asas, Nilai & Tujuan</div>
						<div class="chapter-content">Ps. 2: Asas Pancasila · Ps. 3: Nilai · Ps. 4: Fungsi · Ps. 5: Tujuan · Ps. 6: Sifat</div>
					</div>
					<div class="law-chapter">
						<div class="chapter-title">Bab III — Penyelenggaraan</div>
						<div class="chapter-content">Ps. 7-16: Organisasi, Kwartir (Ranting, Cabang, Daerah, Nasional), Gugus Depan, Saka</div>
					</div>
					<div class="law-chapter">
						<div class="chapter-title">Bab IV — Keanggotaan</div>
						<div class="chapter-content">Ps. 17-25: Siaga, Penggalang, Penegak, Pandega, Anggota Dewasa, Hak & Kewajiban</div>
					</div>
					<div class="law-chapter">
						<div class="chapter-title">Bab V — Pendidikan</div>
						<div class="chapter-content">Ps. 26-45: Kurikulum, Kode Kehormatan, Metode, SKU, SKK, SPG</div>
					</div>
					<div class="law-chapter">
						<div class="chapter-title">Bab VI-IX — Lain-lain</div>
						<div class="chapter-content">Pendanaan · Pengawasan · Sanksi Administratif · Ketentuan Peralihan</div>
					</div>
				</div>

				<div class="law-fact-box">
					<div class="fact-row">
						<span class="fact-key">Disahkan</span>
						<span class="fact-val">24 November 2010</span>
					</div>
					<div class="fact-row">
						<span class="fact-key">Pasal</span>
						<span class="fact-val">50 Pasal</span>
					</div>
					<div class="fact-row">
						<span class="fact-key">Asas</span>
						<span class="fact-val">Pancasila</span>
					</div>
					<div class="fact-row">
						<span class="fact-key">Sifat</span>
						<span class="fact-val">Mandiri · Sukarela · Nonpolitik</span>
					</div>
				</div>
			</div>
		</div>

		<!-- Result Overlay -->
		<div class="result-overlay" id="result-overlay" style="display: none;">
			<div class="result-card glass-card">
				<div class="result-emoji" id="result-emoji">🏆</div>
				<h2 id="result-title">Kuis Selesai!</h2>
				<p class="result-summary" id="result-text">Anda menjawab soal dengan baik.</p>

				<div class="result-stats-details">
					<div class="detail-item">
						<span class="label">XP Diperoleh</span>
						<span class="value score-xp" id="result-xp">+100 XP</span>
					</div>
					<div class="detail-item">
						<span class="label">Skor Akhir</span>
						<span class="value" id="result-score">100/100</span>
					</div>
					<div class="detail-item">
						<span class="label">Jawaban Benar</span>
						<span class="value" id="result-correct">10/10</span>
					</div>
				</div>

				<div class="unlocked-badges-container" id="unlocked-badges" style="display: none;">
					<h3>🎖️ Lencana Baru Terbuka!</h3>
					<div class="unlocked-badges-list" id="badges-list-el"></div>
				</div>

				<div class="result-actions">
					<button id="btn-restart" class="btn btn-primary">Ulangi Kuis</button>
					<a href="/" class="btn btn-gold">Kembali ke Dasbor</a>
				</div>
			</div>
		</div>
	</div>
</Layout>

<script>
	// ─── Bank Soal (30 soal, pilih 10 acak per sesi) ──────────────────────────

	interface Question {
		pasal: string;
		q: string;
		options: string[];
		correct: string;
		edu: string;
	}

	const QUESTIONS_POOL: Question[] = [
		{
			pasal: "Pasal 1 Ayat (1)",
			q: "Menurut UU No. 12 Tahun 2010, 'Gerakan Pramuka' adalah...",
			options: [
				"Perkumpulan pemuda Indonesia yang bersifat militer",
				"Organisasi yang dibentuk oleh pramuka untuk menyelenggarakan pendidikan kepramukaan",
				"Lembaga pemerintah yang bertugas melatih pemuda",
				"Yayasan pendidikan luar sekolah milik negara"
			],
			correct: "Organisasi yang dibentuk oleh pramuka untuk menyelenggarakan pendidikan kepramukaan",
			edu: "Pasal 1 Ayat (1): Gerakan Pramuka adalah organisasi yang dibentuk oleh pramuka untuk menyelenggarakan pendidikan kepramukaan. Ini menegaskan bahwa Gerakan Pramuka bukan lembaga pemerintah, melainkan organisasi mandiri yang dibentuk oleh anggotanya sendiri."
		},
		{
			pasal: "Pasal 1 Ayat (2)",
			q: "Definisi 'Pramuka' menurut UU No. 12 Tahun 2010 adalah...",
			options: [
				"Siswa sekolah yang mengikuti kegiatan pramuka",
				"Pegawai negeri yang bertugas melatih kepramukaan",
				"Warga negara Indonesia yang aktif dalam pendidikan kepramukaan serta mengamalkan Satya Pramuka dan Darma Pramuka",
				"Pemuda Indonesia berusia di bawah 25 tahun yang terdaftar di Kwartir Nasional"
			],
			correct: "Warga negara Indonesia yang aktif dalam pendidikan kepramukaan serta mengamalkan Satya Pramuka dan Darma Pramuka",
			edu: "Pasal 1 Ayat (2): Pramuka adalah warga negara Indonesia yang aktif dalam pendidikan kepramukaan serta mengamalkan Satya Pramuka dan Darma Pramuka. Definisi ini mencakup semua golongan, tidak hanya siswa."
		},
		{
			pasal: "Pasal 2",
			q: "Gerakan Pramuka berasaskan...",
			options: [
				"Undang-Undang Dasar 1945",
				"Bhinneka Tunggal Ika",
				"Pancasila",
				"Kode Kehormatan Pramuka"
			],
			correct: "Pancasila",
			edu: "Pasal 2: Gerakan Pramuka berasaskan Pancasila. Pancasila sebagai asas berarti seluruh kegiatan dan nilai kepramukaan berlandaskan pada lima sila Pancasila."
		},
		{
			pasal: "Pasal 6",
			q: "Gerakan Pramuka bersifat...",
			options: [
				"Militer, sukarela, dan terbuka",
				"Mandiri, sukarela, dan nonpolitik",
				"Bebas, aktif, dan demokratis",
				"Nasional, terbuka, dan profesional"
			],
			correct: "Mandiri, sukarela, dan nonpolitik",
			edu: "Pasal 6: Gerakan Pramuka bersifat mandiri, sukarela, dan nonpolitik. Mandiri berarti tidak berada di bawah partai politik manapun. Sukarela berarti keanggotaan tidak dipaksakan. Nonpolitik berarti tidak terlibat dalam politik praktis."
		},
		{
			pasal: "Pasal 5",
			q: "Tujuan Gerakan Pramuka adalah membentuk setiap pramuka agar memiliki...",
			options: [
				"Kemampuan militer yang kuat dan jiwa patriotik",
				"Kepribadian yang beriman, bertakwa, berakhlak mulia, berjiwa patriotik, dan memiliki kecakapan hidup",
				"Keterampilan akademis yang tinggi dan prestasi internasional",
				"Kemampuan olahraga dan seni yang unggul"
			],
			correct: "Kepribadian yang beriman, bertakwa, berakhlak mulia, berjiwa patriotik, dan memiliki kecakapan hidup",
			edu: "Pasal 5: Gerakan Pramuka bertujuan membentuk pramuka agar beriman, bertakwa, berakhlak mulia, berjiwa patriotik, taat hukum, disiplin, menjunjung nilai luhur bangsa, dan memiliki kecakapan hidup sebagai kader bangsa dalam menjaga NKRI, mengamalkan Pancasila, serta melestarikan lingkungan hidup."
		},
		{
			pasal: "Pasal 19 Ayat (1)",
			q: "Golongan Pramuka Siaga mencakup anggota berusia...",
			options: [
				"5 – 9 tahun",
				"6 – 10 tahun",
				"7 – 10 tahun",
				"8 – 12 tahun"
			],
			correct: "7 – 10 tahun",
			edu: "Pasal 19 Ayat (1) huruf a: Anggota muda golongan Siaga berusia 7 (tujuh) sampai dengan 10 (sepuluh) tahun. Golongan Siaga merupakan golongan anggota muda yang paling rendah dalam Gerakan Pramuka."
		},
		{
			pasal: "Pasal 19 Ayat (1)",
			q: "Golongan Pramuka Penggalang mencakup anggota berusia...",
			options: [
				"10 – 14 tahun",
				"11 – 15 tahun",
				"12 – 16 tahun",
				"13 – 17 tahun"
			],
			correct: "11 – 15 tahun",
			edu: "Pasal 19 Ayat (1) huruf b: Anggota muda golongan Penggalang berusia 11 (sebelas) sampai dengan 15 (lima belas) tahun. Penggalang merupakan golongan lanjutan setelah Siaga."
		},
		{
			pasal: "Pasal 19 Ayat (1)",
			q: "Golongan Pramuka Penegak mencakup anggota berusia...",
			options: [
				"14 – 18 tahun",
				"15 – 19 tahun",
				"16 – 20 tahun",
				"17 – 21 tahun"
			],
			correct: "16 – 20 tahun",
			edu: "Pasal 19 Ayat (1) huruf c: Anggota muda golongan Penegak berusia 16 (enam belas) sampai dengan 20 (dua puluh) tahun. Penegak merupakan golongan anggota muda yang hampir memasuki usia dewasa."
		},
		{
			pasal: "Pasal 19 Ayat (1)",
			q: "Golongan Pramuka Pandega mencakup anggota berusia...",
			options: [
				"20 – 25 tahun",
				"21 – 25 tahun",
				"22 – 27 tahun",
				"20 – 26 tahun"
			],
			correct: "21 – 25 tahun",
			edu: "Pasal 19 Ayat (1) huruf d: Anggota muda golongan Pandega berusia 21 (dua puluh satu) sampai dengan 25 (dua puluh lima) tahun. Pandega adalah golongan anggota muda tertinggi sebelum memasuki golongan anggota dewasa."
		},
		{
			pasal: "Pasal 9",
			q: "Satuan organisasi Gerakan Pramuka terdiri atas...",
			options: [
				"Kwartir dan Regu",
				"Gugus depan dan Regu",
				"Gugus depan dan satuan karya pramuka",
				"Kwartir dan Gugus depan"
			],
			correct: "Gugus depan dan satuan karya pramuka",
			edu: "Pasal 9: Satuan organisasi Gerakan Pramuka terdiri atas: (a) gugus depan; dan (b) satuan karya pramuka. Gugus depan merupakan pangkalan keanggotaan, sedangkan satuan karya (Saka) dibentuk berdasarkan kesamaan minat dan profesi."
		},
		{
			pasal: "Pasal 10",
			q: "Gugus depan dalam Gerakan Pramuka berfungsi sebagai...",
			options: [
				"Pusat pelatihan kepemimpinan nasional",
				"Pangkalan keanggotaan pramuka",
				"Kantor administrasi Gerakan Pramuka",
				"Markas besar satuan karya pramuka"
			],
			correct: "Pangkalan keanggotaan pramuka",
			edu: "Pasal 10: Gugus depan sebagai pangkalan keanggotaan pramuka. Gugus depan merupakan satuan organisasi paling bawah yang langsung mengelola kegiatan pramuka dan tempat anggota muda bernaung."
		},
		{
			pasal: "Pasal 11",
			q: "Satuan Karya Pramuka (Saka) dibentuk berdasarkan...",
			options: [
				"Wilayah administrasi pemerintahan",
				"Usia dan tingkat pendidikan anggota",
				"Jumlah anggota minimal yang ditetapkan",
				"Kesamaan minat, profesi, dan ikatan"
			],
			correct: "Kesamaan minat, profesi, dan ikatan",
			edu: "Pasal 11: Satuan karya pramuka merupakan satuan organisasi Gerakan Pramuka yang dibentuk berdasarkan kesamaan minat, profesi, dan ikatan. Contoh Saka: Saka Bhayangkara (kepolisian), Saka Dirgantara (penerbangan), Saka Bahari (kelautan), Saka Wira Kartika (TNI AD)."
		},
		{
			pasal: "Pasal 13",
			q: "Berapa jenis kwartir dalam Gerakan Pramuka berdasarkan UU No. 12 Tahun 2010?",
			options: [
				"2 jenis",
				"3 jenis",
				"4 jenis",
				"5 jenis"
			],
			correct: "4 jenis",
			edu: "Pasal 13: Kwartir terdiri atas: (a) kwartir ranting — tingkat kecamatan; (b) kwartir cabang — tingkat kabupaten/kota; (c) kwartir daerah — tingkat provinsi; dan (d) kwartir nasional — tingkat nasional. Jadi terdapat 4 jenis kwartir."
		},
		{
			pasal: "Pasal 13",
			q: "Kwartir yang bertugas mengelola Gerakan Pramuka pada tingkat kecamatan disebut...",
			options: [
				"Kwartir Nasional",
				"Kwartir Daerah",
				"Kwartir Cabang",
				"Kwartir Ranting"
			],
			correct: "Kwartir Ranting",
			edu: "Pasal 13 huruf a: Kwartir Ranting adalah kwartir yang mengelola Gerakan Pramuka pada tingkat kecamatan. Kwartir Ranting membawahi gugus-gugus depan yang ada di wilayah kecamatannya."
		},
		{
			pasal: "Pasal 13",
			q: "Kwartir yang mengelola Gerakan Pramuka pada tingkat provinsi adalah...",
			options: [
				"Kwartir Ranting",
				"Kwartir Cabang",
				"Kwartir Daerah",
				"Kwartir Nasional"
			],
			correct: "Kwartir Daerah",
			edu: "Pasal 13 huruf c: Kwartir Daerah mengelola Gerakan Pramuka pada tingkat provinsi. Singkatannya adalah Kwarda. Kwartir Daerah membawahi Kwartir Cabang (tingkat kabupaten/kota) di seluruh wilayah provinsinya."
		},
		{
			pasal: "Pasal 17",
			q: "Anggota Gerakan Pramuka adalah...",
			options: [
				"Warga negara Indonesia dan warga negara asing yang berdomisili di Indonesia",
				"Warga negara Indonesia",
				"Seluruh penduduk Indonesia tanpa memandang kewarganegaraan",
				"Warga negara yang berusia di bawah 25 tahun"
			],
			correct: "Warga negara Indonesia",
			edu: "Pasal 17: Anggota Gerakan Pramuka adalah warga negara Indonesia. Hal ini menegaskan bahwa keanggotaan Gerakan Pramuka Indonesia hanya untuk WNI, berbeda dengan beberapa organisasi kepanduan internasional yang mengizinkan anggota asing."
		},
		{
			pasal: "Pasal 18",
			q: "Anggota Gerakan Pramuka terdiri atas dua jenis, yaitu...",
			options: [
				"Anggota aktif dan anggota pasif",
				"Anggota biasa dan anggota kehormatan",
				"Anggota muda dan anggota dewasa",
				"Anggota tetap dan anggota luar biasa"
			],
			correct: "Anggota muda dan anggota dewasa",
			edu: "Pasal 18: Anggota Gerakan Pramuka terdiri atas: (a) anggota muda, yaitu Siaga, Penggalang, Penegak, dan Pandega; serta (b) anggota dewasa, yang mencakup Pembina, Pelatih, Pamong Saka, dan lainnya."
		},
		{
			pasal: "Pasal 22",
			q: "Salah satu kewajiban anggota Gerakan Pramuka berdasarkan UU No. 12 Tahun 2010 adalah...",
			options: [
				"Mengikuti seluruh kegiatan militer negara",
				"Melaksanakan pendidikan kepramukaan",
				"Menjadi aparatur sipil negara",
				"Membina hubungan diplomatik luar negeri"
			],
			correct: "Melaksanakan pendidikan kepramukaan",
			edu: "Pasal 22: Setiap anggota berkewajiban: (a) melaksanakan pendidikan kepramukaan; (b) membayar iuran keanggotaan; dan (c) menjaga nama baik Gerakan Pramuka. Kewajiban ini berlaku bagi seluruh anggota, baik muda maupun dewasa."
		},
		{
			pasal: "Pasal 21",
			q: "Hak anggota Gerakan Pramuka yang tercantum dalam UU No. 12 Tahun 2010 meliputi...",
			options: [
				"Mendapat gaji bulanan dari Kwartir",
				"Mendapatkan pendidikan dan pelatihan kepramukaan",
				"Memimpin Kwartir Nasional secara langsung",
				"Mendapat jabatan pemerintahan otomatis"
			],
			correct: "Mendapatkan pendidikan dan pelatihan kepramukaan",
			edu: "Pasal 21: Setiap anggota berhak: (a) mendapatkan pendidikan dan pelatihan kepramukaan; (b) mengemukakan pendapat; (c) memilih dan dipilih dalam musyawarah; dan (d) mendapat perlindungan dalam mengikuti kegiatan kepramukaan."
		},
		{
			pasal: "Pasal 34",
			q: "Satya Pramuka dalam UU No. 12 Tahun 2010 didefinisikan sebagai...",
			options: [
				"Kumpulan peraturan tertulis tentang tata cara berkepramukaan",
				"Janji dan komitmen diri untuk mengikat diri secara sukarela menerapkan nilai-nilai kepramukaan",
				"Daftar tugas dan tanggung jawab anggota pramuka",
				"Sumpah yang diucapkan saat pelantikan anggota dewasa"
			],
			correct: "Janji dan komitmen diri untuk mengikat diri secara sukarela menerapkan nilai-nilai kepramukaan",
			edu: "Pasal 34: Satya pramuka merupakan janji dan komitmen diri untuk mengikat diri secara sukarela menerapkan dan mengamalkan nilai-nilai kepramukaan dalam kehidupan sehari-hari. Satya pramuka berbeda di setiap golongan: Dwisatya (Siaga), Trisatya (Penggalang, Penegak, Pandega)."
		},
		{
			pasal: "Pasal 35",
			q: "Darma Pramuka menurut UU No. 12 Tahun 2010 merupakan...",
			options: [
				"Peraturan disiplin yang mengikat seluruh anggota pramuka",
				"Hukum adat yang wajib diikuti oleh anggota",
				"Alat proses pendidikan diri yang progresif untuk mengembangkan budi pekerti luhur",
				"Sistem penghargaan bagi anggota berprestasi"
			],
			correct: "Alat proses pendidikan diri yang progresif untuk mengembangkan budi pekerti luhur",
			edu: "Pasal 35: Darma pramuka merupakan alat proses pendidikan diri yang progresif untuk mengembangkan budi pekerti luhur. Darma berbeda di setiap golongan: Dwidarma (Siaga), Dasadarma (Penggalang, Penegak, Pandega)."
		},
		{
			pasal: "Pasal 38",
			q: "Sumber pendanaan Gerakan Pramuka yang berasal dari APBN/APBD termasuk kategori...",
			options: [
				"Iuran anggota",
				"Bantuan masyarakat",
				"Bantuan Pemerintah dan pemerintah daerah",
				"Sumber lain yang tidak mengikat"
			],
			correct: "Bantuan Pemerintah dan pemerintah daerah",
			edu: "Pasal 38: Pendanaan Gerakan Pramuka bersumber dari: (a) iuran anggota; (b) bantuan masyarakat; (c) bantuan Pemerintah dan pemerintah daerah (APBN/APBD); dan (d) sumber lain yang tidak mengikat seperti hibah. Bantuan pemerintah merupakan salah satu sumber resmi yang dijamin UU."
		},
		{
			pasal: "Pasal 43",
			q: "Kurikulum pendidikan kepramukaan disusun oleh...",
			options: [
				"Kementerian Pendidikan dan Kebudayaan",
				"Kwartir Ranting setempat",
				"Kwartir Nasional Gerakan Pramuka",
				"Gugus depan masing-masing sekolah"
			],
			correct: "Kwartir Nasional Gerakan Pramuka",
			edu: "Pasal 43: Kurikulum pendidikan kepramukaan disusun oleh Kwartir Nasional. Hal ini memastikan standar pendidikan kepramukaan seragam di seluruh Indonesia, walaupun pelaksanaannya dapat disesuaikan dengan kondisi daerah masing-masing."
		},
		{
			pasal: "Pasal 4",
			q: "Gerakan Pramuka berfungsi sebagai wadah untuk mencapai tujuan pramuka, salah satunya melalui...",
			options: [
