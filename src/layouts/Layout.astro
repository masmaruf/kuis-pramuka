					setTimeout(checkAndShowShare, 600);
					setTimeout(injectWrongAnswerReview, 300);
					stopQuestionTimer();
					// Bonus XP dari timer — tulis setelah kuis simpan XP-nya
					setTimeout(() => {
						if (isTimerMode() && !isLatihanMode() && sessionBonusXp > 0) {
							const cur = parseInt(localStorage.getItem('scout_xp') || '0');
							(window as any)._origLocalSetItem('scout_xp', (cur + sessionBonusXp).toString());
							const xpEl = document.getElementById('result-xp');
							if (xpEl) {
								const base = xpEl.textContent?.match(/\d+/)?.[0] ?? '0';
								xpEl.innerHTML = `+${parseInt(base) + sessionBonusXp} XP <span class="bonus-xp-tag">⏱️ +${sessionBonusXp}</span>`;
							}
							updateHeaderStats();
						}
						sessionBonusXp = 0;
					}, 150);
				});

				// Mulai tracking soal salah jika ini halaman kuis
				startReviewTracking();

				// Reset tracking & timer saat kuis diulang
				document.addEventListener('click', (e) => {
					if ((e.target as HTMLElement).id === 'btn-restart') {
						setTimeout(startReviewTracking, 100);
						if (isTimerMode()) setTimeout(initTimerOnPage, 150);
