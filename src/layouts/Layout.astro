				});

				// Share panel controls
				document.getElementById('btn-close-share')?.addEventListener('click', () => {
					document.getElementById('share-panel')?.classList.remove('show');
				});

				document.getElementById('btn-copy-link')?.addEventListener('click', () => {
					const url = window.location.origin + window.location.pathname;
					navigator.clipboard?.writeText(url).then(() => {
						const el = document.getElementById('copy-link-text');
						if (el) { el.textContent = 'Tersalin! ✓'; setTimeout(() => { el.textContent = 'Salin Link'; }, 2000); }
					});
				});

				// Tutup overlay badge saat klik tombol
				document.getElementById('btn-close-unlock')?.addEventListener('click', closeUnlockOverlay);
				// Klik background overlay juga tutup
				document.getElementById('badge-unlock-overlay')?.addEventListener('click', (e) => {
					if (e.target === e.currentTarget) closeUnlockOverlay();
				});

				// Buka modal profil saat klik tombol header
				document.getElementById('header-profile-btn')?.addEventListener('click', openProfileModal);

				// Kontrol modal
				document.getElementById('btn-close-modal')?.addEventListener('click', closeProfileModal);
				document.getElementById('btn-skip-profile')?.addEventListener('click', () => {
					localStorage.setItem('scout_visited', 'true');
					closeProfileModal();
				});
				document.getElementById('btn-save-profile')?.addEventListener('click', saveProfile);

				// Validasi real-time nama
				document.getElementById('input-username')?.addEventListener('input', updateSaveBtn);

				// Enter untuk simpan
				document.getElementById('input-username')?.addEventListener('keydown', (e) => {
					if ((e as KeyboardEvent).key === 'Enter') saveProfile();
				});

				// Klik luar modal untuk tutup
				document.getElementById('profile-modal')?.addEventListener('click', (e) => {
					if (e.target === e.currentTarget) closeProfileModal();
				});

				// Tampilkan modal pertama kali jika belum ada profil
				if (!localStorage.getItem('scout_visited') && !localStorage.getItem('scout_username')) {
					setTimeout(openProfileModal, 800);
				}

				// Daftarkan Service Worker untuk PWA / offline
				if ('serviceWorker' in navigator) {
					window.addEventListener('load', () => {
						navigator.serviceWorker.register('/sw.js');
					});
				}

				// ─── Mode Latihan ──────────────────────────────────────────────────────
				function isLatihanMode(): boolean {
					return localStorage.getItem('scout_latihan') === '1';
				}

				function applyLatihanPatch() {
					const BLOCKED = ['scout_xp', 'scout_badges', 'scout_streak', 'scout_last_visit'];
					localStorage.setItem = function(k: string, v: string) {
						if (BLOCKED.includes(k)) return;
						(window as any)._origLocalSetItem(k, v);
					};
					document.documentElement.setAttribute('data-latihan', 'true');
				}

				function removeLatihanPatch() {
					localStorage.setItem = (window as any)._origLocalSetItem;
					document.documentElement.removeAttribute('data-latihan');
				}

				function updateLatihanBtn() {
					const btn = document.getElementById('latihan-toggle');
					const icon = document.getElementById('latihan-icon');
					const active = isLatihanMode();
					btn?.setAttribute('aria-pressed', active ? 'true' : 'false');
					btn?.setAttribute('title', active ? 'Nonaktifkan Mode Latihan' : 'Aktifkan Mode Latihan');
					if (icon) icon.textContent = active ? '📖' : '🎯';
				}

				function toggleLatihanMode() {
					const active = isLatihanMode();
					if (active) {
						(window as any)._origLocalSetItem('scout_latihan', '');
						localStorage.removeItem('scout_latihan');
						removeLatihanPatch();
						showStreakToast('✅', 'Mode Latihan Nonaktif', 'XP kembali dihitung seperti biasa');
					} else {
						(window as any)._origLocalSetItem('scout_latihan', '1');
						applyLatihanPatch();
						showStreakToast('🎯', 'Mode Latihan Aktif', 'Jawaban langsung ditampilkan — XP tidak dihitung');
					}
					updateLatihanBtn();
				}

				// Auto-submit saat opt-btn diklik di Mode Latihan
				document.addEventListener('click', (e) => {
					if (!isLatihanMode()) return;
					const optBtn = (e.target as HTMLElement).closest('.opt-btn');
					if (!optBtn) return;
					setTimeout(() => {
						const btn = document.getElementById('btn-submit-answer') as HTMLButtonElement | null;
						const txt = btn?.textContent?.trim() ?? '';
						if (btn && !btn.disabled && txt.startsWith('Konfirmasi')) {
							btn.click();
						}
					}, 80);
				});

				updateLatihanBtn();
				document.getElementById('latihan-toggle')?.addEventListener('click', toggleLatihanMode);

				// ─── Timer Kuis ───────────────────────────────────────────────────────
				const TIMER_DURATION = 30;
				let timerInterval: ReturnType<typeof setInterval> | null = null;
				let timerSecondsLeft = TIMER_DURATION;
				let sessionBonusXp = 0;
				let containerTimerObs: MutationObserver | null = null;

				function isTimerMode(): boolean {
					return localStorage.getItem('scout_timer') === '1';
				}

				function updateTimerToggleBtn() {
					const btn = document.getElementById('timer-toggle');
					const active = isTimerMode();
					btn?.setAttribute('aria-pressed', active ? 'true' : 'false');
					btn?.setAttribute('title', active ? `Nonaktifkan Timer (${TIMER_DURATION}s/soal)` : 'Aktifkan Timer Kuis');
				}

				function stopQuestionTimer() {
					if (timerInterval) { clearInterval(timerInterval); timerInterval = null; }
				}

				function updateTimerDisplay() {
					const fill = document.getElementById('timer-fill') as HTMLElement | null;
					const sec  = document.getElementById('timer-seconds');
					const bar  = document.getElementById('quiz-timer-bar');
					if (!fill || !sec || !bar) return;
					fill.style.width = `${(timerSecondsLeft / TIMER_DURATION) * 100}%`;
					sec.textContent = String(timerSecondsLeft);
					bar.classList.toggle('timer-warning', timerSecondsLeft <= 10 && timerSecondsLeft > 5);
					bar.classList.toggle('timer-danger',  timerSecondsLeft <= 5);
				}

				function forceSubmit() {
					const btn = document.getElementById('btn-submit-answer') as HTMLButtonElement | null;
					if (!btn) return;
					const txt = btn.textContent?.trim() ?? '';
					if (!txt.startsWith('Konfirmasi')) return;
					if (!btn.disabled) {
						btn.click();
					} else {
						// Belum pilih jawaban — pilih opsi pertama lalu submit
						const firstOpt = document.querySelector('#options-container .opt-btn:not(.is-answered)') as HTMLElement | null;
						if (firstOpt) {
							firstOpt.click();
							setTimeout(() => {
								const b = document.getElementById('btn-submit-answer') as HTMLButtonElement | null;
								if (b && !b.disabled) b.click();
							}, 100);
						}
					}
				}

				function startQuestionTimer() {
					stopQuestionTimer();
					timerSecondsLeft = TIMER_DURATION;
					updateTimerDisplay();
					timerInterval = setInterval(() => {
						timerSecondsLeft = Math.max(0, timerSecondsLeft - 1);
						updateTimerDisplay();
						if (timerSecondsLeft === 0) { stopQuestionTimer(); forceSubmit(); }
					}, 1000);
				}

				function injectTimerUI() {
					document.getElementById('quiz-timer-bar')?.remove();
					const container = document.getElementById('options-container');
					if (!container) return;
					const bar = document.createElement('div');
					bar.id = 'quiz-timer-bar';
					bar.className = 'quiz-timer-bar';
					bar.innerHTML = `
						<span class="timer-emoji">⏱️</span>
						<div class="timer-track">
							<div id="timer-fill" class="timer-fill" style="width:100%"></div>
						</div>
						<span id="timer-seconds" class="timer-seconds">${TIMER_DURATION}</span>`;
					container.parentElement?.insertBefore(bar, container);
				}

				function initTimerOnPage() {
					const container = document.getElementById('options-container');
					if (!container) return;
					injectTimerUI();
					sessionBonusXp = 0;
					containerTimerObs?.disconnect();

					// Restart timer setiap kali soal baru di-render
					containerTimerObs = new MutationObserver((mutations) => {
						if (!isTimerMode()) return;
						for (const mut of mutations) {
							if (mut.type === 'childList' && mut.addedNodes.length > 0) {
								const firstAdded = mut.addedNodes[0] as HTMLElement;
								if (firstAdded?.classList?.contains('opt-btn')) {
									setTimeout(startQuestionTimer, 60);
									return;
								}
							}
						}
					});
					containerTimerObs.observe(container, { childList: true });

					// Mulai timer jika soal sudah tampil
					if (container.querySelector('.opt-btn')) startQuestionTimer();
				}

				function toggleTimerMode() {
					const active = isTimerMode();
					if (active) {
						localStorage.removeItem('scout_timer');
						stopQuestionTimer();
						document.getElementById('quiz-timer-bar')?.remove();
						containerTimerObs?.disconnect();
						showStreakToast('⏱️', 'Timer Dinonaktifkan', 'Kuis tanpa batas waktu');
					} else {
						localStorage.setItem('scout_timer', '1');
						initTimerOnPage();
						showStreakToast('⏱️', 'Timer Aktif', `${TIMER_DURATION} detik per soal — jawab cepat untuk bonus XP!`);
					}
					updateTimerToggleBtn();
				}

				// Deteksi submit untuk hitung bonus XP timer
				document.addEventListener('click', (e) => {
					if (!isTimerMode()) return;
					const target = e.target as HTMLElement;
					const submitBtn = target.closest('#btn-submit-answer') as HTMLButtonElement | null;
					if (!submitBtn) return;
					if (!submitBtn.textContent?.trim().startsWith('Konfirmasi')) return;
					setTimeout(() => {
						stopQuestionTimer();
						const c = document.getElementById('options-container');
						const isCorrect = !!c?.querySelector('.opt-btn.is-correct') && !c?.querySelector('.opt-btn.is-incorrect');
						if (isCorrect && timerSecondsLeft > 0) {
							sessionBonusXp += Math.max(1, Math.ceil(timerSecondsLeft / 4));
						}
					}, 180);
				});

				updateTimerToggleBtn();
				document.getElementById('timer-toggle')?.addEventListener('click', toggleTimerMode);
				if (isTimerMode()) initTimerOnPage();

				// Dark mode toggle
				function applyTheme(dark: boolean) {
					document.documentElement.setAttribute('data-theme', dark ? 'dark' : 'light');
					const icon = document.getElementById('theme-icon');
					if (icon) icon.textContent = dark ? '☀️' : '🌙';
					localStorage.setItem('scout_theme', dark ? 'dark' : 'light');
				}

				// Sinkron ikon dengan preferensi yang sudah diset di <head>
				const savedTheme = localStorage.getItem('scout_theme');
				applyTheme(savedTheme === 'dark');

				document.getElementById('theme-toggle')?.addEventListener('click', () => {
					const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
					applyTheme(!isDark);
				});
			}
		</script>
	</body>
</html>

