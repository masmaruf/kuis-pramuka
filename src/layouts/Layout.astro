			// ─── Review Soal Salah ────────────────────────────────────────────────────
			interface WrongItem { q: string; wrong: string; correct: string; edu: string; }
			let wrongAnswers: WrongItem[] = [];
			let reviewObserver: MutationObserver | null = null;

			function startReviewTracking() {
				const container = document.getElementById('options-container');
				if (!container) return;

				wrongAnswers = [];
				reviewObserver?.disconnect();

				reviewObserver = new MutationObserver((mutations) => {
					for (const mut of mutations) {
						if (mut.type !== 'attributes' || mut.attributeName !== 'class') continue;
						const btn = mut.target as HTMLElement;
						if (!btn.classList.contains('is-incorrect')) continue;

						// Ambil detail jawaban setelah semua class teraplikasi
						setTimeout(() => {
							const correctBtn = container.querySelector('.opt-btn.is-correct') as HTMLElement | null;
							const qEl  = document.getElementById('question-prompt');
							const eduEl = document.getElementById('education-text');

							const qText      = qEl?.textContent?.trim() ?? '';
							const wrongText  = (btn.querySelector('.opt-text') as HTMLElement)?.textContent?.trim()
								?? btn.dataset.answer ?? '';
							const correctText = (correctBtn?.querySelector('.opt-text') as HTMLElement)?.textContent?.trim()
								?? correctBtn?.dataset.answer ?? '';
							const eduText = eduEl?.textContent?.trim() ?? '';

							if (qText && wrongText && correctText) {
								wrongAnswers.push({ q: qText, wrong: wrongText, correct: correctText, edu: eduText });
							}
						}, 50);
					}
				});

				reviewObserver.observe(container, { attributes: true, attributeFilter: ['class'], subtree: true });
			}

			function injectWrongAnswerReview() {
				const resultCard = document.querySelector('.result-card');
				const resultActions = resultCard?.querySelector('.result-actions') as HTMLElement | null;
				if (!resultCard || !resultActions) return;

				document.getElementById('review-wrong-answers')?.remove();
				if (wrongAnswers.length === 0) return;

				const div = document.createElement('div');
				div.id = 'review-wrong-answers';
				div.className = 'review-wrong-answers';
				div.innerHTML = `
					<button class="review-toggle" id="btn-review-toggle" aria-expanded="false">
						<span>📝 Review ${wrongAnswers.length} Soal yang Salah</span>
						<svg class="review-caret" viewBox="0 0 10 6" fill="none">
							<path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
						</svg>
					</button>
					<div class="review-list" id="review-list" hidden>
						${wrongAnswers.map((item, i) => `
							<div class="review-item">
								<div class="review-q"><span class="review-num">${i + 1}</span>${item.q}</div>
								<div class="review-wrong">✗ &nbsp;${item.wrong}</div>
								<div class="review-correct">✓ &nbsp;${item.correct}</div>
								${item.edu ? `<div class="review-edu">${item.edu}</div>` : ''}
							</div>
						`).join('')}
					</div>`;

				resultCard.insertBefore(div, resultActions);

				document.getElementById('btn-review-toggle')?.addEventListener('click', () => {
					const list = document.getElementById('review-list') as HTMLElement | null;
					const btn  = document.getElementById('btn-review-toggle');
					if (!list) return;
					const opening = list.hasAttribute('hidden');
					opening ? list.removeAttribute('hidden') : list.setAttribute('hidden', '');
					btn?.setAttribute('aria-expanded', opening ? 'true' : 'false');
					btn?.classList.toggle('open', opening);
				});
			}

			function launchConfetti(stage: HTMLElement) {
				stage.innerHTML = '';
				const colors = ['#d4a32b','#1b4d32','#2a6f4a','#c0513c','#5a6bc4','#e07b20','#b2831b','#4a9960'];
				for (let i = 0; i < 56; i++) {
					const piece = document.createElement('div');
					const angle    = Math.random() * Math.PI * 2;
					const dist     = 70 + Math.random() * 130;
					const dx       = Math.cos(angle) * dist;
					const dy       = Math.sin(angle) * dist - 30;
					const size     = 6 + Math.random() * 8;
					const color    = colors[Math.floor(Math.random() * colors.length)];
					const delay    = Math.random() * 350;
					const dur      = 700 + Math.random() * 800;
					const rot      = 200 + Math.random() * 560;
					const isCircle = Math.random() > 0.45;
					piece.style.cssText = `
						position:absolute; left:calc(50% - ${size/2}px); top:38%;
						width:${size}px; height:${size}px;
						background:${color}; border-radius:${isCircle?'50%':'3px'};
						opacity:1; pointer-events:none;
					`;
					stage.appendChild(piece);
					setTimeout(() => {
						piece.style.transition = `transform ${dur}ms cubic-bezier(.25,.46,.45,.94), opacity ${dur}ms ease`;
						piece.style.transform  = `translate(${dx}px,${dy}px) rotate(${rot}deg)`;
						piece.style.opacity    = '0';
					}, delay);
				}
				setTimeout(() => { stage.innerHTML = ''; }, 1800);
			}

			function showNextUnlock() {
				if (isShowingUnlock || unlockQueue.length === 0) return;
				const badgeId = unlockQueue.shift()!;
				const meta = BADGE_META[badgeId];
				if (!meta) { showNextUnlock(); return; }

				const overlay  = document.getElementById('badge-unlock-overlay');
				const iconEl   = document.getElementById('unlock-icon');
				const nameEl   = document.getElementById('unlock-name');
				const descEl   = document.getElementById('unlock-desc');
				const stage    = document.getElementById('confetti-stage');
				if (!overlay) return;

				if (iconEl)  iconEl.textContent  = meta.icon;
				if (nameEl)  nameEl.textContent  = meta.name;
				if (descEl)  descEl.textContent  = meta.desc;

				overlay.style.display = 'flex';
				requestAnimationFrame(() => overlay.classList.add('visible'));
				isShowingUnlock = true;

				if (stage) setTimeout(() => launchConfetti(stage), 200);
			}

			function closeUnlockOverlay() {
				const overlay = document.getElementById('badge-unlock-overlay');
				if (!overlay) return;
				overlay.classList.remove('visible');
				setTimeout(() => {
					overlay.style.display = 'none';
					isShowingUnlock = false;
					showNextUnlock();
				}, 300);
			}

			function checkForNewBadges() {
				const current: string[] = JSON.parse(localStorage.getItem('scout_badges') || '[]');
				const newOnes = current.filter(id => !knownBadgeSet.has(id));
				if (newOnes.length > 0) {
					newOnes.forEach(id => { unlockQueue.push(id); knownBadgeSet.add(id); });
					showNextUnlock();
				}
			}

			// Expose ke window agar /profil bisa trigger modal
			(window as any).openProfileModal = openProfileModal;

