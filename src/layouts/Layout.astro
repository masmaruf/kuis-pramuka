			if (typeof window !== 'undefined') {
				localStorage.setItem('scout_xp', localStorage.getItem('scout_xp') || '0');
				localStorage.setItem('scout_badges', localStorage.getItem('scout_badges') || '[]');

				// Inisialisasi set badge yang sudah diketahui (sebelum event apapun)
				knownBadgeSet = new Set(JSON.parse(localStorage.getItem('scout_badges') || '[]'));

				updateHeaderStats();
