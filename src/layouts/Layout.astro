---
interface Props {
	title: string;
	description?: string;
}

const { title, description = "Platform latihan kepramukaan interaktif: Morse, Semaphore, Sandi, SKU, Kompas, P3K, dan 16 modul lainnya. Kumpulkan XP dan raih Lencana Pandu. Gratis, offline, tanpa daftar." } = Astro.props;

const SITE_URL = 'https://kuis.pramukaupdate.id';
const canonicalURL = new URL(Astro.url.pathname, SITE_URL).href;
const ogImage = `${SITE_URL}/og-image.svg`;

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	"name": "Kuis Pramuka Interaktif",
	"alternateName": "KuisPramuka",
	"url": SITE_URL,
	"description": "Platform latihan kepramukaan interaktif: Morse, Semaphore, Sandi, SKU, Kompas, P3K, Dasa Darma, dan modul lainnya.",
	"inLanguage": "id",
	"publisher": {
		"@type": "Organization",
		"name": "PramukaUpdate.id",
		"url": "https://pramukaupdate.id"
	},
	"potentialAction": {
		"@type": "SearchAction",
		"target": { "@type": "EntryPoint", "urlTemplate": `${SITE_URL}/?q={search_term_string}` },
		"query-input": "required name=search_term_string"
	}
};
---

<!doctype html>
<html lang="id">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Kuis Pramuka Interaktif</title>
		<meta name="description" content={description} />

		<!-- PWA -->
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="theme-color" content="#1b4d32" />
		<meta name="mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
		<meta name="apple-mobile-web-app-title" content="KuisPramuka" />
		<link rel="apple-touch-icon" href="/icons/pwa-192.svg" />

		<!-- Canonical -->
		<link rel="canonical" href={canonicalURL} />

		<!-- Open Graph -->
		<meta property="og:title" content={`${title} | Kuis Pramuka Interaktif`} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:locale" content="id_ID" />
		<meta property="og:site_name" content="Kuis Pramuka Interaktif" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={`${title} | Kuis Pramuka Interaktif`} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />

		<!-- JSON-LD Structured Data -->
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

		<!-- Anti-flash: apply theme + latihan patch before first paint -->
		<script is:inline>
			(function(){
				var t = localStorage.getItem('scout_theme');
				if (t === 'dark') document.documentElement.setAttribute('data-theme', 'dark');

				// Simpan fungsi asli sebelum dipatch
				window._origLocalSetItem = localStorage.setItem.bind(localStorage);

				// Jika Mode Latihan aktif, blokir penulisan XP/badge/streak
				if (localStorage.getItem('scout_latihan') === '1') {
					document.documentElement.setAttribute('data-latihan', 'true');
					var BLOCKED = ['scout_xp', 'scout_badges', 'scout_streak', 'scout_last_visit'];
					localStorage.setItem = function(k, v) {
						if (BLOCKED.indexOf(k) !== -1) return;
						window._origLocalSetItem(k, v);
					};
				}
			})();
		</script>

		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
		<script src="https://cdn.tailwindcss.com"></script>
		<script>
			// @ts-ignore
			tailwind.config = {
				theme: {
					extend: {
						colors: {
							scout:   { DEFAULT: '#1b4d32', light: '#2a6f4a', dark: '#0f2e1e' },
							gold:    { DEFAULT: '#b2831b', light: '#d4a32b' },
							success: { DEFAULT: '#236c32' },
							danger:  { DEFAULT: '#a5301a' },
						}
					}
				},
				corePlugins: { preflight: false }
			}
		</script>
	</head>
	<body>
		<header class="app-header">
			<div class="header-container">
				<a href="/" class="logo-area">
					<svg class="logo-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
						<path d="M12 2L2 22H22L12 2Z" stroke="var(--color-gold)" stroke-width="2" stroke-linejoin="round"/>
						<circle cx="12" cy="14" r="3" stroke="var(--color-gold)" stroke-width="2"/>
						<path d="M12 8V11" stroke="var(--color-gold)" stroke-width="2" stroke-linecap="round"/>
					</svg>
					<span class="logo-text">KUIS<span>PRAMUKA</span></span>
				</a>

				<nav class="nav-links">
					<a href="/" class="nav-link" id="nav-home">Dasbor</a>
					<div class="nav-dropdown" id="nav-modul-wrap">
						<button class="nav-link nav-dropdown-btn" id="nav-modul" aria-haspopup="true" aria-expanded="false">
							Modul
							<svg class="dropdown-caret" viewBox="0 0 10 6" fill="none">
								<path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
							</svg>
						</button>
						<div class="nav-dropdown-menu" role="menu">
							<div class="dropdown-col">
								<span class="dropdown-col-title">Komunikasi &amp; Isyarat</span>
								<a href="/morse" class="dropdown-item" data-nav="morse">⚡ Kode Morse</a>
								<a href="/semaphore" class="dropdown-item" data-nav="semaphore">🚩 Semaphore</a>
								<a href="/sandi" class="dropdown-item" data-nav="sandi">🔑 Sandi</a>
							</div>
							<div class="dropdown-col">
								<span class="dropdown-col-title">Teknik Kepramukaan</span>
								<a href="/simpul" class="dropdown-item" data-nav="simpul">🪢 Simpul &amp; Ikatan</a>
								<a href="/pioniring" class="dropdown-item" data-nav="pioniring">🏗️ Pioniring</a>
								<a href="/kompas" class="dropdown-item" data-nav="kompas">🧭 Kompas &amp; Navigasi</a>
								<a href="/perkemahan" class="dropdown-item" data-nav="perkemahan">⛺ Perkemahan</a>
								<a href="/p3k" class="dropdown-item" data-nav="p3k">🩺 P3K</a>
								<a href="/baris-berbaris" class="dropdown-item" data-nav="baris-berbaris">🪖 Baris-Berbaris</a>
							</div>
							<div class="dropdown-col">
								<span class="dropdown-col-title">Pengetahuan Pramuka</span>
								<a href="/sejarah" class="dropdown-item" data-nav="sejarah">🕰️ Sejarah</a>
								<a href="/uu-pramuka" class="dropdown-item" data-nav="uu-pramuka">⚖️ UU No. 12/2010</a>
								<a href="/sku" class="dropdown-item" data-nav="sku">📖 SKU</a>
								<a href="/organisasi" class="dropdown-item" data-nav="organisasi">🏛️ Organisasi</a>
								<a href="/tanda-pengenal" class="dropdown-item" data-nav="tanda-pengenal">🎗️ Tanda Pengenal</a>
								<a href="/dasa-darma" class="dropdown-item" data-nav="dasa-darma">⚜️ Dasa Darma</a>
							</div>
						</div>
					</div>
					<a href="/referensi" class="nav-link" id="nav-referensi">Referensi</a>
					<a href="/lencana" class="nav-link" id="nav-lencana">Lencana</a>
					<a href="/profil" class="nav-link" id="nav-profil">Profil</a>
				</nav>

				<div class="user-stats-bar">
					<button class="profile-btn" id="header-profile-btn">
						<span id="header-avatar" class="avatar-icon">👤</span>
						<span id="header-username" class="username-text">Atur Profil</span>
					</button>

					<div class="stat-separator"></div>

					<div class="stat-badge level-badge">
						<span class="label">LVL</span>
						<span id="header-level" class="value">1</span>
					</div>
					<div class="xp-progress-container">
						<div class="xp-info">
							<span id="header-xp-display">0/100 XP</span>
						</div>
						<div class="xp-bar-outer">
							<div id="header-xp-bar" class="xp-bar-inner" style="width: 0%"></div>
						</div>
					</div>
					<div class="stat-badge badge-count" title="Lencana yang Diperoleh">
						<svg class="badge-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M12 15L15.5 18L14.5 13.5L18 10.5L13.5 10L12 5.5L10.5 10L6 10.5L9.5 13.5L8.5 18L12 15Z" fill="var(--color-gold)" stroke="var(--color-gold)"/>
						</svg>
						<span id="header-badge-count" class="value">0</span>
					</div>
					<div class="stat-badge streak-badge" id="header-streak" title="Streak Harian">
						<span class="streak-fire">🔥</span>
						<span id="header-streak-count" class="value">0</span>
					</div>
					<button id="theme-toggle" class="theme-toggle-btn" aria-label="Toggle dark mode" title="Ganti Tema">
						<span id="theme-icon">🌙</span>
					</button>
					<button id="latihan-toggle" class="theme-toggle-btn latihan-toggle-btn" aria-label="Mode Latihan" title="Aktifkan Mode Latihan" aria-pressed="false">
						<span id="latihan-icon">🎯</span>
					</button>
					<button id="timer-toggle" class="theme-toggle-btn timer-toggle-btn" aria-label="Timer kuis" title="Aktifkan Timer" aria-pressed="false">
						<span id="timer-icon">⏱️</span>
					</button>
				</div>
			</div>
		</header>

		<!-- Banner Mode Latihan -->
		<div id="latihan-banner" class="latihan-banner" aria-live="polite">
			🎯 <strong>Mode Latihan Aktif</strong> — Jawaban ditampilkan langsung, XP tidak dihitung
		</div>

		<main class="main-content">
			<slot />
		</main>

		<footer class="app-footer">
			<div class="footer-container">
				<p>&copy; 2026 <strong>Kuis Pramuka Interaktif</strong> — Media Pembelajaran &amp; Kegiatan Gugus Depan.</p>
				<p class="credit">
					Bagian dari <a href="https://pramukaupdate.id" target="_blank" rel="noopener" class="footer-brand">PramukaUpdate.id</a>
					— Media Informasi &amp; Edukasi Gerakan Pramuka Indonesia.
				</p>
			</div>
		</footer>

		<!-- Badge Unlock Overlay -->
		<div id="badge-unlock-overlay" class="badge-unlock-overlay" style="display:none">
			<div class="badge-unlock-card">
				<div id="confetti-stage" class="confetti-stage"></div>
				<div class="unlock-sparkle">✨ Lencana Baru Terbuka!</div>
				<div id="unlock-icon" class="unlock-icon">⚡</div>
				<h2 id="unlock-name" class="unlock-name">—</h2>
				<p id="unlock-desc" class="unlock-desc">—</p>
				<button id="btn-close-unlock" class="btn btn-gold">Luar Biasa! 🎉</button>
			</div>
		</div>

		<!-- Share Panel -->
		<div id="share-panel" class="share-panel">
			<button id="btn-close-share" class="share-close" aria-label="Tutup">✕</button>
			<div class="share-header">
				<span id="share-emoji" class="share-emoji">📢</span>
				<div>
					<strong id="share-title">Bagikan Hasil</strong>
					<span id="share-subtitle">Ajak temanmu latihan!</span>
				</div>
			</div>
			<div class="share-actions">
				<a id="btn-share-wa" href="#" target="_blank" rel="noopener" class="btn btn-share-wa">
					<svg viewBox="0 0 24 24" fill="currentColor" style="width:16px;height:16px;flex-shrink:0"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
					WhatsApp
				</a>
				<button id="btn-copy-link" class="btn btn-copy-link">
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:15px;height:15px;flex-shrink:0"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
					<span id="copy-link-text">Salin Link</span>
				</button>
			</div>
		</div>

		<!-- Streak Toast -->
		<div id="streak-toast" class="streak-toast" role="status" aria-live="polite">
			<span id="streak-toast-icon">🔥</span>
			<div class="toast-body">
				<strong id="streak-toast-title"></strong>
				<span id="streak-toast-sub"></span>
			</div>
		</div>

		<!-- Modal Profil / Registrasi -->
		<div id="profile-modal" class="modal-overlay" style="display:none;" role="dialog" aria-modal="true" aria-labelledby="modal-title">
			<div class="modal-card">
				<button class="modal-close-btn" id="btn-close-modal" aria-label="Tutup modal">✕</button>

				<div class="modal-header-area">
					<div class="modal-avatar-preview" id="modal-preview-avatar">👤</div>
					<h2 class="modal-title" id="modal-title">Buat Profil Pandumu</h2>
					<p class="modal-subtitle">Profilmu disimpan di perangkat ini. Tidak perlu daftar ke server — progres kuis, XP, dan lencanamu tetap tersimpan.</p>
				</div>

				<div class="modal-body-area">
					<div class="form-group">
						<label for="input-username" class="form-label">Nama Pandu</label>
						<input
							type="text"
							id="input-username"
							class="form-input"
							placeholder="Contoh: Budi Santoso"
							maxlength="20"
							autocomplete="off"
						/>
						<span class="form-hint">Maks. 20 karakter</span>
					</div>

					<div class="form-group">
						<label class="form-label">Pilih Avatar</label>
						<div class="avatar-grid" id="avatar-picker">
							<!-- diisi oleh JavaScript -->
						</div>
					</div>
				</div>

				<div class="modal-footer-area">
					<button id="btn-save-profile" class="btn btn-primary" disabled>Simpan Profil</button>
					<button id="btn-skip-profile" class="btn btn-secondary">Lewati</button>
				</div>
			</div>
		</div>

		<script>
			// ─── Konstanta & Konfigurasi ──────────────────────────────────────────────

			const AVATAR_OPTIONS = ['🦁', '🦊', '🐺', '🦅', '🐻', '🌟', '⚜️', '🏕️', '🧭', '🔥', '🎯', '🏆', '🛡️', '🌿', '⛺'];

			// ─── Fungsi Leveling (Satu Sumber Kebenaran) ─────────────────────────────

			function calcLevel(xp) {
				if (xp >= 1000) {
					const lvl = 5 + Math.floor((xp - 1000) / 500);
					const base = 1000 + (lvl - 5) * 500;
					return { level: lvl, xpBase: base, xpNext: base + 500 };
				}
				if (xp >= 600) return { level: 4, xpBase: 600, xpNext: 1000 };
				if (xp >= 300) return { level: 3, xpBase: 300, xpNext: 600 };
				if (xp >= 100) return { level: 2, xpBase: 100, xpNext: 300 };
				return { level: 1, xpBase: 0, xpNext: 100 };
			}

			// ─── Update Header Stats ──────────────────────────────────────────────────

			function updateHeaderStats() {
				const xp = parseInt(localStorage.getItem('scout_xp') || '0');
				const badges = JSON.parse(localStorage.getItem('scout_badges') || '[]');
				const { level, xpBase, xpNext } = calcLevel(xp);
				const pct = Math.min(100, Math.max(0, ((xp - xpBase) / (xpNext - xpBase)) * 100));

				const username = localStorage.getItem('scout_username') || '';
				const avatar = localStorage.getItem('scout_avatar') || '👤';

				const profileBtn = document.getElementById('header-profile-btn');
				const avatarEl = document.getElementById('header-avatar');
				const usernameEl = document.getElementById('header-username');

				if (avatarEl) avatarEl.textContent = avatar;
				if (usernameEl) usernameEl.textContent = username ? `Kak ${username}` : 'Atur Profil';
				if (profileBtn) profileBtn.classList.toggle('has-profile', !!username);

				const lvlEl = document.getElementById('header-level');
				const xpTextEl = document.getElementById('header-xp-display');
				const xpBarEl = document.getElementById('header-xp-bar');
				const badgeCountEl = document.getElementById('header-badge-count');

				if (lvlEl) lvlEl.textContent = level.toString();
				if (xpTextEl) xpTextEl.textContent = `${xp}/${xpNext} XP`;
				if (xpBarEl) xpBarEl.style.width = `${pct}%`;
				if (badgeCountEl) badgeCountEl.textContent = badges.length.toString();
			}

			// ─── Active Nav Link ──────────────────────────────────────────────────────

			function highlightActiveLink() {
				const path = window.location.pathname;

				const homeEl = document.getElementById('nav-home');
				if (homeEl) homeEl.classList.toggle('active', path === '/' || path === '/index.html');

				const referensiEl = document.getElementById('nav-referensi');
				if (referensiEl) referensiEl.classList.toggle('active', path.includes('referensi'));

				const lencanaEl = document.getElementById('nav-lencana');
				if (lencanaEl) lencanaEl.classList.toggle('active', path.includes('lencana'));

				const profilEl = document.getElementById('nav-profil');
				if (profilEl) profilEl.classList.toggle('active', path.includes('profil'));

				const quizRoutes = ['morse','semaphore','sandi','simpul','pioniring','kompas','perkemahan','p3k','baris-berbaris','sejarah','uu-pramuka','sku','organisasi','tanda-pengenal','dasa-darma'];
				const onQuiz = quizRoutes.some(r => path.includes(r));
				const modulBtn = document.getElementById('nav-modul');
				if (modulBtn) modulBtn.classList.toggle('active', onQuiz);

				document.querySelectorAll('.dropdown-item[data-nav]').forEach(el => {
					const route = (el as HTMLElement).dataset.nav || '';
					el.classList.toggle('active', path.includes(route));
				});
			}

			// ─── Modal Profil ─────────────────────────────────────────────────────────

			let selectedAvatar = '👤';

			function openProfileModal() {
				const modal = document.getElementById('profile-modal');
				if (!modal) return;

				const savedUsername = localStorage.getItem('scout_username') || '';
				const savedAvatar = localStorage.getItem('scout_avatar') || '👤';
				selectedAvatar = savedAvatar;

				const input = document.getElementById('input-username') as HTMLInputElement | null;
				if (input) input.value = savedUsername;

				buildAvatarPicker();
				updateModalPreview();
				updateSaveBtn();

				modal.style.display = 'flex';
				document.body.style.overflow = 'hidden';
				setTimeout(() => input?.focus(), 50);
			}

			function closeProfileModal() {
				const modal = document.getElementById('profile-modal');
				if (modal) modal.style.display = 'none';
				document.body.style.overflow = '';
			}

			function buildAvatarPicker() {
				const grid = document.getElementById('avatar-picker');
				if (!grid) return;

				grid.innerHTML = AVATAR_OPTIONS.map(emoji => `
					<button
						type="button"
						class="avatar-option ${emoji === selectedAvatar ? 'selected' : ''}"
						data-avatar="${emoji}"
						aria-label="Pilih avatar ${emoji}"
					>${emoji}</button>
				`).join('');

				grid.querySelectorAll('.avatar-option').forEach(btn => {
					btn.addEventListener('click', () => {
						selectedAvatar = (btn as HTMLElement).dataset.avatar || '👤';
						grid.querySelectorAll('.avatar-option').forEach(b => b.classList.remove('selected'));
						btn.classList.add('selected');
						updateModalPreview();
					});
				});
			}

			function updateModalPreview() {
				const preview = document.getElementById('modal-preview-avatar');
				if (preview) preview.textContent = selectedAvatar;
			}

			function updateSaveBtn() {
				const input = document.getElementById('input-username') as HTMLInputElement | null;
				const btn = document.getElementById('btn-save-profile') as HTMLButtonElement | null;
				if (btn && input) btn.disabled = input.value.trim().length === 0;
			}

			function saveProfile() {
				const input = document.getElementById('input-username') as HTMLInputElement | null;
				const name = input?.value.trim() || '';
				if (!name) return;

				localStorage.setItem('scout_username', name);
				localStorage.setItem('scout_avatar', selectedAvatar);
				localStorage.setItem('scout_visited', 'true');

				updateHeaderStats();
				closeProfileModal();
				window.dispatchEvent(new Event('statsUpdated'));
