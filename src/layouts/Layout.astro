		padding: 0.6rem 1rem;
		cursor: pointer;
		font-family: var(--font-main);
		font-size: 0.86rem;
		font-weight: 600;
		color: var(--color-text);
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.5rem;
		transition: background var(--transition-fast), border-color var(--transition-fast);
	}

	.review-toggle:hover {
		background: var(--color-surface);
		border-color: var(--color-border-hover);
	}

	.review-caret {
		width: 10px;
		height: 6px;
		flex-shrink: 0;
		opacity: 0.6;
		transition: transform var(--transition-fast);
	}

	.review-toggle.open .review-caret { transform: rotate(180deg); }

	.review-list {
		margin-top: 0.6rem;
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
		max-height: 340px;
		overflow-y: auto;
		padding-right: 2px;
	}

	.review-item {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		padding: 0.7rem 0.85rem;
		font-size: 0.82rem;
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
	}

	.review-num {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 18px;
		height: 18px;
		background: var(--color-primary);
		color: #fff;
		border-radius: 50%;
		font-size: 0.68rem;
		font-weight: 700;
		flex-shrink: 0;
		margin-right: 0.4rem;
	}

	.review-q   { color: var(--color-text); font-weight: 500; line-height: 1.45; display: flex; align-items: flex-start; gap: 0; }
	.review-wrong   { color: var(--color-danger);  font-size: 0.79rem; padding-left: 0.25rem; }
	.review-correct { color: var(--color-success); font-size: 0.79rem; font-weight: 600; padding-left: 0.25rem; }

	.review-edu {
		color: var(--color-text-muted);
		font-size: 0.77rem;
		line-height: 1.55;
		border-top: 1px solid var(--color-border);
		margin-top: 0.2rem;
		padding-top: 0.4rem;
	}

	/* ─── Badge Unlock Overlay ───────────────────────────────────────────────── */

	.badge-unlock-overlay {
		position: fixed;
		inset: 0;
		z-index: 400;
		background: rgba(10, 30, 18, 0.6);
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 1rem;
		opacity: 0;
		transition: opacity 0.28s ease;
	}

	.badge-unlock-overlay.visible { opacity: 1; }

	.badge-unlock-card {
		background: var(--color-surface-solid);
		border: 1px solid rgba(212, 163, 43, 0.28);
		border-radius: var(--radius-lg);
		box-shadow: 0 24px 70px rgba(10, 30, 18, 0.32), 0 0 0 1px rgba(212, 163, 43, 0.1);
		padding: 2.5rem 2rem;
		width: 100%;
		max-width: 360px;
		text-align: center;
		position: relative;
		overflow: hidden;
		animation: card-pop 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) both;
	}

	@keyframes card-pop {
		from { transform: scale(0.82) translateY(20px); opacity: 0; }
		to   { transform: scale(1) translateY(0);       opacity: 1; }
	}

	.confetti-stage {
		position: absolute;
		inset: 0;
		pointer-events: none;
		overflow: hidden;
	}

	.unlock-sparkle {
		display: inline-block;
		background: linear-gradient(135deg, rgba(212, 163, 43, 0.15), rgba(212, 163, 43, 0.06));
		color: var(--color-gold);
		border: 1px solid rgba(212, 163, 43, 0.3);
		padding: 0.3rem 0.9rem;
		border-radius: var(--radius-full);
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.8px;
		text-transform: uppercase;
		margin-bottom: 1.25rem;
	}

	.unlock-icon {
		font-size: 4rem;
		line-height: 1;
		margin-bottom: 1rem;
		display: block;
		animation: icon-bounce 0.6s 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) both;
		filter: drop-shadow(0 4px 16px rgba(212, 163, 43, 0.35));
	}

	@keyframes icon-bounce {
		from { transform: scale(0.5) rotate(-15deg); opacity: 0; }
		to   { transform: scale(1) rotate(0deg);     opacity: 1; }
	}

	.unlock-name {
		font-size: 1.4rem;
		font-weight: 800;
		color: var(--color-text);
		margin-bottom: 0.45rem;
	}

	.unlock-desc {
		font-size: 0.88rem;
		color: var(--color-text-muted);
		margin-bottom: 1.75rem;
		line-height: 1.5;
	}

	/* ─── Streak Toast ────────────────────────────────────────────────────────── */

	.streak-toast {
		position: fixed;
		bottom: 1.5rem;
		right: 1.5rem;
		display: flex;
		align-items: center;
		gap: 0.85rem;
		background: var(--color-surface-solid);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		padding: 0.9rem 1.2rem;
		box-shadow: 0 8px 28px rgba(27, 77, 50, 0.14);
		z-index: 300;
		min-width: 240px;
		max-width: 320px;
		opacity: 0;
		transform: translateY(12px);
		pointer-events: none;
		transition: opacity 0.3s ease, transform 0.3s ease;
	}

	.streak-toast.show {
		opacity: 1;
		transform: translateY(0);
		pointer-events: auto;
	}

	#streak-toast-icon {
		font-size: 1.6rem;
		flex-shrink: 0;
	}

	.toast-body {
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
	}

	.toast-body strong {
		font-size: 0.9rem;
		font-weight: 700;
		color: var(--color-text);
	}

	.toast-body span {
		font-size: 0.78rem;
		color: var(--color-text-muted);
	}

	/* ─── Share Panel ─────────────────────────────────────────────────────────── */

	.share-panel {
		position: fixed;
		bottom: 1.5rem;
		left: 1.5rem;
		background: var(--color-surface-solid);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		padding: 1rem 1.1rem;
		box-shadow: 0 8px 28px rgba(27, 77, 50, 0.14);
		z-index: 290;
		width: 280px;
		opacity: 0;
		transform: translateY(12px);
		pointer-events: none;
		transition: opacity 0.3s ease, transform 0.3s ease;
	}

	.share-panel.show {
		opacity: 1;
		transform: translateY(0);
		pointer-events: auto;
	}

	.share-close {
		position: absolute;
		top: 0.6rem;
		right: 0.75rem;
		background: none;
		border: none;
		cursor: pointer;
		font-size: 0.8rem;
		color: var(--color-text-faint);
		padding: 0.15rem 0.3rem;
		border-radius: 4px;
		transition: color var(--transition-fast);
		font-family: var(--font-main);
	}

	.share-close:hover { color: var(--color-danger); }

	.share-header {
		display: flex;
		align-items: center;
		gap: 0.7rem;
		margin-bottom: 0.85rem;
	}

	.share-emoji { font-size: 1.5rem; flex-shrink: 0; }

	.share-header strong {
		display: block;
		font-size: 0.88rem;
		font-weight: 700;
		color: var(--color-text);
	}

	.share-header span {
		font-size: 0.73rem;
		color: var(--color-text-faint);
	}

	.share-actions {
		display: flex;
		gap: 0.5rem;
	}

	.btn-share-wa {
		flex: 1;
		background: #25d366;
		color: #ffffff !important;
		border: none;
		font-size: 0.82rem;
		padding: 0.55rem 0.75rem;
		border-radius: var(--radius-sm);
		display: flex;
		align-items: center;
		gap: 0.4rem;
		justify-content: center;
		font-weight: 600;
		cursor: pointer;
		transition: filter var(--transition-fast);
		text-decoration: none;
		font-family: var(--font-main);
	}

	.btn-share-wa:hover { filter: brightness(1.08); }

	.btn-copy-link {
		background: rgba(27, 77, 50, 0.06);
		color: var(--color-text-muted);
		border: 1px solid var(--color-border);
		font-size: 0.82rem;
		padding: 0.55rem 0.75rem;
		border-radius: var(--radius-sm);
		display: flex;
		align-items: center;
		gap: 0.4rem;
		font-weight: 600;
		cursor: pointer;
		transition: all var(--transition-fast);
		font-family: var(--font-main);
		white-space: nowrap;
	}

	.btn-copy-link:hover {
		background: rgba(27, 77, 50, 0.1);
		color: var(--color-primary);
	}

	/* ─── Main Content ────────────────────────────────────────────────────────── */

	.main-content {
		flex: 1;
		max-width: 1200px;
		width: 100%;
		margin: 0 auto;
		padding: 2rem 1.5rem;
	}

	/* ─── Footer ──────────────────────────────────────────────────────────────── */

	.app-footer {
		background: var(--color-surface-solid);
		border-top: 1px solid var(--color-border);
		padding: 1.75rem 1.5rem;
		text-align: center;
		color: var(--color-text-faint);
		font-size: 0.82rem;
	}

	.footer-container {
		max-width: 1200px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}

	.footer-container .credit {
		color: rgba(178, 131, 27, 0.7);
		font-style: italic;
	}

	.footer-brand {
		color: var(--color-gold);
		font-weight: 700;
		text-decoration: none;
		font-style: normal;
		border-bottom: 1px dotted rgba(178, 131, 27, 0.4);
		transition: border-color var(--transition-fast), color var(--transition-fast);
	}

	.footer-brand:hover {
		color: var(--color-gold-light);
		border-bottom-color: var(--color-gold-light);
	}

	/* ─── Glass Card ──────────────────────────────────────────────────────────── */

	.glass-card {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		box-shadow: var(--shadow-md);
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
		border-radius: var(--radius-lg);
		padding: 2rem;
		transition: box-shadow var(--transition-normal), border-color var(--transition-normal);
	}

	.glass-card:hover {
		box-shadow: var(--shadow-lg);
		border-color: var(--color-border-hover);
	}

	/* ─── Buttons ─────────────────────────────────────────────────────────────── */

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.45rem;
		font-family: var(--font-main);
		font-weight: 600;
		font-size: 0.9rem;
		padding: 0.7rem 1.4rem;
		border-radius: var(--radius-sm);
		border: none;
		cursor: pointer;
		text-decoration: none;
		transition: all var(--transition-fast);
		white-space: nowrap;
	}

	.btn:disabled {
		opacity: 0.45;
		cursor: not-allowed;
		transform: none !important;
	}

	.btn-primary {
		background: linear-gradient(135deg, var(--color-primary-light), var(--color-primary));
		color: #ffffff;
		box-shadow: 0 3px 10px rgba(27, 77, 50, 0.28);
	}

	.btn-primary:hover:not(:disabled) {
		transform: translateY(-2px);
		box-shadow: 0 5px 14px rgba(27, 77, 50, 0.38);
		filter: brightness(1.08);
	}

	.btn-primary:active:not(:disabled) {
		transform: translateY(0);
	}

	.btn-gold {
		background: linear-gradient(135deg, var(--color-gold), var(--color-gold-light));
		color: #ffffff;
		box-shadow: 0 3px 10px rgba(178, 131, 27, 0.28);
	}

	.btn-gold:hover:not(:disabled) {
		transform: translateY(-2px);
		box-shadow: 0 5px 14px rgba(212, 163, 43, 0.38);
	}

	.btn-secondary {
		background: rgba(27, 77, 50, 0.06);
		color: var(--color-text-muted);
		border: 1px solid var(--color-border);
	}

	.btn-secondary:hover:not(:disabled) {
		background: rgba(27, 77, 50, 0.1);
		border-color: var(--color-border-hover);
		color: var(--color-text);
	}

	/* ─── Modal Profil ────────────────────────────────────────────────────────── */

	.modal-overlay {
		position: fixed;
		inset: 0;
		z-index: 200;
		background: rgba(15, 46, 30, 0.45);
		backdrop-filter: blur(6px);
		-webkit-backdrop-filter: blur(6px);
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 1rem;
		animation: fadeIn 0.2s ease;
	}

	@keyframes fadeIn {
		from { opacity: 0; }
		to { opacity: 1; }
	}

	.modal-card {
		background: var(--color-surface-solid);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		box-shadow: 0 20px 60px rgba(15, 46, 30, 0.2);
		width: 100%;
		max-width: 440px;
		position: relative;
		animation: slideUp 0.25s ease;
		overflow: hidden;
	}

	@keyframes slideUp {
		from { opacity: 0; transform: translateY(16px); }
		to { opacity: 1; transform: translateY(0); }
	}

	.modal-close-btn {
		position: absolute;
		top: 1rem;
		right: 1rem;
		width: 32px;
		height: 32px;
		border-radius: 50%;
		border: 1px solid var(--color-border);
		background: var(--color-bg);
		color: var(--color-text-muted);
		font-size: 0.85rem;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: all var(--transition-fast);
		font-family: var(--font-main);
		z-index: 1;
	}

	.modal-close-btn:hover {
		background: rgba(165, 48, 26, 0.08);
		color: var(--color-danger);
		border-color: rgba(165, 48, 26, 0.2);
	}

	.modal-header-area {
		background: linear-gradient(135deg, rgba(27, 77, 50, 0.06) 0%, rgba(212, 163, 43, 0.04) 100%);
		border-bottom: 1px solid var(--color-border);
		padding: 2rem 2rem 1.75rem;
		text-align: center;
	}

	.modal-avatar-preview {
		font-size: 3rem;
		line-height: 1;
		margin-bottom: 0.85rem;
		transition: transform 0.2s ease;
	}

	.modal-title {
		font-size: 1.35rem;
		font-weight: 800;
		color: var(--color-text);
		margin-bottom: 0.5rem;
	}

	.modal-subtitle {
		font-size: 0.82rem;
		color: var(--color-text-muted);
		line-height: 1.5;
	}

	.modal-body-area {
		padding: 1.75rem 2rem;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.form-group {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.form-label {
		font-size: 0.82rem;
		font-weight: 700;
		color: var(--color-text);
		text-transform: uppercase;
		letter-spacing: 0.8px;
	}

	.form-input {
		font-family: var(--font-main);
		font-size: 0.95rem;
		padding: 0.7rem 1rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		background: var(--color-bg);
		color: var(--color-text);
		outline: none;
		transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
	}

	.form-input:focus {
		border-color: var(--color-primary-light);
		box-shadow: 0 0 0 3px rgba(42, 111, 74, 0.12);
	}

	.form-hint {
		font-size: 0.75rem;
		color: var(--color-text-faint);
	}

	.avatar-grid {
		display: grid;
		grid-template-columns: repeat(5, 1fr);
		gap: 0.5rem;
	}

	.avatar-option {
		aspect-ratio: 1;
		font-size: 1.5rem;
		border-radius: var(--radius-sm);
		border: 2px solid transparent;
		background: var(--color-bg);
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: all var(--transition-fast);
		padding: 0;
	}

	.avatar-option:hover {
		background: rgba(27, 77, 50, 0.06);
		border-color: var(--color-border-hover);
		transform: scale(1.1);
	}

	.avatar-option.selected {
		border-color: var(--color-primary-light);
		background: rgba(42, 111, 74, 0.1);
		box-shadow: 0 0 0 3px rgba(42, 111, 74, 0.1);
	}

	.modal-footer-area {
		padding: 1.25rem 2rem 1.75rem;
		display: flex;
		flex-direction: column;
		gap: 0.65rem;
	}

	.modal-footer-area .btn {
		width: 100%;
		padding: 0.8rem;
	}

	/* ─── Responsive ──────────────────────────────────────────────────────────── */

	@media (max-width: 900px) {
		.header-container {
			flex-wrap: wrap;
			padding: 0.85rem 1rem;
			gap: 0.75rem;
		}

		.nav-links {
			order: 3;
			width: 100%;
			justify-content: center;
			gap: 1.25rem;
		}

		.user-stats-bar {
			margin-left: auto;
		}

		.xp-progress-container {
			display: none;
		}
	}

	@media (max-width: 600px) {
		.user-stats-bar {
			width: 100%;
			justify-content: space-between;
		}

		.xp-progress-container {
			display: flex;
			flex: 1;
			max-width: 120px;
		}

		.username-text {
			display: none;
		}

		.modal-header-area {
			padding: 1.5rem 1.5rem 1.25rem;
		}

		.modal-body-area,
		.modal-footer-area {
			padding-left: 1.5rem;
			padding-right: 1.5rem;
		}
	}

	/* ═══════════════════════════════════════════════════════════════
	   GLOBAL OPTION BUTTON — dipakai di semua halaman kuis
	   Elemen dibuat dinamis via JS, sehingga harus global (is:global)
	   ═══════════════════════════════════════════════════════════════ */

	@keyframes option-enter {
		from { opacity: 0; transform: translateY(10px); }
		to   { opacity: 1; transform: translateY(0); }
	}
	@keyframes correct-pulse {
		0%   { box-shadow: 0 0 0 0 rgba(35, 108, 50, 0.45); }
		60%  { box-shadow: 0 0 0 10px rgba(35, 108, 50, 0); }
		100% { box-shadow: 0 0 0 3px rgba(35, 108, 50, 0.12); }
	}
	@keyframes wrong-shake {
		0%, 100% { transform: translateX(0); }
		20%      { transform: translateX(-7px); }
		50%      { transform: translateX(7px); }
		80%      { transform: translateX(-3px); }
	}

	.opt-btn {
		width: 100%;
		display: flex;
		align-items: stretch;
		border-radius: 12px;
		border: 2px solid #e2e8f0;
		background: #ffffff;
		text-align: left;
		cursor: pointer;
		overflow: hidden;
		font-family: 'Outfit', sans-serif;
		transition: border-color 0.18s, background 0.18s, box-shadow 0.18s, opacity 0.18s;
		animation: option-enter 0.26s ease both;
	}
	.opt-btn:hover:not(.is-answered) {
		border-color: #2a6f4a;
		box-shadow: 0 3px 12px rgba(27, 77, 50, 0.1);
	}
	.opt-btn:hover:not(.is-answered) .opt-letter {
		background: rgba(27, 77, 50, 0.06);
		color: #2a6f4a;
	}

	.opt-letter {
		width: 56px;
		min-width: 56px;
		display: flex;
		align-items: center;
		justify-content: center;
		font-weight: 800;
		font-size: 0.875rem;
		color: #94a3b8;
		background: #f8fafc;
		border-right: 1.5px solid #e2e8f0;
		flex-shrink: 0;
		padding: 1rem 0;
		transition: background 0.18s, color 0.18s, border-color 0.18s;
	}
	.opt-text {
		flex: 1;
		padding: 0.875rem 1rem;
		font-size: 0.9rem;
		font-weight: 500;
		color: #334155;
		line-height: 1.55;
		text-align: left;
		transition: color 0.18s;
	}
	.opt-indicator {
		width: 48px;
		min-width: 48px;
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}
	.opt-radio {
		width: 20px;
		height: 20px;
		border-radius: 50%;
		border: 2px solid #e2e8f0;
		background: transparent;
		transition: all 0.18s;
		flex-shrink: 0;
	}
	.opt-icon { display: none; width: 20px; height: 20px; flex-shrink: 0; }

	/* ── Selected ── */
	.opt-btn.is-selected {
		border-color: #b2831b;
		background: rgba(178, 131, 27, 0.04);
		box-shadow: 0 0 0 3px rgba(178, 131, 27, 0.14);
	}
	.opt-btn.is-selected .opt-letter {
		background: rgba(178, 131, 27, 0.1);
		color: #b2831b;
		border-right-color: rgba(178, 131, 27, 0.25);
	}
	.opt-btn.is-selected .opt-text { font-weight: 600; color: #1e293b; }
	.opt-btn.is-selected .opt-radio {
		border-color: #b2831b;
		background: #b2831b;
