			// ─── Streak Harian ───────────────────────────────────────────────────────

			function todayStr() {
				return new Date().toISOString().split('T')[0];
			}

			function yesterdayStr() {
				const d = new Date();
				d.setDate(d.getDate() - 1);
				return d.toISOString().split('T')[0];
			}

			function showStreakToast(icon: string, title: string, sub: string) {
				const toast   = document.getElementById('streak-toast');
				const iconEl  = document.getElementById('streak-toast-icon');
				const titleEl = document.getElementById('streak-toast-title');
				const subEl   = document.getElementById('streak-toast-sub');
				if (!toast) return;
				if (iconEl)  iconEl.textContent  = icon;
				if (titleEl) titleEl.textContent = title;
				if (subEl)   subEl.textContent   = sub;
				toast.classList.add('show');
				setTimeout(() => toast.classList.remove('show'), 4000);
			}

			function updateStreakDisplay(streak: number) {
				const el = document.getElementById('header-streak-count');
				const wrap = document.getElementById('header-streak');
				if (el) el.textContent = streak.toString();
				if (wrap) {
					wrap.classList.toggle('streak-active', streak >= 3);
					wrap.classList.toggle('streak-hot',    streak >= 7);
				}
			}

			function checkDailyStreak() {
				const today    = todayStr();
				const lastVisit  = localStorage.getItem('scout_last_visit') || '';
				const prevStreak = parseInt(localStorage.getItem('scout_streak') || '0');

				if (lastVisit === today) {
					updateStreakDisplay(prevStreak);
					return;
				}

				let newStreak: number;
				if (lastVisit === yesterdayStr()) {
					newStreak = prevStreak + 1;
				} else if (!lastVisit) {
					newStreak = 1;
				} else {
					newStreak = 1;
				}

				localStorage.setItem('scout_last_visit', today);
				localStorage.setItem('scout_streak', newStreak.toString());
				updateStreakDisplay(newStreak);

				// Streak putus setelah >2 hari
				if (!lastVisit) {
					// Kunjungan pertama — sapa saja
					setTimeout(() => showStreakToast('🌿', 'Selamat datang, Pandu!', 'Mulai kuis pertamamu hari ini.'), 1200);
					return;
				}

				if (lastVisit !== yesterdayStr() && prevStreak >= 3) {
					// Streak putus
					setTimeout(() => showStreakToast('😅', `Streak ${prevStreak} hari terputus`, 'Mulai lagi hari ini — kamu bisa!'), 1200);
					return;
				}

				// Bonus XP untuk streak hari ke-2+
				if (newStreak >= 2) {
					const bonusXp = newStreak >= 7 ? 15 : newStreak >= 3 ? 10 : 5;
					const xp = parseInt(localStorage.getItem('scout_xp') || '0');
					localStorage.setItem('scout_xp', (xp + bonusXp).toString());

					// Cek badge scout_master (500 XP)
					const newXp = xp + bonusXp;
					if (newXp >= 500) {
						const badges: string[] = JSON.parse(localStorage.getItem('scout_badges') || '[]');
						if (!badges.includes('scout_master')) {
							badges.push('scout_master');
							localStorage.setItem('scout_badges', JSON.stringify(badges));
						}
					}

					window.dispatchEvent(new Event('statsUpdated'));

					const msg = newStreak >= 7
						? `🔥 ${newStreak} hari berturut-turut!`
						: newStreak >= 3
							? `${newStreak} hari streak!`
							: 'Hari kedua!';
					setTimeout(() => showStreakToast('🔥', msg, `+${bonusXp} XP bonus streak`), 1000);
				}
			}

			// ─── Share Panel ─────────────────────────────────────────────────────────

			let shareTimeout: ReturnType<typeof setTimeout> | null = null;

			function showSharePanel(quizName: string, correct: number, total: number, pct: number) {
				const panel   = document.getElementById('share-panel');
				const emoji   = document.getElementById('share-emoji');
				const title   = document.getElementById('share-title');
				const sub     = document.getElementById('share-subtitle');
				const waBtn   = document.getElementById('btn-share-wa') as HTMLAnchorElement | null;
				if (!panel) return;

				const icon = pct === 100 ? '🏆' : pct >= 80 ? '⭐' : pct >= 60 ? '👍' : '📚';
				const pageUrl = window.location.origin + window.location.pathname;
				const msg = `Aku baru dapat ${pct}/100 di Kuis Pramuka: *${quizName}* ${icon}\n🏕️ Coba juga: ${pageUrl}`;

				if (emoji) emoji.textContent = icon;
				if (title) title.textContent = `${correct}/${total} Benar — ${quizName}`;
				if (sub)   sub.textContent   = 'Bagikan ke temanmu!';
				if (waBtn) waBtn.href = `https://wa.me/?text=${encodeURIComponent(msg)}`;

				panel.classList.add('show');
				if (shareTimeout) clearTimeout(shareTimeout);
				shareTimeout = setTimeout(() => panel.classList.remove('show'), 12000);
			}

			function checkAndShowShare() {
